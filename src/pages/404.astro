---
import Base from "../layouts/Base.astro";
import { getLangFromUrl, useTranslations } from "../i18n/locales";

const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);
const homeUrl = locale === "en" ? "/en" : "/";

Astro.cache.set({ maxAge: 3600 });
---

<Base title={t("404.title")} robots="noindex, nofollow">
	<section class="not-found">
		<div class="not-found-code">404</div>
		<h1>{t("404.title")}</h1>
		<p>{t("404.message")}</p>
		<a href={homeUrl} class="btn-primary">{t("404.goHome")}</a>
	</section>
</Base>

<style>
	.not-found {
		max-width: 480px;
		margin: var(--spacing-24) auto;
		text-align: center;
		padding: 0 var(--spacing-6);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-4);
	}

	.not-found-code {
		font-size: clamp(4rem, 12vw, 8rem);
		font-weight: 700;
		letter-spacing: -0.06em;
		background: var(--tc-gradient-text);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		line-height: 1;
	}

	.not-found h1 {
		font-size: var(--font-size-2xl);
		font-weight: 600;
		color: var(--color-text);
	}

	.not-found p {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
	}

	.btn-primary {
		display: inline-flex;
		padding: 14px 32px;
		background: var(--color-accent);
		color: #fff;
		font-weight: 600;
		border-radius: var(--radius-pill);
		text-decoration: none;
		transition: all 250ms ease;
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 30px rgba(200, 146, 42, 0.4);
		color: #fff;
	}
</style>
