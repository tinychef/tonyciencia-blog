---
import { getEmDashCollection, getEntryTerms, getSiteSettings } from "emdash";
import { Image } from "emdash/ui";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import { getReadingTime } from "../utils/reading-time";
import { resolveBlogSiteIdentity } from "../utils/site-identity";

const { entries: posts, cacheHint } = await getEmDashCollection("posts");
const { siteTitle, siteTagline } = resolveBlogSiteIdentity(await getSiteSettings());

Astro.cache.set(cacheHint);

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

const featuredPost = sortedPosts.find((p) => p.data.featured_image);
const featuredIndex = featuredPost ? sortedPosts.indexOf(featuredPost) : -1;
const gridPosts = sortedPosts.filter((_, i) => i !== featuredIndex).slice(0, 6);
const totalShown = (featuredPost ? 1 : 0) + gridPosts.length;
const hasMorePosts = sortedPosts.length > totalShown;

let featuredTags: Array<{ slug: string; label: string }> = [];
const featuredBylines = featuredPost?.data.bylines ?? [];
if (featuredPost) {
	const tags = await getEntryTerms("posts", featuredPost.data.id, "tag");
	featuredTags = tags.map((t) => ({ slug: t.slug, label: t.label }));
}

const gridPostsWithTags = await Promise.all(
	gridPosts.map(async (post) => {
		const tags = await getEntryTerms("posts", post.data.id, "tag");
		const bylines = post.data.bylines ?? [];
		return { post, tags: tags.map((t) => ({ slug: t.slug, label: t.label })), bylines };
	})
);

function formatDate(date: Date | null | undefined) {
	if (!date) return null;
	return date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}
---

<Base title={siteTitle} description={siteTagline}>
	<!-- ═══ HERO ═══════════════════════════════════════════════════════ -->
	<section class="hero">
		<div class="hero-inner">
			<div class="hero-badge">
				<span class="hero-badge-dot"></span>
				IA · Automatización · Crecimiento
			</div>
			<div class="hero-logo-wrap">
				<img
					src="/assets/logo-tonyciencia-full.webp"
					alt="Tony Ciencia"
					class="hero-logo"
					width="280"
					height="80"
					loading="eager"
					fetchpriority="high"
				/>
			</div>
			<h1 class="hero-title">
				Automatiza tu negocio.<br />
				<span class="hero-title-gradient">Escala con IA.</span>
			</h1>
			<p class="hero-subtitle">
				Cursos, apps y automatizaciones que convierten tu esfuerzo manual<br class="hero-br" />
				en sistemas que trabajan para ti — 24/7.
			</p>
			<div class="hero-actions">
				<a href="/servicios" class="btn-primary">Ver servicios</a>
				<a href="/posts" class="btn-secondary">Leer el blog</a>
			</div>
			<div class="hero-stats">
				<div class="hero-stat">
					<span class="stat-number">+500</span>
					<span class="stat-label">Estudiantes activos</span>
				</div>
				<div class="stat-divider"></div>
				<div class="hero-stat">
					<span class="stat-number">50+</span>
					<span class="stat-label">Workflows automatizados</span>
				</div>
				<div class="stat-divider"></div>
				<div class="hero-stat">
					<span class="stat-number">100%</span>
					<span class="stat-label">Enfoque en resultados</span>
				</div>
			</div>
		</div>
		<div class="hero-glow" aria-hidden="true"></div>
	</section>

	<!-- ═══ SERVICIOS ══════════════════════════════════════════════════ -->
	<section class="services-section">
		<div class="section-container">
			<div class="section-label">Lo que hacemos</div>
			<h2 class="section-heading">Tecnología que genera resultados reales</h2>
			<p class="section-sub">
				No vendemos humo. Cada servicio está diseñado para que recuperes tu tiempo
				y multipliques tu impacto.
			</p>
			<div class="services-grid">
				<div class="service-card">
					<div class="service-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 2a10 10 0 1 0 10 10H12V2z"/><path d="M12 2a10 10 0 0 1 10 10"/>
							<path d="M12 12 2.1 9.1"/>
						</svg>
					</div>
					<h3 class="service-title">Automatización con IA</h3>
					<p class="service-desc">
						Conectamos tus herramientas con n8n, Zapier y APIs propias para
						eliminar el trabajo repetitivo y reducir errores.
					</p>
					<a href="/servicios#automatizacion" class="service-link">
						Más info →
					</a>
				</div>
				<div class="service-card service-card--featured">
					<div class="service-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
							<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
						</svg>
					</div>
					<div class="service-badge">Más popular</div>
					<h3 class="service-title">Cursos & Formación Digital</h3>
					<p class="service-desc">
						Aprende a construir sistemas de IA, automatizar flujos de trabajo
						y escalar tu negocio con formación práctica y directa.
					</p>
					<a href="/servicios#cursos" class="service-link">
						Ver cursos →
					</a>
				</div>
				<div class="service-card">
					<div class="service-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
							<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
						</svg>
					</div>
					<h3 class="service-title">Apps & Herramientas Propias</h3>
					<p class="service-desc">
						Desarrollamos aplicaciones a medida con Cloudflare Workers, D1 y
						React para resolver problemas específicos de tu negocio.
					</p>
					<a href="/servicios#apps" class="service-link">
						Ver proyectos →
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══ CTA CENTRAL ════════════════════════════════════════════════ -->
	<section class="cta-section">
		<div class="cta-inner">
			<h2 class="cta-title">¿Listo para automatizar tu negocio?</h2>
			<p class="cta-sub">
				Agenda una llamada gratuita de 30 minutos y te mostramos exactamente
				qué automatizaciones tienen más impacto para ti.
			</p>
			<a href="/contacto" class="btn-primary btn-large">
				Habla con nosotros
			</a>
		</div>
		<div class="cta-glow" aria-hidden="true"></div>
	</section>

	<!-- ═══ BLOG ════════════════════════════════════════════════════════ -->
	<div class="home-content">
		{
			posts.length === 0 ? (
				<section class="empty-state">
					<h2>Sin artículos aún</h2>
					<p>Crea tu primer post desde el panel de administración.</p>
					<a href="/_emdash/admin/content/posts/new" class="btn-primary">
						Crear artículo
					</a>
				</section>
			) : (
				<>
					{featuredPost && (
						<section class="featured-section">
							<div class="featured-grid">
								<a href={`/posts/${featuredPost.id}`} class="featured-image-link">
									<div class="featured-image">
										<Image image={featuredPost.data.featured_image} />
									</div>
								</a>
								<div class="featured-content">
									<div class="featured-meta">
										{featuredBylines.length > 0 && (
											<>
												<div class="featured-bylines">
													{featuredBylines.slice(0, 2).map((credit, index) => (
														<>
															{index > 0 && <span class="byline-sep">,</span>}
															<span class="featured-byline">
																{credit.byline.avatarMediaId && (
																	<img
																		src={`/_emdash/api/media/file/${credit.byline.avatarMediaId}`}
																		alt={credit.byline.displayName}
																		class="featured-byline-avatar"
																	/>
																)}
																<span class="featured-byline-name">
																	{credit.byline.displayName}
																</span>
															</span>
														</>
													))}
													{featuredBylines.length > 2 && (
														<span class="byline-more">
															+{featuredBylines.length - 2}
														</span>
													)}
												</div>
												<span class="meta-dot" />
											</>
										)}
										{formatDate(featuredPost.data.publishedAt) && (
											<time>{formatDate(featuredPost.data.publishedAt)}</time>
										)}
										<span class="meta-dot" />
										<span>{getReadingTime(featuredPost.data.content)} min read</span>
									</div>
									<a href={`/posts/${featuredPost.id}`} class="featured-title-link">
										<h2 class="featured-title">{featuredPost.data.title}</h2>
									</a>
									{featuredPost.data.excerpt && (
										<p class="featured-excerpt">{featuredPost.data.excerpt}</p>
									)}
									{featuredTags.length > 0 && (
										<div class="featured-tags">
											{featuredTags.map((tag) => (
												<a href={`/tag/${tag.slug}`} class="featured-tag">
													{tag.label}
												</a>
											))}
										</div>
									)}
								</div>
							</div>
						</section>
					)}

					{gridPostsWithTags.length > 0 && (
						<section class="posts-section">
							<header class="section-header">
								<h2 class="section-title">Últimos artículos</h2>
								{hasMorePosts && (
									<a href="/posts" class="section-link">Ver todos</a>
								)}
							</header>
							<div class="posts-grid">
								{gridPostsWithTags.map(({ post, tags, bylines }) => (
									<PostCard
										title={post.data.title ?? "Sin título"}
										excerpt={post.data.excerpt}
										featuredImage={post.data.featured_image}
										href={`/posts/${post.id}`}
										date={post.data.publishedAt ?? undefined}
										readingTime={getReadingTime(post.data.content)}
										tags={tags}
										bylines={bylines}
									/>
								))}
							</div>
						</section>
					)}
				</>
			)
		}
	</div>
</Base>

<style>
	/* ── HERO — European Startup ──────────────────────────── */
	.hero {
		position: relative;
		overflow: hidden;
		padding: clamp(6rem, 14vw, 11rem) var(--spacing-6) clamp(5rem, 10vw, 9rem);
		text-align: center;
		background: var(--color-bg);
	}

	.hero-inner {
		position: relative;
		z-index: 1;
		max-width: 800px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-8);
	}

	.hero-glow {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse 60% 50% at 50% 0%, var(--color-accent-muted), transparent 70%),
			radial-gradient(circle 300px at 20% 80%, rgba(200, 146, 42, 0.06), transparent),
			radial-gradient(circle 250px at 85% 20%, rgba(224, 168, 50, 0.05), transparent);
		pointer-events: none;
		animation: glowPulse 8s ease-in-out infinite alternate;
	}

	@keyframes glowPulse {
		0% { opacity: 0.7; }
		100% { opacity: 1; }
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-2);
		padding: 6px 16px;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-pill);
		font-size: var(--font-size-xs);
		font-weight: 500;
		color: var(--color-accent);
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.hero-badge-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--color-accent);
		animation: pulse 2s ease-in-out infinite;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; transform: scale(1); }
		50% { opacity: 0.4; transform: scale(0.8); }
	}

	.hero-logo-wrap { display: flex; justify-content: center; }
	.hero-logo { height: clamp(44px, 7vw, 64px); width: auto; }

	.hero-title {
		font-size: clamp(2.5rem, 6vw, 4.25rem);
		font-weight: 700;
		line-height: 1.08;
		letter-spacing: -0.04em;
		color: var(--color-text);
		margin: 0;
	}

	.hero-title-gradient {
		background: var(--tc-gradient-text);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hero-subtitle {
		font-size: clamp(1.05rem, 1.8vw, 1.25rem);
		color: var(--color-muted);
		line-height: 1.7;
		max-width: 540px;
		margin: 0;
	}

	.hero-br { display: inline; }

	.hero-actions { display: flex; gap: var(--spacing-4); flex-wrap: wrap; justify-content: center; }

	.hero-stats {
		display: flex;
		align-items: center;
		gap: var(--spacing-10);
		flex-wrap: wrap;
		justify-content: center;
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border);
	}

	.hero-stat { display: flex; flex-direction: column; align-items: center; gap: 4px; }

	.stat-number {
		font-size: var(--font-size-3xl);
		font-weight: 700;
		letter-spacing: -0.03em;
		color: var(--color-text);
	}

	.stat-label {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.stat-divider { width: 1px; height: 40px; background: var(--color-border); }

	/* ── BUTTONS — Pill shaped ───────────────────────────── */
	.btn-primary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 14px 32px;
		background: var(--color-accent);
		color: #fff;
		font-weight: 600;
		font-size: var(--font-size-base);
		border-radius: var(--radius-pill);
		text-decoration: none;
		transition: all 250ms ease;
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 30px rgba(200, 146, 42, 0.4);
		color: #fff;
		background: var(--color-accent-hover);
	}

	.btn-primary.btn-large { padding: 18px 44px; font-size: var(--font-size-lg); }

	.btn-secondary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 13px 31px;
		border: 1.5px solid var(--color-border);
		color: var(--color-text);
		font-weight: 500;
		font-size: var(--font-size-base);
		border-radius: var(--radius-pill);
		text-decoration: none;
		transition: all 250ms ease;
	}

	.btn-secondary:hover {
		border-color: var(--color-accent);
		color: var(--color-accent);
		background: var(--color-accent-muted);
	}

	/* ── SERVICES — Glass cards ──────────────────────────── */
	.services-section {
		background: var(--color-bg-subtle);
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
		padding: clamp(5rem, 10vw, 8rem) var(--spacing-6);
	}

	.section-container { max-width: var(--wide-width); margin: 0 auto; }

	.section-label {
		font-size: var(--font-size-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--color-accent);
		margin-bottom: var(--spacing-4);
	}

	.section-heading {
		font-size: clamp(1.75rem, 3.5vw, 2.5rem);
		font-weight: 700;
		letter-spacing: -0.03em;
		color: var(--color-text);
		margin: 0 0 var(--spacing-4);
		max-width: 560px;
	}

	.section-sub {
		font-size: var(--font-size-lg);
		color: var(--color-muted);
		line-height: 1.7;
		max-width: 520px;
		margin: 0 0 var(--spacing-12);
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-6);
	}

	.service-card {
		position: relative;
		padding: var(--spacing-8);
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-xl);
		display: flex;
		flex-direction: column;
		gap: var(--spacing-4);
		transition: all 300ms ease;
	}

	.service-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
		border-color: var(--color-accent-muted);
	}

	.service-card--featured {
		border-color: color-mix(in srgb, var(--color-accent) 40%, var(--color-border));
		background: linear-gradient(160deg, var(--color-bg) 60%, var(--color-accent-muted));
	}

	.service-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 48px;
		height: 48px;
		border-radius: 14px;
		background: var(--color-accent-muted);
		color: var(--color-accent);
		flex-shrink: 0;
	}

	.service-badge {
		position: absolute;
		top: var(--spacing-4);
		right: var(--spacing-4);
		padding: 4px 12px;
		background: var(--color-accent);
		color: #fff;
		font-size: var(--font-size-xs);
		font-weight: 600;
		border-radius: var(--radius-pill);
		letter-spacing: 0.02em;
	}

	.service-title {
		font-size: var(--font-size-xl);
		font-weight: 600;
		letter-spacing: -0.02em;
		color: var(--color-text);
		margin: 0;
	}

	.service-desc {
		font-size: var(--font-size-base);
		color: var(--color-muted);
		line-height: 1.7;
		margin: 0;
		flex: 1;
	}

	.service-link {
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-accent);
		text-decoration: none;
		transition: color 200ms ease;
	}

	.service-link:hover { color: var(--color-accent-hover); }

	/* ── CTA — Premium ───────────────────────────────────── */
	.cta-section {
		position: relative;
		overflow: hidden;
		padding: clamp(5rem, 10vw, 7rem) var(--spacing-6);
		text-align: center;
		background: var(--color-bg);
	}

	.cta-inner {
		position: relative;
		z-index: 1;
		max-width: 600px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-6);
	}

	.cta-glow {
		position: absolute;
		inset: 0;
		background: radial-gradient(ellipse 70% 80% at 50% 100%, var(--color-accent-muted), transparent);
		pointer-events: none;
	}

	.cta-title {
		font-size: clamp(1.75rem, 4vw, 2.75rem);
		font-weight: 700;
		letter-spacing: -0.03em;
		color: var(--color-text);
		margin: 0;
	}

	.cta-sub {
		font-size: var(--font-size-lg);
		color: var(--color-muted);
		line-height: 1.7;
		margin: 0;
	}

	/* ── BLOG SECTION ────────────────────────────────────────── */
	.home-content {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-6);
	}

	.featured-section { margin-bottom: var(--spacing-16); }

	.featured-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-8);
		align-items: center;
	}

	.featured-image-link {
		grid-column: 1 / 3;
		display: block;
		margin-left: min(-6rem, calc(-1 * (var(--spacing-6) + (100vw - var(--wide-width)) / 2)));
	}

	.featured-image {
		overflow: hidden;
		border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
		background: var(--color-surface);
	}

	.featured-image img {
		width: 100%;
		height: auto;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.featured-image-link:hover .featured-image img,
	.featured-grid:has(.featured-title-link:hover) .featured-image img {
		transform: scale(1.02);
	}

	.featured-content {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-4);
	}

	.featured-meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		column-gap: var(--spacing-3);
		row-gap: var(--spacing-1);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	.meta-dot {
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--color-muted);
	}

	.featured-bylines {
		display: flex;
		align-items: center;
		gap: 2px;
	}

	.featured-byline {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-2);
	}

	.featured-byline-avatar {
		width: var(--avatar-size-md);
		height: var(--avatar-size-md);
		border-radius: 50%;
		object-fit: cover;
	}

	.featured-byline-name {
		font-weight: 500;
		color: var(--color-text-secondary);
	}

	.byline-sep { color: var(--color-muted); margin-right: 2px; }

	.byline-more {
		font-size: var(--font-size-xs);
