---
import Base from "../layouts/Base.astro";
---

<Base
	title="Servicios — Tony Ciencia"
	description="Automatización con IA, cursos digitales y desarrollo de apps a medida para escalar tu negocio."
>
	<!-- ═══ PAGE HERO ═══════════════════════════════════════════ -->
	<section class="page-hero">
		<div class="page-hero-inner">
			<div class="page-breadcrumb">
				<a href="/">Tony Ciencia</a>
				<span>→</span>
				<span>Servicios</span>
			</div>
			<h1 class="page-title">
				Tecnología que<br />
				<span class="title-gradient">genera resultados</span>
			</h1>
			<p class="page-subtitle">
				Cada servicio está diseñado para que recuperes tu tiempo y multipliques
				tu impacto — sin necesidad de un equipo técnico grande.
			</p>
		</div>
	</section>

	<!-- ═══ SERVICIO 1: AUTOMATIZACIÓN ══════════════════════════ -->
	<section id="automatizacion" class="service-block">
		<div class="service-block-inner">
			<div class="service-block-text">
				<div class="service-tag">Automatización</div>
				<h2 class="service-block-title">Automatización con IA</h2>
				<p class="service-block-desc">
					Conectamos tus herramientas favoritas — CRM, email, hojas de cálculo,
					bases de datos — para que trabajen juntas sin intervención manual.
					Usamos n8n, Zapier, y APIs propias construidas sobre Cloudflare Workers.
				</p>
				<ul class="service-feature-list">
					<li>Integración de CRM con automatización de leads</li>
					<li>Pipelines de email marketing automatizados</li>
					<li>Reportes automáticos con datos en tiempo real</li>
					<li>Agentes IA que responden y clasifican mensajes</li>
					<li>Sincronización entre plataformas (Zoho, HubSpot, Google Sheets)</li>
				</ul>
				<a href="/contacto" class="btn-primary">Quiero automatizar mi negocio →</a>
			</div>
			<div class="service-block-visual">
				<div class="visual-card">
					<div class="visual-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 2a10 10 0 1 0 10 10H12V2z"/><path d="M12 2a10 10 0 0 1 10 10"/>
							<path d="M12 12 2.1 9.1"/>
						</svg>
					</div>
					<div class="visual-metric">
						<span class="metric-val">−80%</span>
						<span class="metric-lbl">Tiempo en tareas repetitivas</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══ SERVICIO 2: CURSOS ═══════════════════════════════════ -->
	<section id="cursos" class="service-block service-block--alt">
		<div class="service-block-inner service-block-inner--reverse">
			<div class="service-block-text">
				<div class="service-tag">Formación</div>
				<h2 class="service-block-title">Cursos & Formación Digital</h2>
				<p class="service-block-desc">
					Aprende a construir sistemas de IA y automatización desde cero, con
					formación práctica orientada a resultados reales. Sin teoría vacía —
					solo lo que funciona en negocios como el tuyo.
				</p>
				<ul class="service-feature-list">
					<li>Cursos de IA aplicada al negocio</li>
					<li>Taller de automatización con n8n</li>
					<li>Formación en Cloudflare Workers y edge computing</li>
					<li>Comunidad de práctica activa</li>
					<li>Acceso de por vida + actualizaciones incluidas</li>
				</ul>
				<a href="/contacto" class="btn-primary">Ver próximos cursos →</a>
			</div>
			<div class="service-block-visual">
				<div class="visual-card">
					<div class="visual-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
							<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
						</svg>
					</div>
					<div class="visual-metric">
						<span class="metric-val">+500</span>
						<span class="metric-lbl">Estudiantes formados</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══ SERVICIO 3: APPS ══════════════════════════════════════ -->
	<section id="apps" class="service-block">
		<div class="service-block-inner">
			<div class="service-block-text">
				<div class="service-tag">Desarrollo</div>
				<h2 class="service-block-title">Apps & Herramientas Propias</h2>
				<p class="service-block-desc">
					Desarrollamos aplicaciones web a medida construidas sobre el edge de
					Cloudflare — rápidas, seguras y escalables desde el primer día. Sin
					servidores propios, sin complejidad operativa.
				</p>
				<ul class="service-feature-list">
					<li>Apps con Cloudflare Workers + D1 (SQLite en el edge)</li>
					<li>Interfaces React con Astro para máximo rendimiento</li>
					<li>Integraciones con APIs de terceros (Zoho, YouTube, PartnerStack)</li>
					<li>Dashboards de analítica y reporting</li>
					<li>Sistemas de afiliados y partners</li>
				</ul>
				<a href="/contacto" class="btn-primary">Cuéntame tu proyecto →</a>
			</div>
			<div class="service-block-visual">
				<div class="visual-card">
					<div class="visual-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
							<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
						</svg>
					</div>
					<div class="visual-metric">
						<span class="metric-val">&lt; 50ms</span>
						<span class="metric-lbl">Latencia global (edge)</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══ CTA FINAL ════════════════════════════════════════════ -->
	<section class="page-cta">
		<div class="page-cta-inner">
			<h2 class="page-cta-title">¿Por dónde empezamos?</h2>
			<p class="page-cta-sub">
				Agenda una llamada gratuita de 30 minutos. Sin compromiso, solo
				para entender qué es lo que más impacto puede tener en tu caso.
			</p>
			<a href="/contacto" class="btn-primary btn-large">Reservar llamada gratuita</a>
		</div>
	</section>
</Base>

<style>
	.page-hero {
		padding: clamp(4rem, 8vw, 7rem) var(--spacing-6) clamp(3rem, 6vw, 5rem);
		background: var(--color-bg);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.page-hero-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
	}

	.page-breadcrumb {
		display: flex;
		align-items: center;
		gap: var(--spacing-2);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin-bottom: var(--spacing-6);
	}

	.page-breadcrumb a {
		color: var(--color-muted);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.page-breadcrumb a:hover { color: var(--color-accent); }

	.page-title {
		font-size: clamp(2.25rem, 5vw, 3.5rem);
		font-weight: 700;
		letter-spacing: -0.03em;
		line-height: 1.12;
		color: var(--color-text);
		margin: 0 0 var(--spacing-6);
	}

	.title-gradient {
		background: var(--tc-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.page-subtitle {
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
		line-height: 1.65;
		max-width: 560px;
		margin: 0;
	}

	/* ── SERVICE BLOCKS ────────────────────────────────────── */
	.service-block {
		padding: clamp(4rem, 7vw, 6rem) var(--spacing-6);
	}

	.service-block--alt {
		background: var(--color-bg-subtle);
		border-top: 1px solid var(--color-border-subtle);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.service-block-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 380px;
		gap: var(--spacing-16);
		align-items: center;
	}

	.service-block-inner--reverse {
		grid-template-columns: 380px 1fr;
	}

	.service-block-inner--reverse .service-block-text {
		order: 2;
	}

	.service-block-inner--reverse .service-block-visual {
		order: 1;
	}

	.service-tag {
		display: inline-block;
		font-size: var(--font-size-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-accent);
		margin-bottom: var(--spacing-4);
	}

	.service-block-title {
		font-size: clamp(1.75rem, 3vw, 2.5rem);
		font-weight: 700;
		letter-spacing: -0.025em;
		color: var(--color-text);
		margin: 0 0 var(--spacing-5);
	}

	.service-block-desc {
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
		line-height: 1.65;
		margin: 0 0 var(--spacing-6);
	}

	.service-feature-list {
		list-style: none;
		padding: 0;
		margin: 0 0 var(--spacing-8);
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
	}

	.service-feature-list li {
		display: flex;
		align-items: flex-start;
		gap: var(--spacing-3);
		font-size: var(--font-size-base);
		color: var(--color-text-secondary);
	}

	.service-feature-list li::before {
		content: "✓";
		color: var(--color-accent);
		font-weight: 700;
		font-size: var(--font-size-sm);
		flex-shrink: 0;
		margin-top: 2px;
	}

	/* ── VISUAL CARD ──────────────────────────────────────── */
	.visual-card {
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-xl);
		padding: var(--spacing-12);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-8);
		text-align: center;
		box-shadow: 0 4px 24px rgba(2, 116, 190, 0.06);
	}

	.visual-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 72px;
		height: 72px;
		border-radius: 20px;
		background: var(--tc-gradient);
		color: white;
	}

	.visual-metric {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2);
	}

	.metric-val {
		font-size: clamp(2rem, 5vw, 3rem);
		font-weight: 700;
		letter-spacing: -0.03em;
		background: var(--tc-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.metric-lbl {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	/* ── BUTTONS ──────────────────────────────────────────── */
	.btn-primary {
		display: inline-flex;
		align-items: center;
		padding: 13px 28px;
		background: var(--tc-gradient);
		color: white;
		font-weight: 600;
		font-size: var(--font-size-base);
		border-radius: var(--radius-lg);
		text-decoration: none;
		transition: transform var(--transition-fast), box-shadow var(--transition-fast);
	}

	.btn-primary:hover {
		transform: translateY(-1px);
		box-shadow: 0 8px 24px rgba(2, 116, 190, 0.35);
		color: white;
	}

	.btn-primary.btn-large {
		padding: 16px 40px;
		font-size: var(--font-size-lg);
		border-radius: var(--radius-xl);
	}

	/* ── PAGE CTA ─────────────────────────────────────────── */
	.page-cta {
		padding: clamp(4rem, 8vw, 6rem) var(--spacing-6);
		text-align: center;
		background: var(--color-bg-subtle);
		border-top: 1px solid var(--color-border-subtle);
	}

	.page-cta-inner {
		max-width: 560px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-5);
	}

	.page-cta-title {
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		font-weight: 700;
		letter-spacing: -0.025em;
		color: var(--color-text);
		margin: 0;
	}

	.page-cta-sub {
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
		line-height: 1.65;
		margin: 0;
	}

	/* ── RESPONSIVE ──────────────────────────────────────── */
	@media (max-width: 900px) {
		.service-block-inner,
		.service-block-inner--reverse {
			grid-template-columns: 1fr;
			gap: var(--spacing-10);
		}

		.service-block-inner--reverse .service-block-text,
		.service-block-inner--reverse .service-block-visual {
			order: unset;
		}
	}
</style>
