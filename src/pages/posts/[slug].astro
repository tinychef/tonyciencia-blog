---
import {
	getEmDashEntry,
	getEmDashCollection,
	getEntryTerms,
	getSeoMeta,
	decodeSlug,
	getSiteSettings,
} from "emdash";
import {
	Image,
	PortableText,
	Comments,
	CommentForm,
	WidgetArea,
} from "emdash/ui";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import AuthorBio from "../../components/AuthorBio.astro";
import ArticleMeta from "../../components/ArticleMeta.astro";
import { getReadingTime } from "../../utils/reading-time";
import { resolveBlogSiteIdentity } from "../../utils/site-identity";
import { getStaticPost, getStaticPosts, getStaticTags } from "../../utils/static-posts";
import { getLangFromUrl, useTranslations } from "../../i18n/locales";

const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: cmsPost, cacheHint } = await getEmDashEntry("posts", slug);
const staticPost = cmsPost ? null : getStaticPost("es", slug);
const post = (cmsPost ?? staticPost) as any;
const isStaticPost = !cmsPost && !!staticPost;

if (!post) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);

// Get featured image URL for OG fallback
// The image may have src (external) or meta.storageKey (local)
function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	// Check for direct src
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http")
			? image.src
			: `${Astro.url.origin}${image.src}`;
	}
	// Build from storageKey for local images
	const meta = image.meta as Record<string, unknown> | undefined;
	const storageKey =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	if (storageKey) {
		return `${Astro.url.origin}/_emdash/api/media/file/${storageKey}`;
	}
	return undefined;
}
const featuredImageUrl = getImageUrl(post.data.featured_image);
const { siteTitle } = resolveBlogSiteIdentity(await getSiteSettings());

// Generate SEO meta from content
const seo = isStaticPost
	? {
			title: `${post.data.title} — ${siteTitle}`,
			ogTitle: post.data.title,
			description: post.data.excerpt ?? "",
			ogImage: featuredImageUrl,
			canonical: new URL(`/posts/${slug}`, Astro.site ?? Astro.url.origin).href,
			robots: null,
		}
	: getSeoMeta(post as any, {
			siteTitle,
			siteUrl: Astro.url.origin,
			path: `/posts/${slug}`,
			defaultOgImage: featuredImageUrl,
		});
const canonicalUrl = seo.canonical || new URL(`/posts/${slug}`, Astro.site ?? Astro.url.origin).href;

// Get tags for this post
// Note: post.id is the slug, post.data.id is the database ULID
const tags = isStaticPost ? getStaticTags(post) : await getEntryTerms("posts", post.data.id, "tag");

// Bylines are already hydrated by getEmDashEntry
const bylines = post.data.bylines ?? [];

// Get reading time
const readingTime = getReadingTime(post.data.content as any);

// Get other posts for "Related posts" section
// Strategy: shared categories first, then shared tags, then recent posts.
// PERF: cuando el post se sirve estático NO tocamos D1 — los queries de
// categoría/tag/recientes se descartaban igual (relatedPosts se sobrescribía).
// eslint-disable-next-line @typescript-eslint/no-explicit-any
let relatedPosts: any[] = [];

if (isStaticPost) {
	relatedPosts = getStaticPosts("es")
		.filter((candidate) => candidate.id !== post.id)
		.slice(0, 4);
} else {
	const postCategories = await getEntryTerms("posts", post.data.id, "category");

	const categoryResults = await Promise.all(
		postCategories.map((cat) =>
			getEmDashCollection("posts", {
				where: { category: cat.slug },
				orderBy: { published_at: "desc" },
				limit: 6,
				locale: "es",
			})
		)
	);

	for (const { entries: catPosts } of categoryResults) {
		for (const cp of catPosts) {
			if (cp.id !== post.id && !relatedPosts.find((r) => r.id === cp.id)) {
				relatedPosts.push(cp);
			}
			if (relatedPosts.length >= 4) break;
		}
		if (relatedPosts.length >= 4) break;
	}

	if (relatedPosts.length < 4 && tags.length > 0) {
		const tagResults = await Promise.all(
			tags.map((tag) =>
				getEmDashCollection("posts", {
					where: { tag: tag.slug },
					orderBy: { published_at: "desc" },
					limit: 6,
					locale: "es",
				})
			)
		);

		for (const { entries: tagPosts } of tagResults) {
			for (const tp of tagPosts) {
				if (tp.id !== post.id && !relatedPosts.find((r) => r.id === tp.id)) {
					relatedPosts.push(tp);
				}
				if (relatedPosts.length >= 4) break;
			}
			if (relatedPosts.length >= 4) break;
		}
	}

	// Fallback to recent posts if still not enough
	if (relatedPosts.length < 4) {
		const { entries: recentPosts } = await getEmDashCollection("posts", {
			orderBy: { published_at: "desc" },
			limit: 8,
			locale: "es",
		});
		for (const rp of recentPosts) {
			if (rp.id !== post.id && !relatedPosts.find((r) => r.id === rp.id)) {
				relatedPosts.push(rp);
			}
			if (relatedPosts.length >= 4) break;
		}
	}
}
const otherPosts = relatedPosts.slice(0, 4);

// Extract FAQ items from post data for FAQPage schema
function extractFaqItems(faqData: unknown): Array<{ question: string; answer: string }> {
	if (!faqData || !Array.isArray(faqData)) return [];
	const items: Array<{ question: string; answer: string }> = [];
	const blocks = faqData as Array<{ _type: string; style?: string; children?: Array<{ text?: string }> }>;
	for (let i = 0; i < blocks.length; i++) {
		const block = blocks[i];
		if (block._type === "block" && block.style === "h3") {
			const question = block.children?.map((c) => c.text ?? "").join("") ?? "";
			const nextBlock = blocks[i + 1];
			const answer = nextBlock?.children?.map((c) => c.text ?? "").join("") ?? "";
			if (question && answer) {
				items.push({ question, answer });
				i++;
			}
		}
	}
	return items;
}
const faqItems = extractFaqItems(post.data.faq_items);

const { entries: translatedPosts } = isStaticPost
	? { entries: getStaticPosts("en").filter((candidate) => candidate.data.translation_of === slug).slice(0, 1) }
	: await getEmDashCollection("posts", {
			where: { translation_of: slug },
			locale: "en",
			limit: 1,
		});

const translatedPost = translatedPosts[0];
const alternatePath = translatedPost ? `/en/posts/${translatedPost.id}` : undefined;

// Fetch tags for related posts (bylines are already hydrated by getEmDashCollection)
const otherPostsWithTags = await Promise.all(
	otherPosts.map(async (p) => {
		const postTags = isStaticPost ? getStaticTags(p) : await getEntryTerms("posts", p.data.id, "tag");
		const postBylines = p.data.bylines ?? [];
		return { post: p, tags: postTags, bylines: postBylines };
	})
);

const publishDate =
	post.data.publishedAt?.toLocaleDateString(locale === "en" ? "en-US" : "es-ES", {
		year: "numeric",
		month: "long",
		day: "numeric",
	}) ?? null;
---

<Base
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	image={seo.ogImage}
	canonical={seo.canonical}
	robots={seo.robots}
	type="article"
	publishedTime={post.data.publishedAt?.toISOString() ?? null}
	modifiedTime={post.data.updatedAt.toISOString()}
	author={bylines.length > 0 ? bylines[0].byline.displayName : null}
	breadcrumbs={[
		{ name: "Blog", url: locale === "en" ? "/en/posts" : "/posts" },
		{ name: post.data.title, url: `${locale === "en" ? "/en/posts" : "/posts"}/${slug}` },
	]}
	content={isStaticPost ? undefined : { collection: "posts", id: post.data.id, slug }}
	schemaType={post.data.schema_type || (faqItems.length > 0 ? "BlogPosting" : undefined)}
	faqItems={faqItems.length > 0 ? faqItems : undefined}
	readingTime={readingTime}
	alternatePath={alternatePath}
>
	<div class="reading-progress" id="reading-progress"></div>
	<button type="button" class="back-to-top" id="back-to-top" aria-label="Back to top">
		<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
	</button>
	<article class="article">
		{/* Hero: Full-width featured image */}
		{
			post.data.featured_image && (
				<div class="article-hero" {...post.edit.featured_image}>
					{isStaticPost ? (
						<img src={(post.data.featured_image as any).src} alt={(post.data.featured_image as any).alt ?? post.data.title} loading="eager" decoding="async" />
					) : (
						<Image image={post.data.featured_image as any} />
					)}
				</div>
			)
		}

		{/* Three-column layout */}
		<div class="article-grid">
			{/* Left gutter: Meta information */}
			<aside class="article-meta-col">
				<div class="meta-sticky">
					{
						bylines.length > 0 && (
							<div class="meta-block byline-block">
								<span class="meta-label">
									{bylines.length === 1 ? t("posts.author") : t("posts.authors")}
								</span>
								<div class="bylines">
									{bylines.map((credit) => (
										<div class="byline">
											{credit.byline.avatarMediaId && (
												<img
													src={`/_emdash/api/media/file/${credit.byline.avatarMediaId}`}
													alt={credit.byline.displayName}
													class="byline-avatar"
													width="32" height="32" loading="lazy" decoding="async"
												/>
											)}
											<div class="byline-info">
												<span class="byline-name">
													{credit.byline.displayName}
												</span>
												{credit.roleLabel && (
													<span class="byline-role">{credit.roleLabel}</span>
												)}
											</div>
										</div>
									))}
								</div>
							</div>
						)
					}
					{
						publishDate && (
							<div class="meta-block">
								<span class="meta-label">{t("posts.published")}</span>
								<time class="meta-value">{publishDate}</time>
							</div>
						)
					}
					<div class="meta-block">
						<span class="meta-label">{t("posts.readingTime")}</span>
						<span class="meta-value">{readingTime} min</span>
					</div>
					{
						tags.length > 0 && (
							<div class="meta-block">
								<span class="meta-label">{t("posts.tags")}</span>
								<div class="meta-tags">
									{tags.map((t) => (
										<a href={`${locale === "en" ? "/en/tag" : "/tag"}/${t.slug}`} class="meta-tag">
											{t.label}
										</a>
									))}
								</div>
							</div>
						)
					}
				</div>
			</aside>

			{/* Main content */}
			<div class="article-main">
				<header class="article-header">
					<div class="article-meta">
						{
							bylines.length > 0 && (
								<>
									<span class="article-meta-byline">
										{bylines.map((credit, i) => (
											<>
												{i > 0 && ", "}
												{credit.byline.displayName}
											</>
										))}
									</span>
									<span class="meta-dot" />
								</>
							)
						}
						{
							publishDate && (
								<>
									<time>{publishDate}</time>
									<span class="meta-dot" />
								</>
							)
						}
						<span>{readingTime} {t("blog.minRead")}</span>
					</div>
					<h1 class="article-title" {...post.edit.title}>{post.data.title}</h1>
					{
						post.data.excerpt && (
							<p class="article-excerpt" {...post.edit.excerpt}>{post.data.excerpt}</p>
						)
					}
					<div class="share-bar" id="share-bar">
						<span class="share-label">{locale === "en" ? "Share:" : "Compartir:"}</span>
						<button type="button" class="share-btn share-native" aria-label="Share" data-url={canonicalUrl}>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
						</button>
						<a class="share-btn" href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(canonicalUrl)}&text=${encodeURIComponent(post.data.title)}`} target="_blank" rel="noopener noreferrer" aria-label="X / Twitter">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
						</a>
						<a class="share-btn" href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalUrl)}`} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
						</a>
						<a class="share-btn" href={`https://wa.me/?text=${encodeURIComponent(post.data.title + " " + canonicalUrl)}`} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
						</a>
						<button type="button" class="share-btn share-copy" aria-label="Copy link" data-url={canonicalUrl}>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
						</button>
					</div>
				</header>

				<div class="article-content">
					<PortableText value={post.data.content} />
				</div>

				<ArticleMeta publishedTime={post.data.publishedAt?.toISOString() ?? null} modifiedTime={post.data.updatedAt.toISOString()} readingTime={readingTime} locale={locale} />
				<AuthorBio bylines={bylines} locale={locale} />

				{!isStaticPost && (
					<div class="article-comments">
						<Comments collection="posts" contentId={post.data.id} threaded />
						<CommentForm collection="posts" contentId={post.data.id} />
					</div>
				)}
			</div>

			{/* Right gutter: TOC + Sidebar widgets */}
			<aside class="article-sidebar">
				<div class="sidebar-sticky">
					<nav class="toc" aria-label="Table of contents">
						<h4 class="toc-title">{t("posts.onThisPage")}</h4>
						<div class="toc-content" id="toc-content">
							<!-- Populated by JS -->
						</div>
					</nav>
					<div class="sidebar-widgets">
						<WidgetArea name="sidebar" />
					</div>
				</div>
			</aside>
		</div>
	</article>

	{
		otherPostsWithTags.length > 0 && (
			<section class="more-posts">
				<div class="more-inner">
					<h2 class="more-title">{t("posts.relatedPosts")}</h2>
					<div class="more-grid">
						{otherPostsWithTags.map(
							({ post: p, tags: postTags, bylines: postBylines }) => (
								<PostCard
									title={p.data.title}
									excerpt={p.data.excerpt}
									featuredImage={p.data.featured_image}
									href={`/posts/${p.id}`}
									date={p.data.publishedAt ?? undefined}
									readingTime={getReadingTime(p.data.content)}
									tags={postTags.map((t) => ({ slug: t.slug, label: t.label }))}
									bylines={postBylines}
								/>
							)
						)}
					</div>
				</div>
			</section>
		)
	}

	<script>
		// 2.1 Reading progress bar
		(function () {
			const bar = document.getElementById("reading-progress");
			if (!bar) return;
			let ticking = false;
			function updateProgress() {
				const scrollTop = window.scrollY;
				const docHeight = document.documentElement.scrollHeight - window.innerHeight;
				const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
				bar.style.width = progress + "%";
				ticking = false;
			}
			window.addEventListener("scroll", () => {
				if (!ticking) {
					requestAnimationFrame(updateProgress);
					ticking = true;
				}
			}, { passive: true });
		})();

		// 2.5 Back to top button
		(function () {
			const btn = document.getElementById("back-to-top");
			if (!btn) return;
			function toggleBtn() {
				if (window.scrollY > 500) btn.classList.add("is-visible");
				else btn.classList.remove("is-visible");
			}
			window.addEventListener("scroll", toggleBtn, { passive: true });
			btn.addEventListener("click", () => {
				window.scrollTo({ top: 0, behavior: "smooth" });
			});
			toggleBtn();
		})();

		// 2.2 Share buttons
		(function () {
			const nativeBtn = document.querySelector(".share-native") as HTMLButtonElement | null;
			const copyBtn = document.querySelector(".share-copy") as HTMLButtonElement | null;
			if (nativeBtn) {
				if (!navigator.share) {
					nativeBtn.style.display = "none";
				} else {
					nativeBtn.addEventListener("click", async () => {
						try {
							await navigator.share({ url: nativeBtn.dataset.url });
						} catch {}
					});
				}
			}
			if (copyBtn) {
				copyBtn.addEventListener("click", async () => {
					try {
						await navigator.clipboard.writeText(copyBtn.dataset.url || "");
						copyBtn.classList.add("copied");
						setTimeout(() => copyBtn.classList.remove("copied"), 2000);
					} catch {}
				});
			}
		})();

		// 2.3 Copy code button
		(function () {
			document.querySelectorAll(".article-content pre").forEach((pre) => {
				const btn = document.createElement("button");
				btn.className = "copy-code-btn";
				btn.type = "button";
				btn.setAttribute("aria-label", "Copy code");
				btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg><span>Copy</span>';
				btn.addEventListener("click", async () => {
					const code = pre.querySelector("code");
					if (!code) return;
					try {
						await navigator.clipboard.writeText(code.textContent || "");
						btn.classList.add("copied");
						btn.querySelector("span")!.textContent = "Copied!";
						setTimeout(() => {
							btn.classList.remove("copied");
							btn.querySelector("span")!.textContent = "Copy";
						}, 2000);
					} catch {}
				});
				(pre as HTMLElement).style.position = "relative";
				pre.appendChild(btn);
			});
		})();

		// 2.4 Anchor links on headings
		(function () {
			const content = document.querySelector(".article-content");
			if (!content) return;
			content.querySelectorAll("h2, h3").forEach((heading) => {
				if (!heading.id) return;
				const anchor = document.createElement("a");
				anchor.className = "heading-anchor";
				anchor.href = `#${heading.id}`;
				anchor.setAttribute("aria-label", "Link to this section");
				anchor.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>';
				heading.appendChild(anchor);
			});
		})();

		// Build table of contents from h2/h3 headings
		function buildToc() {
			const content = document.querySelector(".article-content");
			const tocContainer = document.getElementById("toc-content");
			if (!content || !tocContainer) return;

			const headings = content.querySelectorAll("h2, h3");
			if (headings.length === 0) {
				const toc = document.querySelector(".toc") as HTMLElement | null;
				if (toc) toc.style.display = "none";
				return;
			}

			const list = document.createElement("ul");
			list.className = "toc-list";

			headings.forEach((heading, index) => {
				if (!heading.id) {
					heading.id = `heading-${index}`;
				}

				const li = document.createElement("li");
				li.className =
					heading.tagName === "H3" ? "toc-item toc-item--nested" : "toc-item";

				const link = document.createElement("a");
				link.href = `#${heading.id}`;
				link.className = "toc-link";
				link.textContent = heading.textContent;

				li.appendChild(link);
				list.appendChild(li);
			});

			tocContainer.appendChild(list);

			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						const id = entry.target.id;
						const link = tocContainer.querySelector(`a[href="#${id}"]`);
						if (link) {
							if (entry.isIntersecting) {
								tocContainer
									.querySelectorAll(".toc-link")
									.forEach((l) => l.classList.remove("active"));
								link.classList.add("active");
							}
						}
					});
				},
				{ rootMargin: "-80px 0px -80% 0px" }
			);

			headings.forEach((heading) => observer.observe(heading));
		}

		// 2.6 Mobile TOC dropdown
		function buildMobileToc() {
			const content = document.querySelector(".article-content");
			const header = document.querySelector(".article-header");
			if (!content || !header) return;
			const headings = content.querySelectorAll("h2, h3");
			if (headings.length === 0) return;

			const wrapper = document.createElement("details");
			wrapper.className = "mobile-toc";
			wrapper.innerHTML = `<summary>${document.querySelector(".toc-title")?.textContent || "On this page"}</summary>`;
			const list = document.createElement("ul");
			list.className = "mobile-toc-list";
			headings.forEach((heading) => {
				const li = document.createElement("li");
				li.className = heading.tagName === "H3" ? "mobile-toc-item mobile-toc-item--nested" : "mobile-toc-item";
				const a = document.createElement("a");
				a.href = `#${heading.id}`;
				a.className = "mobile-toc-link";
				a.textContent = heading.textContent;
				li.appendChild(a);
				list.appendChild(li);
			});
			wrapper.appendChild(list);
			header.after(wrapper);
		}

		buildToc();
		buildMobileToc();
	</script>
</Base>

