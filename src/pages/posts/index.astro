---
import { getEmDashCollection, getEntryTerms } from "emdash";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { getReadingTime } from "../../utils/reading-time";
import { getLangFromUrl, useTranslations } from "../../i18n/locales";

const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);

const { entries: posts, cacheHint } = await getEmDashCollection("posts", { locale });
Astro.cache.set(cacheHint);

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

const postsWithTags = await Promise.all(
	sortedPosts.map(async (post) => ({
		post,
		tags: (await getEntryTerms("posts", post.data.id, "tag")).map((tag) => ({ slug: tag.slug, label: tag.label })),
		bylines: post.data.bylines ?? [],
	}))
);
---

<Base title={t("posts.title")} description={t("posts.description")}>
	<section class="posts-hero">
		<div class="tc-shell posts-hero-inner">
			<span class="tc-eyebrow">AI Radar</span>
			<h1>{t("posts.title")}</h1>
			<p>{locale === "en" ? "Enterprise AI, automation, agents, and productivity guides for companies that need practical implementation." : "IA empresarial, automatización, agentes y productividad para empresas que necesitan implementación práctica."}</p>
			<div class="posts-count">{posts.length} {posts.length === 1 ? "article" : "articles"}</div>
		</div>
	</section>

	<section class="posts-catalog">
		<div class="tc-shell">
			{sortedPosts.length === 0 ? (
				<p class="empty">{t("posts.noPostsYet")}</p>
			) : (
				<div class="posts-grid">
					{postsWithTags.map(({ post, tags, bylines }) => (
						<PostCard
							title={post.data.title}
							excerpt={post.data.excerpt}
							featuredImage={post.data.featured_image}
							href={`/posts/${post.id}`}
							date={post.data.publishedAt ?? undefined}
							readingTime={getReadingTime(post.data.content)}
							tags={tags}
							bylines={bylines}
						/>
					))}
				</div>
			)}
		</div>
	</section>
</Base>

<style>
	.posts-hero {
		padding: clamp(4rem, 8vw, 7rem) 0 clamp(3rem, 6vw, 5rem);
		border-bottom: 1px solid var(--color-border-subtle);
		background:
			var(--tc-grid),
			linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 10%, transparent), transparent 42%),
			var(--color-bg);
		background-size: 46px 46px, auto, auto;
	}

	.posts-hero-inner {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: var(--spacing-5);
	}

	.posts-hero h1 {
		max-width: 880px;
		font-size: clamp(3rem, 8vw, 6.5rem);
		line-height: 0.9;
		letter-spacing: -0.08em;
	}

	.posts-hero p {
		max-width: 62ch;
		color: var(--color-text-secondary);
		font-size: clamp(1.05rem, 1.4vw, 1.28rem);
		line-height: 1.75;
	}

	.posts-count {
		padding: 0.45rem 0.8rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-pill);
		background: var(--color-bg);
		color: var(--color-muted);
		font-size: var(--font-size-sm);
		font-weight: 800;
	}

	.posts-catalog {
		padding: clamp(3rem, 7vw, 6rem) 0;
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-5);
	}

	.empty {
		color: var(--color-muted);
		font-size: var(--font-size-lg);
	}

	@media (max-width: 980px) {
		.posts-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 640px) {
		.posts-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
