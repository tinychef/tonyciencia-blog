---
import { getEmDashEntry, decodeSlug } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../../../layouts/Base.astro";

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: page, cacheHint } = await getEmDashEntry("legal_pages", slug);

if (!page) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);
---

<Base
	title={`${page.data.title} — Tony Ciencia`}
	description={page.data.title}
	content={{ collection: "legal_pages", id: page.data.id, slug }}
>
	<article class="legal-page">
		<div class="legal-inner">
			<h1 {...page.edit.title}>{page.data.title}</h1>
			<div class="legal-content">
				<PortableText value={page.data.content} />
			</div>
			{page.data.last_reviewed && (
				<p class="legal-reviewed">Last reviewed: {new Date(page.data.last_reviewed).toLocaleDateString("en", { year: "numeric", month: "long", day: "numeric" })}</p>
			)}
		</div>
	</article>
</Base>

<style>
	.legal-page { padding: var(--spacing-16) var(--spacing-6); }
	.legal-inner { max-width: var(--content-width); margin: 0 auto; }
	.legal-inner :global(h1) { font-size: var(--font-size-3xl); font-weight: 700; letter-spacing: -0.03em; margin-bottom: var(--spacing-8); }
	.legal-inner :global(h2) { font-size: var(--font-size-xl); font-weight: 600; margin-top: var(--spacing-10); margin-bottom: var(--spacing-4); }
	.legal-inner :global(p) { color: var(--color-text-secondary); line-height: var(--leading-relaxed); margin-bottom: var(--spacing-4); }
	.legal-inner :global(a) { color: var(--color-accent); }
	.legal-reviewed { margin-top: var(--spacing-12); font-size: var(--font-size-sm); color: var(--color-muted); border-top: 1px solid var(--color-border); padding-top: var(--spacing-4); }
</style>
