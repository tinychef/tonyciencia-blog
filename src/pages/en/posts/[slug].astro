---
import { getEmDashEntry, getEntryTerms, getSeoMeta } from "emdash";
import { Image, PortableText } from "emdash/ui";
import Base from "../../../layouts/Base.astro";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/404");

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);
if (!post) return Astro.redirect("/404");

Astro.cache.set(cacheHint);

const seo = getSeoMeta(post, {
	siteTitle: "Tony Ciencia",
	siteUrl: Astro.url.origin,
	path: `/en/posts/${slug}`,
});

const tags = await getEntryTerms("posts", post.data.id, "tag");
const translationSlug = post.data.translation_of;
---

<Base
	title={seo.title}
	description={seo.description}
	type="article"
	image={seo.ogImage}
	content={{ collection: "posts", id: post.data.id, slug }}
	publishedTime={post.data.publishedAt?.toISOString()}
	modifiedTime={post.data.updatedAt?.toISOString()}
	author={post.data.byline?.displayName}
>
	<article class="article-page">
		<div class="article-inner">
			{post.data.featured_image && (
				<div class="article-hero" {...post.edit.featured_image}>
					<Image image={post.data.featured_image} />
				</div>
			)}
			<h1 class="article-title" {...post.edit.title}>{post.data.title}</h1>
			<div class="article-meta">
				{post.data.byline && <span class="article-author">{post.data.byline.displayName}</span>}
				{post.data.publishedAt && (
					<time>{post.data.publishedAt.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</time>
				)}
			</div>
			{translationSlug && (
				<a href={`/posts/${translationSlug}`} class="translation-link">🇪🇸 Leer en español</a>
			)}
			<div class="article-content">
				<PortableText value={post.data.content} />
			</div>
			{tags.length > 0 && (
				<div class="article-tags">
					{tags.map((t) => <a href={`/en/tag/${t.slug}`} class="article-tag">{t.label}</a>)}
				</div>
			)}
		</div>
	</article>
</Base>

<style>
	.article-page { padding: var(--spacing-12) var(--spacing-6) var(--spacing-16); }
	.article-inner { max-width: var(--content-width); margin: 0 auto; }
	.article-hero { margin-bottom: var(--spacing-8); border-radius: var(--radius-lg); overflow: hidden; }
	.article-hero img { width: 100%; height: auto; aspect-ratio: 16/9; object-fit: cover; }
	.article-title { font-size: clamp(var(--font-size-3xl), 4vw, var(--font-size-5xl)); font-weight: 700; letter-spacing: -0.03em; line-height: 1.1; margin-bottom: var(--spacing-4); }
	.article-meta { display: flex; align-items: center; gap: var(--spacing-3); font-size: var(--font-size-sm); color: var(--color-muted); margin-bottom: var(--spacing-6); }
	.article-author { font-weight: 500; color: var(--color-text-secondary); }
	.translation-link { display: inline-block; padding: 6px 16px; font-size: var(--font-size-sm); color: var(--color-accent); border: 1px solid var(--color-border); border-radius: var(--radius-pill); text-decoration: none; margin-bottom: var(--spacing-8); transition: all 200ms ease; }
	.translation-link:hover { border-color: var(--color-accent); background: var(--color-accent-muted); }
	.article-content { font-size: var(--font-size-lg); line-height: var(--leading-relaxed); color: var(--color-text-secondary); }
	.article-content :global(h2) { font-size: var(--font-size-2xl); color: var(--color-text); margin-top: var(--spacing-10); margin-bottom: var(--spacing-4); }
	.article-content :global(p) { margin-bottom: var(--spacing-6); }
	.article-tags { display: flex; flex-wrap: wrap; gap: var(--spacing-2); margin-top: var(--spacing-10); padding-top: var(--spacing-6); border-top: 1px solid var(--color-border-subtle); }
	.article-tag { padding: var(--tag-padding-y) var(--spacing-3); font-size: var(--font-size-sm); color: var(--color-text-secondary); background: var(--color-surface); border-radius: var(--radius); text-decoration: none; }
	.article-tag:hover { color: var(--color-text); background: var(--color-border); }
</style>
