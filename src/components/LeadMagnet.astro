---
interface Props {
  title?: string;
  description?: string;
  cta?: string;
  badge?: string;
}
const {
  title = "Descarga gratuita",
  description = "Ingresa tu nombre y email para recibir el recurso en tu bandeja de entrada.",
  cta = "Quiero el recurso →",
  badge = "Gratis",
} = Astro.props;
---

<section class="lead-magnet" data-state="idle">
  <div class="lm-inner">
    <div class="lm-content">
      <span class="lm-badge">{badge}</span>
      <h2 class="lm-title">{title}</h2>
      <p class="lm-desc">{description}</p>
    </div>

    <form class="lm-form" id="lm-form" novalidate>
      <div class="lm-fields">
        <input
          type="text"
          name="name"
          placeholder="Tu nombre"
          autocomplete="given-name"
          required
          minlength="2"
          class="lm-input"
        />
        <input
          type="email"
          name="email"
          placeholder="tu@email.com"
          autocomplete="email"
          required
          class="lm-input"
        />
        <button type="submit" class="lm-btn">
          <span class="state-idle">{cta}</span>
          <span class="state-loading">Enviando...</span>
        </button>
      </div>
      <p class="lm-error" id="lm-error" role="alert"></p>
      <p class="lm-trust">
        <span>✓ Gratis</span>
        <span>✓ Sin spam</span>
        <span>✓ Entrega inmediata</span>
      </p>
    </form>

    <div class="lm-success" id="lm-success" role="status">
      <span class="success-icon">✅</span>
      <strong>¡En camino!</strong>
      <p>Revisa tu bandeja de entrada. Si no llega en 2 minutos, revisa spam.</p>
    </div>
  </div>
</section>

<script>
  const WORKER = "https://resend-contact-worker.antonioduquejuliao.workers.dev";

  const section = document.querySelector<HTMLElement>(".lead-magnet");
  const form = document.getElementById("lm-form") as HTMLFormElement;
  const errorEl = document.getElementById("lm-error") as HTMLParagraphElement;
  const successEl = document.getElementById("lm-success") as HTMLDivElement;

  if (form && section) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      section.dataset.state = "loading";
      errorEl.textContent = "";

      try {
        const res = await fetch(`${WORKER}/subscribe`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            name: data.get("name"),
            email: data.get("email"),
          }),
        });
        const json = await res.json();
        if (!res.ok) throw new Error(json.error ?? "Error al enviar. Intenta de nuevo.");
        section.dataset.state = "success";
        form.style.display = "none";
        successEl.style.display = "flex";
      } catch (err) {
        section.dataset.state = "error";
        errorEl.textContent = err instanceof Error ? err.message : "Error inesperado.";
      }
    });
  }
</script>

<style>
  .lead-magnet {
    background: linear-gradient(135deg, oklch(18% 0.04 250) 0%, oklch(22% 0.06 260) 100%);
    border: 1px solid oklch(35% 0.08 250 / 0.4);
    border-radius: 20px;
    padding: 3rem 2.5rem;
    position: relative;
    overflow: hidden;
  }

  .lead-magnet::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 50% at 70% 50%, oklch(65% 0.18 60 / 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .lm-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .lm-badge {
    display: inline-block;
    background: oklch(65% 0.18 60 / 0.15);
    color: oklch(80% 0.15 60);
    border: 1px solid oklch(65% 0.18 60 / 0.3);
    border-radius: 100px;
    padding: 0.25rem 0.85rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .lm-title {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 800;
    color: oklch(95% 0.02 250);
    line-height: 1.2;
    margin: 0 0 0.75rem;
  }

  .lm-desc {
    font-size: 0.95rem;
    color: oklch(70% 0.04 250);
    line-height: 1.6;
    margin: 0;
  }

  .lm-fields {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .lm-input {
    background: oklch(100% 0 0 / 0.06);
    border: 1px solid oklch(100% 0 0 / 0.12);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-size: 0.95rem;
    color: oklch(95% 0.02 250);
    width: 100%;
    transition: border-color 0.2s;
    font-family: inherit;
  }

  .lm-input::placeholder {
    color: oklch(55% 0.03 250);
  }

  .lm-input:focus {
    outline: none;
    border-color: oklch(65% 0.18 60 / 0.6);
    background: oklch(100% 0 0 / 0.09);
  }

  .lm-btn {
    background: linear-gradient(135deg, oklch(62% 0.18 60), oklch(55% 0.18 50));
    color: oklch(98% 0.01 60);
    border: none;
    border-radius: 10px;
    padding: 0.85rem 1.5rem;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
    font-family: inherit;
  }

  .lm-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .lm-btn:active {
    transform: translateY(0);
  }

  .state-loading { display: none; }

  [data-state="loading"] .state-idle { display: none; }
  [data-state="loading"] .state-loading { display: inline; }
  [data-state="loading"] .lm-btn { opacity: 0.7; pointer-events: none; }

  .lm-error {
    color: oklch(65% 0.2 25);
    font-size: 0.85rem;
    margin: 0.5rem 0 0;
    min-height: 1.2em;
  }

  .lm-trust {
    display: flex;
    gap: 1rem;
    margin: 0.75rem 0 0;
    font-size: 0.78rem;
    color: oklch(55% 0.04 250);
  }

  .lm-success {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    text-align: center;
    color: oklch(85% 0.05 250);
  }

  .success-icon { font-size: 2.5rem; }

  .lm-success strong {
    font-size: 1.1rem;
    color: oklch(95% 0.02 250);
  }

  .lm-success p {
    font-size: 0.9rem;
    color: oklch(65% 0.04 250);
    margin: 0;
  }

  @media (max-width: 640px) {
    .lead-magnet { padding: 2rem 1.5rem; }
    .lm-inner { grid-template-columns: 1fr; gap: 1.5rem; }
  }
</style>
