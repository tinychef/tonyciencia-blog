---
import { getEmDashCollection, getEntryTerms, getSiteSettings } from "emdash";
import { Image } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import ToolsMarquee from "../../components/ToolsMarquee.astro";
import { getReadingTime } from "../../utils/reading-time";
import { resolveBlogSiteIdentity } from "../../utils/site-identity";
import { getLangFromUrl, useTranslations } from "../../i18n/locales";

const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);

const { entries: posts, cacheHint } = await getEmDashCollection("posts", { locale });
const { siteTitle, siteTagline } = resolveBlogSiteIdentity(await getSiteSettings());

Astro.cache.set(cacheHint);

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

const featuredPost = sortedPosts.find((p) => p.data.featured_image);
const featuredIndex = featuredPost ? sortedPosts.indexOf(featuredPost) : -1;
const gridPosts = sortedPosts.filter((_, i) => i !== featuredIndex).slice(0, 6);
const totalShown = (featuredPost ? 1 : 0) + gridPosts.length;
const hasMorePosts = sortedPosts.length > totalShown;

let featuredTags: Array<{ slug: string; label: string }> = [];
const featuredBylines = featuredPost?.data.bylines ?? [];

const allPostsToFetch = [
	...(featuredPost ? [{ post: featuredPost, isFeatured: true }] : []),
	...gridPosts.map((p) => ({ post: p, isFeatured: false })),
];

const allPostTags = await Promise.all(
	allPostsToFetch.map(async ({ post, isFeatured }) => {
		const tags = await getEntryTerms("posts", post.data.id, "tag");
		return { post, isFeatured, tags: tags.map((t) => ({ slug: t.slug, label: t.label })), bylines: post.data.bylines ?? [] };
	})
);

if (featuredPost) {
	const featured = allPostTags.find((p) => p.isFeatured);
	if (featured) featuredTags = featured.tags;
}

const gridPostsWithTags = allPostTags.filter((p) => !p.isFeatured);

function formatDate(date: Date | null | undefined) {
	if (!date) return null;
	const loc = locale === "en" ? "en-US" : "es-ES";
	return date.toLocaleDateString(loc, { year: "numeric", month: "long", day: "numeric" });
}

// Adjust routes based on locale
const servicesRoute = locale === "en" ? "/en/services" : "/servicios";
const postsRoute = locale === "en" ? "/en/posts" : "/posts";
const contactRoute = locale === "en" ? "/en/contact" : "/contacto";
---

<Base title={siteTitle} description={siteTagline}>
	<!-- ═══ HERO ═══════════════════════════════════════════════════════ -->
	<section class="hero">
		<!-- Glow orbs (Framer/Raycast aesthetic) -->
		<div class="hero-orb hero-orb-1" aria-hidden="true"></div>
		<div class="hero-orb hero-orb-2" aria-hidden="true"></div>
		<!-- Dot grid pattern -->
		<div class="hero-dot-grid" aria-hidden="true"></div>

		<div class="hero-inner">
			<h1 class="hero-title">
				{t("hero.title.line1")}<br />
				<span class="hero-title-gradient">{t("hero.title.line2")}</span>
			</h1>
			<p class="hero-subtitle">
				{t("hero.subtitle")}
			</p>
			<div class="hero-actions">
				<a href={servicesRoute} class="btn-primary">{t("hero.cta.primary")}</a>
				<a href={postsRoute} class="btn-secondary">{t("hero.cta.secondary")}</a>
			</div>
			<div class="hero-stats">
				<div class="hero-stat">
					<span class="stat-number">+500</span>
					<span class="stat-label">{t("hero.stat.students")}</span>
				</div>
				<div class="stat-divider"></div>
				<div class="hero-stat">
					<span class="stat-number">50+</span>
					<span class="stat-label">{t("hero.stat.workflows")}</span>
				</div>
				<div class="stat-divider"></div>
				<div class="hero-stat">
					<span class="stat-number">96%</span>
					<span class="stat-label">{t("hero.stat.results")}</span>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══ TOOLS MARQUEE ══════════════════════════════════════════════ -->
	<ToolsMarquee />

	<!-- ═══ SERVICIOS ══════════════════════════════════════════════════ -->
	<section class="services-section">
		<div class="section-container">
			<div class="section-header">
				<span class="section-label">{t("services.label")}</span>
				<h2 class="section-title">{t("services.heading")}</h2>
				<p class="section-subtitle">
					{t("services.sub")}
				</p>
			</div>
			<div class="services-grid">
				<div class="service-card" data-service="01">
					<span class="service-code">01</span>
					<div class="service-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 2a10 10 0 1 0 10 10H12V2z"/><path d="M12 2a10 10 0 0 1 10 10"/>
							<path d="M12 12 2.1 9.1"/>
						</svg>
					</div>
					<h3 class="service-title">{t("services.automation.title")}</h3>
					<p class="service-desc">{t("services.automation.desc")}</p>
					<a href={`${servicesRoute}#automatizacion`} class="service-link">{t("services.automation.link")}</a>
				</div>
				<div class="service-card featured" data-service="02">
					<span class="service-code">02</span>
					<div class="featured-badge">{t("services.courses.badge")}</div>
					<div class="service-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
							<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
						</svg>
					</div>
					<h3 class="service-title">{t("services.courses.title")}</h3>
					<p class="service-desc">{t("services.courses.desc")}</p>
					<a href={`${servicesRoute}#agentes-ia`} class="service-link">{t("services.courses.link")}</a>
				</div>
				<div class="service-card" data-service="03">
					<span class="service-code">03</span>
					<div class="service-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
							<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
						</svg>
					</div>
					<h3 class="service-title">{t("services.apps.title")}</h3>
					<p class="service-desc">{t("services.apps.desc")}</p>
					<a href={`${servicesRoute}#mentoria`} class="service-link">{t("services.apps.link")}</a>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══ CORE VALUES ════════════════════════════════════════════════ -->
	<section class="values-section">
		<div class="section-container">
			<div class="section-header">
				<h2 class="section-title">{t("core.values.title")}</h2>
			</div>
			<div class="values-grid">
				<!-- Pedagogía -->
				<div class="value-item">
					<div class="value-icon">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
					</div>
					<h3 class="value-title">{t("core.values.v1.title")}</h3>
				</div>
				<!-- Experiencia IA -->
				<div class="value-item">
					<div class="value-icon">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M7 8h.01M12 8h.01M17 8h.01"/></svg>
					</div>
					<h3 class="value-title">{t("core.values.v2.title")}</h3>
				</div>
				<!-- Marketing -->
				<div class="value-item">
					<div class="value-icon">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
					</div>
					<h3 class="value-title">{t("core.values.v3.title")}</h3>
				</div>
				<!-- 5 años -->
				<div class="value-item">
					<div class="value-icon">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
					</div>
					<h3 class="value-title">{t("core.values.v4.title")}</h3>
				</div>
				<!-- Confianza legal -->
				<div class="value-item">
					<div class="value-icon">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
					</div>
					<h3 class="value-title">{t("core.values.v5.title")}</h3>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══ TESTIMONIALS ═══════════════════════════════════════════════ -->
	<section class="testimonials-section">
		<div class="section-container">
			<div class="section-header">
				<h2 class="section-title">{t("testimonials.title")}</h2>
			</div>
			<div class="testimonials-grid">
				<div class="testimonial-card">
					<div class="testimonial-stars" aria-label="5 estrellas">★★★★★</div>
					<p class="testimonial-quote">{t("testimonials.t1.quote")}</p>
					<div class="testimonial-author">
						<div class="author-avatar" aria-hidden="true">AJ</div>
						<div class="author-info">
							<span class="author-name">{t("testimonials.t1.author")}</span>
							<span class="author-role">{t("testimonials.t1.role")}</span>
						</div>
					</div>
				</div>
				<div class="testimonial-card">
					<div class="testimonial-stars" aria-label="5 estrellas">★★★★★</div>
					<p class="testimonial-quote">{t("testimonials.t2.quote")}</p>
					<div class="testimonial-author">
						<div class="author-avatar" aria-hidden="true">FP</div>
						<div class="author-info">
							<span class="author-name">{t("testimonials.t2.author")}</span>
							<span class="author-role">{t("testimonials.t2.role")}</span>
						</div>
					</div>
				</div>
				<div class="testimonial-card">
					<div class="testimonial-stars" aria-label="5 estrellas">★★★★★</div>
					<p class="testimonial-quote">{t("testimonials.t3.quote")}</p>
					<div class="testimonial-author">
						<div class="author-avatar" aria-hidden="true">RM</div>
						<div class="author-info">
							<span class="author-name">{t("testimonials.t3.author")}</span>
							<span class="author-role">{t("testimonials.t3.role")}</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══ BLOG PREVIEW ═══════════════════════════════════════════════ -->
	<section class="blog-preview-section">
		<div class="section-container">
			<div class="section-header">
				<h2 class="section-title">{t("blog.latest")}</h2>
				{hasMorePosts && <a href={postsRoute} class="btn-outline">{t("blog.viewAll")} →</a>}
			</div>

			{posts.length === 0 ? (
				<div class="empty-state">
					<p>{t("blog.noPostsYet")}</p>
					{process.env.NODE_ENV === "development" && (
						<a href="/_emdash/admin/content/posts" class="btn-primary">
							{t("blog.createPost")}
						</a>
					)}
				</div>
			) : (
				<div class="blog-grid-layout">
					{featuredPost && (
						<article class="featured-post-card">
							<a href={`${postsRoute}/${featuredPost.id}`} class="featured-post-link">
								{featuredPost.data.featured_image ? (
									<div class="featured-post-image">
										<Image image={featuredPost.data.featured_image} />
									</div>
								) : (
									<div class="featured-post-image-placeholder" />
								)}
								<div class="featured-post-content">
									<div class="featured-post-meta">
										{featuredBylines.length > 0 && (
											<>
												<div class="featured-bylines">
													{featuredBylines.slice(0, 2).map((credit, index) => (
														<>
															{index > 0 && <span class="byline-sep">,</span>}
															<span class="post-byline">
																{credit.byline.avatarMediaId && (
																	<img
																		src={`/_emdash/api/media/file/${credit.byline.avatarMediaId}`}
																		alt={credit.byline.displayName}
																		class="post-byline-avatar"
																	/>
																)}
																<span>{credit.byline.displayName}</span>
															</span>
														</>
													))}
												</div>
												<span class="meta-dot" />
											</>
										)}
										{featuredPost.data.publishedAt && (
											<time>{formatDate(featuredPost.data.publishedAt)}</time>
										)}
										<span class="meta-dot" />
										<span>{getReadingTime(featuredPost.data.content)} {t("blog.minRead")}</span>
									</div>
									<h3 class="featured-post-title">{featuredPost.data.title}</h3>
									{featuredPost.data.excerpt && (
										<p class="featured-post-excerpt">{featuredPost.data.excerpt}</p>
									)}
									{featuredTags.length > 0 && (
										<div class="post-tags">
											{featuredTags.slice(0, 3).map((tag) => (
												<span class="post-tag">{tag.label}</span>
											))}
										</div>
									)}
								</div>
							</a>
						</article>
					)}

					<div class="grid-posts">
						{gridPostsWithTags.map(({ post, tags }) => (
							<PostCard
								title={post.data.title}
								excerpt={post.data.excerpt}
								featuredImage={post.data.featured_image}
								href={`${postsRoute}/${post.id}`}
								date={post.data.publishedAt ?? undefined}
								readingTime={getReadingTime(post.data.content)}
								tags={tags}
							/>
						))}
					</div>
				</div>
			)}
		</div>
	</section>

	<!-- ═══ CTA FINAL ══════════════════════════════════════════════════ -->
	<section class="cta-section">
		<div class="cta-inner">
			<p class="cta-social-proof">{t("cta.social_proof")}</p>
			<h2 class="cta-title">{t("cta.title")}</h2>
			<p class="cta-subtitle">
				{t("cta.sub")}
			</p>
			<a href={contactRoute} class="btn-primary btn-large">{t("cta.button")}</a>
		</div>
	</section>
</Base>

<script>
	// 4.1 Scroll-reveal animations
	(function () {
		const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
		const sections = document.querySelectorAll(".services-section, .values-section, .testimonials-section, .blog-preview-section, .cta-section");
		sections.forEach((s) => s.classList.add("reveal-section"));

		if (prefersReduced) {
			sections.forEach((s) => s.classList.add("is-visible"));
			return;
		}

		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add("is-visible");
						observer.unobserve(entry.target);
					}
				});
			},
			{ threshold: 0.1 }
		);
		sections.forEach((s) => observer.observe(s));
	})();

	// 4.4 Stats counter animation
	(function () {
		const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
		const stats = document.querySelectorAll(".stat-number");
		if (stats.length === 0) return;

		function animateCounter(el: Element) {
			const text = el.textContent || "";
			const match = text.match(/(\d+)/);
			if (!match) return;
			const target = parseInt(match[1], 10);
			const prefix = text.slice(0, text.indexOf(match[1]));
			const suffix = text.slice(text.indexOf(match[1]) + match[1].length);
			const duration = 1500;
			const start = performance.now();

			function step(now: number) {
				const elapsed = now - start;
				const progress = Math.min(elapsed / duration, 1);
				const eased = 1 - Math.pow(1 - progress, 3);
				const current = Math.round(eased * target);
				el.textContent = prefix + current + suffix;
				if (progress < 1) requestAnimationFrame(step);
				else el.textContent = text;
			}
			requestAnimationFrame(step);
		}

		if (prefersReduced) return;

		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						animateCounter(entry.target);
						observer.unobserve(entry.target);
					}
				});
			},
			{ threshold: 0.5 }
		);
		stats.forEach((s) => observer.observe(s));
	})();
</script>

<style>
	/* ── Values & Testimonials (moved from theme.css) ──── */
	.values-section, .testimonials-section {
		padding: 6rem 0;
		background: var(--color-bg);
	}

	.values-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 2rem;
		margin-top: 3rem;
	}

	.value-item {
		display: flex;
		align-items: flex-start;
		gap: 1rem;
		padding: 1.5rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		transition: transform 0.2s ease, border-color 0.2s ease;
	}

	.value-item:hover {
		transform: translateY(-2px);
		border-color: var(--color-border-subtle);
	}

	.value-icon {
		color: var(--color-accent);
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		background: var(--color-accent-muted);
		border-radius: 50%;
	}

	.value-title {
		font-size: 1.1rem;
		font-weight: 600;
		line-height: 1.4;
		color: var(--color-text);
		margin: 0;
		padding-top: 0.5rem;
	}

	.testimonials-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
		margin-top: 3rem;
	}

	.testimonial-card {
		padding: 2rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		position: relative;
	}

	.testimonial-card::before {
		content: '"';
		position: absolute;
		top: -10px;
		left: 15px;
		font-size: 4rem;
		color: var(--color-accent-muted);
		font-family: serif;
		line-height: 1;
	}

	.testimonial-quote {
		font-size: 1rem;
		line-height: 1.6;
		color: var(--color-text-secondary);
		margin: 0;
		position: relative;
		z-index: 1;
		font-style: italic;
	}

	/* ── HERO ─────────────────────────────────────────────── */
	.hero {
		position: relative;
		padding: clamp(3rem, 8vw, 5rem) var(--spacing-6) clamp(4rem, 8vw, 7rem);
		overflow: hidden;
		background: var(--color-bg);
		isolation: isolate;
	}

	/* Glow orbs — Framer/Raycast aesthetic */
	.hero-orb {
		position: absolute;
		border-radius: 50%;
		pointer-events: none;
		z-index: 0;
		filter: blur(100px);
		opacity: 0.18;
		animation: orb-float 8s ease-in-out infinite alternate;
	}

	.hero-orb-1 {
		width: 600px;
		height: 400px;
		background: var(--color-accent);
		top: -10%;
		right: -5%;
		animation-delay: 0s;
		opacity: 0.15;
	}

	.hero-orb-2 {
		width: 400px;
		height: 300px;
		background: var(--color-accent-hover);
		bottom: 0;
		left: -8%;
		animation-delay: -4s;
		opacity: 0.10;
	}

	@keyframes orb-float {
		from { transform: translate(0, 0) scale(1); }
		to { transform: translate(20px, -20px) scale(1.05); }
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-orb {
			animation: none;
		}
	}

	/* Dot grid pattern */
	.hero-dot-grid {
		position: absolute;
		inset: 0;
		z-index: 0;
		pointer-events: none;
		background-image: radial-gradient(
			circle,
			var(--color-border) 1px,
			transparent 1px
		);
		background-size: 28px 28px;
		mask-image: radial-gradient(
			ellipse 80% 60% at 50% 50%,
			black 30%,
			transparent 100%
		);
		opacity: 0.5;
	}

	.hero-inner {
		max-width: 800px;
		margin: 0 auto;
		text-align: center;
		position: relative;
		z-index: 10;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 6px 14px;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-pill);
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-text-secondary);
		margin-bottom: var(--spacing-8);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
	}

	.hero-badge-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--color-accent);
		box-shadow: 0 0 8px var(--color-accent);
	}

	.hero-logo-wrap {
		margin-bottom: var(--spacing-8);
	}

	.hero-logo {
