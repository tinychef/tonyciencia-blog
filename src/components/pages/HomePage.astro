---
import { getEmDashCollection, getEntryTerms, getSiteSettings } from "emdash";
import { Image } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import ToolsMarquee from "../../components/ToolsMarquee.astro";
import { getReadingTime } from "../../utils/reading-time";
import { resolveBlogSiteIdentity } from "../../utils/site-identity";
import { getStaticPosts, getStaticTags } from "../../utils/static-posts";
import { getLangFromUrl, useTranslations } from "../../i18n/locales";

const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);

const { entries: cmsPosts, cacheHint } = await getEmDashCollection("posts", { locale });
const { siteTitle, siteTagline } = resolveBlogSiteIdentity(await getSiteSettings());

Astro.cache.set(cacheHint);

const staticPosts = getStaticPosts(locale);
const cmsSlugs = new Set(cmsPosts.map((post) => post.id));
const posts = [...staticPosts.filter((post) => !cmsSlugs.has(post.id)), ...cmsPosts] as any[];

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

const featuredPost = sortedPosts[0];
const gridPosts = sortedPosts.slice(1, 5);
const postsRoute = locale === "en" ? "/en/posts" : "/posts";
const servicesRoute = locale === "en" ? "/en/services" : "/servicios";
const contactRoute = locale === "en" ? "/en/contact" : "/contacto";

const featuredTags = featuredPost
	? getStaticTags(featuredPost).length > 0
		? getStaticTags(featuredPost)
		: (await getEntryTerms("posts", featuredPost.data.id, "tag")).map((tag) => ({ slug: tag.slug, label: tag.label }))
	: [];

const gridPostsWithTags = await Promise.all(
	gridPosts.map(async (post) => ({
		post,
		tags: getStaticTags(post).length > 0
			? getStaticTags(post)
			: (await getEntryTerms("posts", post.data.id, "tag")).map((tag) => ({ slug: tag.slug, label: tag.label })),
	}))
);

const formatDate = (date: Date | null | undefined) =>
	date?.toLocaleDateString(locale === "en" ? "en-US" : "es-ES", {
		year: "numeric",
		month: "short",
		day: "numeric",
	});

const operatingSystem = locale === "en"
	? [
			["Audit", "We map repetitive work, data gaps, and AI-ready decisions."],
			["Build", "We deploy automations and agents connected to your actual tools."],
			["Control", "We document rules, escalation paths, and human review points."],
			["Scale", "We measure impact and expand only where the business case is real."],
		]
	: [
			["Auditar", "Mapeamos trabajo repetitivo, brechas de datos y decisiones listas para IA."],
			["Construir", "Desplegamos automatizaciones y agentes conectados a tus herramientas reales."],
			["Controlar", "Documentamos reglas, escalamiento y puntos de revisión humana."],
			["Escalar", "Medimos impacto y expandimos solo donde el caso de negocio es real."],
		];
---

<Base title={siteTitle} description={siteTagline}>
	<section class="hero-2026">
		<div class="hero-grid-bg" aria-hidden="true"></div>
		<div class="tc-shell hero-shell">
			<div class="hero-copy">
				<span class="tc-eyebrow">{t("services.label")}</span>
				<h1 class="hero-title">
					{t("hero.title.line1")}<br />
					<span class="tc-gradient-text">{t("hero.title.line2")}</span>
				</h1>
				<p class="hero-subtitle">{t("hero.subtitle")}</p>
				<div class="hero-actions">
					<a href={servicesRoute} class="tc-btn tc-btn--primary">{t("hero.cta.primary")}</a>
					<a href={postsRoute} class="tc-btn tc-btn--secondary">{t("hero.cta.secondary")}</a>
				</div>
				<div class="hero-proof" aria-label="Business proof">
					<div>
						<strong>3</strong>
						<span>{locale === "en" ? "B2B services" : "servicios B2B"}</span>
					</div>
					<div>
						<strong>24/7</strong>
						<span>{locale === "en" ? "automation logic" : "lógica automatizada"}</span>
					</div>
					<div>
						<strong>0</strong>
						<span>{locale === "en" ? "AI improvisation" : "improvisación con IA"}</span>
					</div>
				</div>
			</div>

			<div class="hero-console tc-card" aria-label="AI implementation console">
				<div class="console-top">
					<span></span><span></span><span></span>
					<p>{locale === "en" ? "AI operating layer" : "Capa operativa IA"}</p>
				</div>
				<div class="console-flow">
					<div class="flow-node active">{locale === "en" ? "CRM Lead" : "Lead CRM"}</div>
					<div class="flow-line"></div>
					<div class="flow-node">{locale === "en" ? "AI Agent" : "Agente IA"}</div>
					<div class="flow-line"></div>
					<div class="flow-node">{locale === "en" ? "Human Review" : "Revisión humana"}</div>
				</div>
				<div class="console-panel">
					<p class="panel-label">{locale === "en" ? "Business rule" : "Regla empresarial"}</p>
					<p>{locale === "en" ? "Escalate high-value leads, document every decision, and keep the team in control." : "Escala leads de alto valor, documenta cada decisión y mantiene al equipo en control."}</p>
				</div>
				<div class="console-metrics">
					<div><strong>01</strong><span>{t("services.automation.title")}</span></div>
					<div><strong>02</strong><span>{t("services.courses.title")}</span></div>
					<div><strong>03</strong><span>{t("services.apps.title")}</span></div>
				</div>
			</div>
		</div>
	</section>

	<ToolsMarquee />

	<section class="tc-section services-2026">
		<div class="tc-shell">
			<div class="section-split">
				<div>
					<span class="tc-eyebrow">{t("services.label")}</span>
					<h2 class="tc-section-title">{t("services.heading")}</h2>
				</div>
				<p class="tc-section-copy">{t("services.sub")}</p>
			</div>

			<div class="service-matrix">
				<a href={`${servicesRoute}#automatizacion`} class="matrix-card tc-card">
					<span class="matrix-index">01</span>
					<h3>{t("services.automation.title")}</h3>
					<p>{t("services.automation.desc")}</p>
					<strong>{t("services.automation.link")}</strong>
				</a>
				<a href={`${servicesRoute}#agentes-ia`} class="matrix-card tc-card matrix-card--prime">
					<span class="matrix-index">02</span>
					<small>{t("services.courses.badge")}</small>
					<h3>{t("services.courses.title")}</h3>
					<p>{t("services.courses.desc")}</p>
					<strong>{t("services.courses.link")}</strong>
				</a>
				<a href={`${servicesRoute}#mentoria`} class="matrix-card tc-card">
					<span class="matrix-index">03</span>
					<h3>{t("services.apps.title")}</h3>
					<p>{t("services.apps.desc")}</p>
					<strong>{t("services.apps.link")}</strong>
				</a>
			</div>
		</div>
	</section>

	<section class="tc-section operating-section">
		<div class="tc-shell operating-grid">
			<div>
				<span class="tc-eyebrow">{locale === "en" ? "Method" : "Método"}</span>
				<h2 class="tc-section-title">{locale === "en" ? "AI that works like an operating system." : "IA que funciona como sistema operativo."}</h2>
			</div>
			<div class="operating-list">
				{operatingSystem.map(([title, copy], index) => (
					<div class="operating-item">
						<span>{String(index + 1).padStart(2, "0")}</span>
						<div>
							<h3>{title}</h3>
							<p>{copy}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="tc-section blog-radar">
		<div class="tc-shell">
			<div class="section-split">
				<div>
					<span class="tc-eyebrow">{locale === "en" ? "AI Radar" : "Radar IA"}</span>
					<h2 class="tc-section-title">{t("blog.latest")}</h2>
				</div>
				<a href={postsRoute} class="tc-btn tc-btn--secondary">{t("blog.viewAll")}</a>
			</div>

			{sortedPosts.length === 0 ? (
				<div class="empty-state">
					<p>{t("blog.noPostsYet")}</p>
				</div>
			) : (
				<div class="blog-radar-grid">
					{featuredPost && (
						<article class="featured-article tc-card">
							<a href={`${postsRoute}/${featuredPost.id}`} class="featured-link">
								{featuredPost.data.featured_image && (
									<div class="featured-media">
										{featuredPost.data.featured_image?.src ? (
											<img src={featuredPost.data.featured_image.src} alt={featuredPost.data.featured_image.alt ?? featuredPost.data.title} loading="eager" decoding="async" />
										) : (
											<Image image={featuredPost.data.featured_image} />
										)}
									</div>
								)}
								<div class="featured-body">
									<div class="featured-meta">
										{featuredPost.data.publishedAt && <time>{formatDate(featuredPost.data.publishedAt)}</time>}
										<span>{getReadingTime(featuredPost.data.content as any)} {t("blog.minRead")}</span>
									</div>
									<h3>{featuredPost.data.title}</h3>
									{featuredPost.data.excerpt && <p>{featuredPost.data.excerpt}</p>}
									{featuredTags.length > 0 && (
										<div class="featured-tags">
											{featuredTags.slice(0, 3).map((tag) => <span>{tag.label}</span>)}
										</div>
									)}
								</div>
							</a>
						</article>
					)}
					<div class="post-stack">
						{gridPostsWithTags.map(({ post, tags }) => (
							<PostCard
								title={post.data.title}
								excerpt={post.data.excerpt}
								featuredImage={post.data.featured_image}
								href={`${postsRoute}/${post.id}`}
								date={post.data.publishedAt ?? undefined}
								readingTime={getReadingTime(post.data.content as any)}
								tags={tags}
							/>
						))}
					</div>
				</div>
			)}
		</div>
	</section>

	<section class="final-cta">
		<div class="tc-shell">
			<div class="final-cta-card tc-card">
				<span class="tc-eyebrow">{t("cta.social_proof")}</span>
				<h2>{t("cta.title")}</h2>
				<p>{t("cta.sub")}</p>
				<a href={contactRoute} class="tc-btn tc-btn--primary">{t("cta.button")}</a>
			</div>
		</div>
	</section>
</Base>

<script>
	(function () {
		const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
		const targets = document.querySelectorAll(".service-matrix > *, .operating-item, .blog-radar-grid, .final-cta-card");
		targets.forEach((target) => target.classList.add("scroll-reveal"));
		if (prefersReduced) {
			targets.forEach((target) => target.classList.add("is-visible"));
			return;
		}
		const observer = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (!entry.isIntersecting) return;
				entry.target.classList.add("is-visible");
				observer.unobserve(entry.target);
			});
		}, { threshold: 0.14 });
		targets.forEach((target) => observer.observe(target));
	})();
</script>

<style>
	.hero-2026 {
		position: relative;
		isolation: isolate;
		overflow: hidden;
		padding: clamp(4.5rem, 9vw, 8rem) 0 clamp(4rem, 7vw, 6rem);
	}

	.hero-grid-bg {
		position: absolute;
		inset: 0;
		z-index: -1;
		background-image: var(--tc-grid);
		background-size: 46px 46px;
		mask-image: radial-gradient(ellipse 72% 62% at 50% 20%, black 0%, transparent 72%);
		opacity: 0.48;
	}

	.hero-shell {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.85fr);
		gap: clamp(2rem, 5vw, 5rem);
		align-items: center;
	}

	.hero-copy {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: var(--spacing-6);
	}

	.hero-title {
		font-size: clamp(3.2rem, 9vw, 7.4rem);
		line-height: 0.88;
		letter-spacing: -0.085em;
		max-width: 9ch;
	}

	.hero-subtitle {
		max-width: 62ch;
		color: var(--color-text-secondary);
		font-size: clamp(1.1rem, 1.4vw, 1.3rem);
		line-height: 1.75;
	}

	.hero-actions,
	.hero-proof {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-3);
	}

	.hero-proof {
		width: 100%;
		margin-top: var(--spacing-4);
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border);
	}

	.hero-proof div {
		min-width: 140px;
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.hero-proof strong {
		font-size: clamp(1.7rem, 3vw, 2.4rem);
		letter-spacing: -0.05em;
	}

	.hero-proof span {
		color: var(--color-muted);
		font-size: var(--font-size-sm);
	}

	.hero-console {
		padding: clamp(1.2rem, 2vw, 1.6rem);
		transform: rotate(1.2deg);
	}

	.console-top,
	.console-flow,
	.console-metrics {
		position: relative;
		z-index: 1;
	}

	.console-top {
		display: flex;
		align-items: center;
		gap: 0.45rem;
		margin-bottom: var(--spacing-8);
	}

	.console-top span {
		width: 0.65rem;
		height: 0.65rem;
		border-radius: 999px;
		background: var(--color-border);
	}

	.console-top p {
		margin-left: auto;
		color: var(--color-muted);
		font-size: var(--font-size-xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
	}

	.console-flow {
		display: grid;
		grid-template-columns: 1fr auto 1fr auto 1fr;
		align-items: center;
		gap: var(--spacing-3);
		margin-bottom: var(--spacing-6);
	}

	.flow-node {
		padding: 0.85rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		background: var(--color-bg);
		text-align: center;
		font-size: var(--font-size-sm);
		font-weight: 800;
	}

	.flow-node.active {
		border-color: var(--color-accent);
		box-shadow: 0 0 0 4px var(--color-accent-muted);
	}

	.flow-line {
		width: 2rem;
		height: 1px;
		background: var(--color-border);
	}

	.console-panel {
		position: relative;
		z-index: 1;
		padding: var(--spacing-5);
		border: 1px solid var(--color-border-subtle);
		border-radius: var(--radius-xl);
		background: var(--color-bg-subtle);
		color: var(--color-text-secondary);
		line-height: 1.6;
	}

	.panel-label {
		margin-bottom: var(--spacing-2);
		color: var(--color-accent);
		font-size: var(--font-size-xs);
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.12em;
	}

	.console-metrics {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-3);
		margin-top: var(--spacing-4);
	}

	.console-metrics div {
		padding: var(--spacing-4);
		border-radius: var(--radius-lg);
		background: color-mix(in srgb, var(--color-bg) 72%, transparent);
		border: 1px solid var(--color-border-subtle);
	}

	.console-metrics strong,
	.console-metrics span {
		display: block;
	}

	.console-metrics strong {
		color: var(--color-accent);
		font-family: var(--font-mono);
	}

	.console-metrics span {
		color: var(--color-text-secondary);
		font-size: var(--font-size-sm);
	}

	.section-split {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(280px, 0.7fr);
		gap: var(--spacing-10);
		align-items: end;
		margin-bottom: clamp(2rem, 5vw, 4rem);
	}

	.services-2026 {
		background: linear-gradient(180deg, transparent, color-mix(in srgb, var(--color-bg-subtle) 72%, transparent), transparent);
	}

	.service-matrix {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-5);
	}

	.matrix-card {
		display: flex;
		min-height: 390px;
		flex-direction: column;
		justify-content: space-between;
		padding: clamp(1.4rem, 2.5vw, 2rem);
		color: inherit;
		text-decoration: none;
		transition: transform var(--transition-base), border-color var(--transition-base);
	}

	.matrix-card:hover {
		transform: translateY(-8px);
		border-color: var(--color-accent);
	}

	.matrix-card--prime {
		background:
			linear-gradient(140deg, var(--color-bg), color-mix(in srgb, var(--color-accent) 10%, var(--color-bg))),
			var(--color-bg);
	}

	.matrix-index {
		color: var(--color-accent);
		font-family: var(--font-mono);
		font-weight: 900;
	}

	.matrix-card small {
		width: fit-content;
		padding: 0.3rem 0.65rem;
		border-radius: var(--radius-pill);
		background: var(--color-accent-muted);
		color: var(--color-accent);
		font-weight: 900;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.matrix-card h3 {
		margin-top: auto;
		font-size: clamp(1.8rem, 4vw, 3rem);
		letter-spacing: -0.055em;
	}

	.matrix-card p {
		margin: var(--spacing-4) 0 var(--spacing-6);
		color: var(--color-text-secondary);
		line-height: 1.65;
	}

	.matrix-card strong {
		color: var(--color-accent);
	}

	.operating-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.78fr) minmax(320px, 1fr);
		gap: clamp(2rem, 6vw, 5rem);
		align-items: start;
	}

	.operating-list {
		display: grid;
		gap: var(--spacing-3);
	}

	.operating-item {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--spacing-4);
		padding: var(--spacing-5);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-xl);
		background: color-mix(in srgb, var(--color-bg) 82%, transparent);
	}

	.operating-item span {
		color: var(--color-accent);
		font-family: var(--font-mono);
		font-weight: 900;
	}

	.operating-item h3 {
		font-size: var(--font-size-xl);
	}

	.operating-item p {
		color: var(--color-text-secondary);
		line-height: 1.65;
	}

	.blog-radar-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.9fr);
		gap: var(--spacing-6);
		align-items: start;
	}

	.featured-link {
		display: grid;
		color: inherit;
		text-decoration: none;
	}

	.featured-media {
		position: relative;
		z-index: 1;
		aspect-ratio: 16 / 10;
		overflow: hidden;
		border-bottom: 1px solid var(--color-border);
	}

	.featured-media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform var(--transition-slow);
	}

	.featured-link:hover img {
		transform: scale(1.035);
	}

	.featured-body {
		position: relative;
		z-index: 1;
		padding: clamp(1.4rem, 2.5vw, 2rem);
	}

	.featured-meta,
	.featured-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		color: var(--color-muted);
		font-size: var(--font-size-sm);
	}

	.featured-body h3 {
		margin: var(--spacing-4) 0;
		font-size: clamp(1.8rem, 4vw, 3.2rem);
		line-height: 1;
		letter-spacing: -0.055em;
	}

	.featured-body p {
		color: var(--color-text-secondary);
		line-height: 1.7;
	}

	.featured-tags {
		margin-top: var(--spacing-5);
	}

	.featured-tags span {
		padding: 0.28rem 0.65rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-pill);
	}

	.post-stack {
		display: grid;
		gap: var(--spacing-4);
	}

	.final-cta {
		padding: 0 0 clamp(4rem, 8vw, 7rem);
	}

	.final-cta-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-5);
		padding: clamp(2rem, 6vw, 5rem);
		text-align: center;
	}

	.final-cta-card h2 {
		max-width: 760px;
		font-size: clamp(2.3rem, 6vw, 5rem);
		line-height: 0.95;
		letter-spacing: -0.07em;
	}

	.final-cta-card p {
		max-width: 640px;
		color: var(--color-text-secondary);
		font-size: var(--font-size-lg);
		line-height: 1.7;
	}

	.scroll-reveal {
		opacity: 0;
		transform: translateY(24px);
		transition: opacity 0.7s ease, transform 0.7s ease;
	}

	.scroll-reveal.is-visible {
		opacity: 1;
		transform: translateY(0);
	}

	@media (max-width: 980px) {
		.hero-shell,
		.section-split,
		.operating-grid,
		.blog-radar-grid {
			grid-template-columns: 1fr;
		}

		.hero-console {
			transform: none;
		}

		.service-matrix {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.hero-actions,
		.hero-proof,
		.console-flow,
		.console-metrics {
			grid-template-columns: 1fr;
			flex-direction: column;
		}

		.flow-line {
