---
import Base from "../../layouts/Base.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/locales";

const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);

Astro.cache.set({ maxAge: 3600 });

const WORKER_URL = "https://resend-contact-worker.antonioduquejuliao.workers.dev";

const title =
  locale === "en"
    ? "AI Tricks That Work in the Real World — TonyCiencia"
    : "Trucos de IA que Funcionan en el Mundo Real — TonyCiencia";

const description =
  locale === "en"
    ? "Practical guides, workflows and resources to apply AI to your business today — no empty theory."
    : "Guías prácticas, workflows y recursos para aplicar IA a tu negocio hoy — sin teoría vacía.";

// Listado de guías — agregar nuevas aquí
const guides = [
  {
    slug: "5-trucos-ia-ahorrar-tiempo",
    title:
      locale === "en"
        ? "5 AI Tricks to Save 2 Hours a Day"
        : "5 Trucos de IA para Ahorrar 2 Horas al Día",
    excerpt:
      locale === "en"
        ? "Practical strategies with generative AI you can implement today to reclaim time in your business."
        : "Estrategias prácticas con IA generativa que puedes implementar hoy para recuperar tiempo en tu negocio.",
    difficulty: "beginner" as const,
    readTime: 8,
    isFirst: true,
  },
];

type Difficulty = "beginner" | "intermediate" | "advanced";

function difficultyLabel(d: Difficulty): string {
  const map: Record<Difficulty, string> = {
    beginner: t("trucosIA.featured.difficulty.beginner"),
    intermediate: t("trucosIA.featured.difficulty.intermediate"),
    advanced: t("trucosIA.featured.difficulty.advanced"),
  };
  return map[d];
}

const faqItems =
  locale === "en"
    ? [
        {
          question: "Do I need technical knowledge to apply these tricks?",
          answer:
            "No. All guides are designed for entrepreneurs and business owners. We focus on what actually works in production, explained simply.",
        },
        {
          question: "Can I automate these with n8n?",
          answer:
            "Yes. Many of these tricks connect directly with n8n, Cloudflare Workers, and AI tools like GPT and Claude. We show you how.",
        },
        {
          question: "How often are new guides published?",
          answer:
            "We add new guides regularly. Subscribe below to get notified directly in your inbox.",
        },
      ]
    : [
        {
          question: "¿Necesito conocimientos técnicos para aplicar estos trucos?",
          answer:
            "No. Todas las guías están diseñadas para emprendedores y dueños de negocio. Nos enfocamos en lo que realmente funciona en producción, explicado de forma simple.",
        },
        {
          question: "¿Puedo automatizar esto con n8n?",
          answer:
            "Sí. Muchos de estos trucos se conectan directamente con n8n, Cloudflare Workers y herramientas de IA como GPT y Claude. Te mostramos cómo.",
        },
        {
          question: "¿Con qué frecuencia se publican nuevas guías?",
          answer:
            "Agregamos nuevas guías regularmente. Suscríbete abajo para recibirlas directamente en tu bandeja de entrada.",
        },
      ];
---

<Base
  title={title}
  description={description}
  schemaType="FAQPage"
  faqItems={faqItems}
  breadcrumbs={[
    {
      name: locale === "en" ? "AI Tricks" : "Trucos de IA",
      url: locale === "en" ? "/en/trucos-inteligencia-artificial" : "/trucos-inteligencia-artificial",
    },
  ]}
>

  <!-- HERO -->
  <section class="hub-hero">
    <div class="hub-hero-inner">
      <span class="hub-badge">{t("trucosIA.badge")}</span>
      <h1 class="hub-title">
        {t("trucosIA.title.line1")}
        <span class="hub-title-gradient">{t("trucosIA.title.line2")}</span>
      </h1>
      <p class="hub-subtitle">{t("trucosIA.subtitle")}</p>
    </div>
  </section>

  <!-- PRIMERA GUÍA (FEATURED) -->
  <section class="featured-guide" id="5-trucos-ia-ahorrar-tiempo">
    <div class="featured-guide-inner">
      <div class="guide-header">
        <span class="guide-label">{t("trucosIA.featured.label")}</span>
        <div class="guide-meta">
          <span class="guide-badge guide-badge--beginner">{difficultyLabel(guides[0].difficulty)}</span>
          <span class="guide-read-time">{guides[0].readTime} {t("trucosIA.featured.readTime")}</span>
        </div>
      </div>

      <h2 class="guide-title">{guides[0].title}</h2>
      <p class="guide-excerpt">{guides[0].excerpt}</p>

      <!-- CONTENIDO DE LA GUÍA -->
      <div class="guide-content">

        <div class="guide-step">
          <div class="step-number">01</div>
          <div class="step-body">
            <h3>
              {locale === "en" ? "Summarize long emails with one prompt" : "Resume emails largos con un solo prompt"}
            </h3>
            <p>
              {locale === "en"
                ? "Copy any long email or thread into ChatGPT or Claude with: \"Summarize this in 3 bullet points with clear action items.\" You'll read 10 emails in the time it used to take for 2."
                : "Copia cualquier email largo o hilo a ChatGPT o Claude con: \"Resume esto en 3 puntos con acciones claras.\" Leerás 10 emails en el tiempo que antes tardabas en 2."}
            </p>
            <div class="step-tip">
              💡 {locale === "en"
                ? "Pro tip: create a text shortcut on your phone — type \"!sum\" and it expands to your full summarization prompt."
                : "Pro tip: crea un atajo de texto en tu teléfono — escribe \"!res\" y se expande al prompt completo de resumen."}
            </div>
          </div>
        </div>

        <div class="guide-step">
          <div class="step-number">02</div>
          <div class="step-body">
            <h3>
              {locale === "en" ? "Auto-generate meeting notes" : "Genera actas de reunión automáticamente"}
            </h3>
            <p>
              {locale === "en"
                ? "Use Otter.ai or Fireflies to transcribe meetings, then paste the transcript into Claude with: \"Extract decisions, action items, and owners.\" Never manually type meeting notes again."
                : "Usa Otter.ai o Fireflies para transcribir reuniones, luego pega la transcripción en Claude con: \"Extrae decisiones, acciones y responsables.\" Nunca más escribas actas manualmente."}
            </p>
            <div class="step-tip">
              💡 {locale === "en"
                ? "Connect Fireflies to n8n to auto-send notes to your CRM after every call."
                : "Conecta Fireflies a n8n para enviar las notas automáticamente a tu CRM tras cada llamada."}
            </div>
          </div>
        </div>

        <div class="guide-step">
          <div class="step-number">03</div>
          <div class="step-body">
            <h3>
              {locale === "en" ? "Write first drafts 10x faster" : "Escribe primeros borradores 10 veces más rápido"}
            </h3>
            <p>
              {locale === "en"
                ? "Stop writing from scratch. Give AI the topic, your audience, your tone, and 3 key points. Get a solid first draft in 30 seconds. Your job is to edit — not invent from nothing."
                : "Deja de escribir desde cero. Dale a la IA el tema, tu audiencia, tu tono y 3 puntos clave. Obtén un borrador sólido en 30 segundos. Tu trabajo es editar — no inventar desde la nada."}
            </p>
            <div class="step-tip">
              💡 {locale === "en"
                ? "Works for emails, social posts, proposals, SOPs, and even client presentations."
                : "Funciona para emails, posts, propuestas, SOPs e incluso presentaciones para clientes."}
            </div>
          </div>
        </div>

        <div class="guide-step">
          <div class="step-number">04</div>
          <div class="step-body">
            <h3>
              {locale === "en" ? "Build a personal FAQ bot for your business" : "Crea un bot FAQ personal para tu negocio"}
            </h3>
            <p>
              {locale === "en"
                ? "Upload your FAQ doc, pricing, and policies to a custom GPT or Claude Project. Share the link with your team. They get instant answers without interrupting you."
                : "Sube tu doc de preguntas frecuentes, precios y políticas a un GPT personalizado o Claude Project. Comparte el enlace con tu equipo. Obtienen respuestas inmediatas sin interrumpirte."}
            </p>
            <div class="step-tip">
              💡 {locale === "en"
                ? "Update the doc once and the bot learns instantly. No coding required."
                : "Actualiza el doc una vez y el bot aprende al instante. Sin código requerido."}
            </div>
          </div>
        </div>

        <div class="guide-step">
          <div class="step-number">05</div>
          <div class="step-body">
            <h3>
              {locale === "en" ? "Automate repetitive decisions with AI + n8n" : "Automatiza decisiones repetitivas con IA + n8n"}
            </h3>
            <p>
              {locale === "en"
                ? "Any decision you make the same way every time is a candidate for automation. Connect an AI model to n8n and let it classify leads, tag support tickets, or route requests — while you focus on what actually needs a human."
                : "Cualquier decisión que tomas siempre de la misma forma es candidata para automatizar. Conecta un modelo de IA a n8n y deja que clasifique leads, etiquete tickets de soporte o enrute solicitudes — mientras tú te enfocas en lo que realmente necesita un humano."}
            </p>
            <div class="step-tip">
              💡 {locale === "en"
                ? "Start with lead qualification: new contact → AI scores intent → auto-tagged in CRM."
                : "Empieza con calificación de leads: contacto nuevo → IA puntúa intención → etiquetado automático en CRM."}
            </div>
          </div>
        </div>

        <!-- RECURSOS -->
        <div class="guide-resources">
          <h3 class="resources-title">{t("trucosIA.resources.title")}</h3>
          <ul class="resources-list">
            <li>
              <a href={locale === "en" ? "/en/services" : "/servicios"}>
                {locale === "en" ? "Automation services with n8n & AI →" : "Servicios de automatización con n8n & IA →"}
              </a>
            </li>
            <li>
              <a href={locale === "en" ? "/en/posts" : "/posts"}>
                {locale === "en" ? "All blog articles →" : "Todos los artículos del blog →"}
              </a>
            </li>
            <li>
              <a href="https://www.youtube.com/@Tonyciencia" target="_blank" rel="noopener noreferrer">
                {locale === "en" ? "YouTube channel →" : "Canal de YouTube →"}
              </a>
            </li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- SUBSCRIBE -->
  <section class="subscribe-section">
    <div class="subscribe-inner">
      <h2 class="subscribe-title">{t("trucosIA.subscribe.title")}</h2>
      <p class="subscribe-desc">{t("trucosIA.subscribe.desc")}</p>

      <form
        id="subscribe-form"
        class="subscribe-form"
        data-ts={Date.now()}
        data-worker={WORKER_URL}
        novalidate
      >
        <!-- Honeypot: invisible para humanos, bots lo rellenan -->
        <input type="text" name="_hp" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden" aria-hidden="true" />

        <div class="form-row">
          <input
            type="text"
            name="name"
            id="sub-name"
            placeholder={t("trucosIA.subscribe.namePlaceholder")}
            required
            autocomplete="given-name"
          />
          <input
            type="email"
            name="email"
            id="sub-email"
            placeholder={t("trucosIA.subscribe.emailPlaceholder")}
            required
            autocomplete="email"
          />
          <button type="submit" class="subscribe-btn">
            {t("trucosIA.subscribe.btn")}
          </button>
        </div>
        <p class="form-status" aria-live="polite"></p>
      </form>
    </div>
  </section>

  <!-- ÍNDICE DE GUÍAS -->
  <section class="guides-index">
    <div class="guides-index-inner">
      <h2 class="section-title">{t("trucosIA.index.title")}</h2>
      <div class="guides-grid">
        {guides.map((guide) => (
          <a href={`#${guide.slug}`} class="guide-card">
            <div class="guide-card-meta">
              <span class={`guide-badge guide-badge--${guide.difficulty}`}>
                {difficultyLabel(guide.difficulty)}
              </span>
              <span class="guide-read-time">{guide.readTime} {t("trucosIA.featured.readTime")}</span>
            </div>
            <h3 class="guide-card-title">{guide.title}</h3>
            <p class="guide-card-excerpt">{guide.excerpt}</p>
            <span class="guide-card-cta">
              {locale === "en" ? "Read guide →" : "Leer guía →"}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="hub-faq">
    <div class="hub-faq-inner">
      <h2 class="section-title">
        {locale === "en" ? "Frequently asked questions" : "Preguntas frecuentes"}
      </h2>
      <div class="faq-list">
        {faqItems.map((item) => (
          <div class="faq-item">
            <h3 class="faq-question">{item.question}</h3>
            <p class="faq-answer">{item.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</Base>

<script>
  const form = document.getElementById("subscribe-form") as HTMLFormElement | null;
  if (form) {
    const statusEl = form.querySelector(".form-status") as HTMLParagraphElement;
    const btn = form.querySelector(".subscribe-btn") as HTMLButtonElement;
    const ts = parseInt(form.dataset.ts ?? "0", 10);
    const workerUrl = form.dataset.worker ?? "";

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const nameInput = form.querySelector<HTMLInputElement>("#sub-name");
      const emailInput = form.querySelector<HTMLInputElement>("#sub-email");
      const honeypot = form.querySelector<HTMLInputElement>('[name="_hp"]');

      if (!nameInput || !emailInput) return;

      const originalLabel = btn.textContent ?? "";
      btn.disabled = true;
      btn.textContent = "Enviando...";
      statusEl.textContent = "";
      statusEl.className = "form-status";

      try {
        const res = await fetch(`${workerUrl}/subscribe`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            name: nameInput.value.trim(),
            email: emailInput.value.trim(),
            _hp: honeypot?.value ?? "",
            _t: ts,
          }),
        });

        const json = await res.json() as { success?: boolean; error?: string };

        if (res.ok && json.success) {
          statusEl.textContent = "¡Listo! Revisa tu bandeja de entrada.";
          statusEl.className = "form-status form-status--success";
          form.reset();
        } else {
          statusEl.textContent = json.error ?? "Algo salió mal. Intenta de nuevo.";
          statusEl.className = "form-status form-status--error";
        }
      } catch {
        statusEl.textContent = "Algo salió mal. Intenta de nuevo.";
        statusEl.className = "form-status form-status--error";
      } finally {
        btn.disabled = false;
        btn.textContent = originalLabel;
      }
    });
  }
</script>

<style>
  /* ── HERO ── */
  .hub-hero {
    padding: clamp(4rem, 8vw, 7rem) var(--spacing-6) clamp(3rem, 6vw, 5rem);
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border-subtle);
    text-align: center;
  }
  .hub-hero-inner { max-width: 720px; margin: 0 auto; }

  .hub-badge {
    display: inline-block;
    font-size: var(--font-size-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    padding: 4px 12px;
    background: var(--color-accent-muted);
    border-radius: var(--radius-pill);
    margin-bottom: var(--spacing-4);
  }

  .hub-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.12;
    color: var(--color-text);
    margin: 0 0 var(--spacing-6);
  }
  .hub-title-gradient {
    display: block;
    background: var(--tc-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hub-subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  /* ── FEATURED GUIDE ── */
  .featured-guide {
    padding: clamp(4rem, 7vw, 6rem) var(--spacing-6);
    background: var(--color-bg);
  }
  .featured-guide-inner { max-width: 760px; margin: 0 auto; }

  .guide-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-4);
    margin-bottom: var(--spacing-5);
    flex-wrap: wrap;
  }
  .guide-label {
    font-size: var(--font-size-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    padding: 4px 12px;
    background: var(--color-accent-muted);
    border-radius: var(--radius-pill);
  }
  .guide-meta { display: flex; align-items: center; gap: var(--spacing-3); }

  .guide-badge {
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: var(--radius-pill);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .guide-badge--beginner  { background: #dcfce7; color: #15803d; }
  .guide-badge--intermediate { background: #fef9c3; color: #854d0e; }
  .guide-badge--advanced  { background: #fee2e2; color: #b91c1c; }

  .guide-read-time { font-size: var(--font-size-sm); color: var(--color-text-secondary); }

  .guide-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0 0 var(--spacing-4);
    line-height: 1.2;
  }
  .guide-excerpt {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0 0 clamp(2rem, 4vw, 3rem);
    border-left: 3px solid var(--color-accent);
    padding-left: var(--spacing-5);
  }

  /* Steps */
  .guide-content { display: flex; flex-direction: column; gap: var(--spacing-8); }

  .guide-step {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: var(--spacing-5);
    padding: var(--spacing-6);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }
  .step-number {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
    padding-top: 4px;
    font-variant-numeric: tabular-nums;
  }
  .step-body h3 {
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--spacing-3);
  }
  .step-body p {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0 0 var(--spacing-4);
  }
  .step-tip {
    font-size: var(--font-size-sm);
    color: var(--color-accent);
    background: var(--color-accent-muted);
    padding: var(--spacing-3) var(--spacing-4);
    border-radius: var(--radius);
    line-height: 1.6;
  }

  /* Resources */
  .guide-resources {
    padding: var(--spacing-6);
    background: var(--color-bg-subtle, var(--color-surface));
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }
  .resources-title {
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--spacing-4);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 12px;
  }
  .resources-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--spacing-2); }
  .resources-list a { font-size: var(--font-size-base); color: var(--color-accent); text-decoration: none; font-weight: 600; }
  .resources-list a:hover { text-decoration: underline; }

  /* ── SUBSCRIBE ── */
  .subscribe-section {
    padding: clamp(4rem, 7vw, 6rem) var(--spacing-6);
    background: var(--color-bg-subtle, var(--color-surface));
    border-top: 1px solid var(--color-border-subtle);
    border-bottom: 1px solid var(--color-border-subtle);
    text-align: center;
  }
  .subscribe-inner { max-width: 600px; margin: 0 auto; }
  .subscribe-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--spacing-3);
    letter-spacing: -0.02em;
  }
  .subscribe-desc {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    margin: 0 0 var(--spacing-6);
    line-height: 1.6;
  }
  .subscribe-form { width: 100%; }
  .form-row {
    display: flex;
    gap: var(--spacing-3);
    flex-wrap: wrap;
    justify-content: center;
  }
  .form-row input {
    flex: 1;
    min-width: 160px;
    padding: 12px 16px;
    font-size: var(--font-size-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.2s;
  }
  .form-row input:focus { border-color: var(--color-accent); }
  .subscribe-btn {
    padding: 12px 28px;
    background: linear-gradient(135deg, var(--color-accent), #b07a1e);
    color: #fff;
    border: none;
    border-radius: var(--radius);
    font-size: var(--font-size-base);
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s;
    white-space: nowrap;
  }
  .subscribe-btn:hover { opacity: 0.9; }
  .subscribe-btn:disabled { opacity: 0.6; cursor: not-allowed; }

  .form-status { margin-top: var(--spacing-3); font-size: var(--font-size-sm); min-height: 20px; }
  .form-status--success { color: #15803d; }
  .form-status--error { color: #dc2626; }

  /* ── GUIDES INDEX ── */
  .guides-index { padding: clamp(4rem, 7vw, 6rem) var(--spacing-6); background: var(--color-bg); }
  .guides-index-inner { max-width: var(--wide-width); margin: 0 auto; }
  .section-title { font-size: var(--font-size-2xl); font-weight: 700; color: var(--color-text); margin: 0 0 var(--spacing-8); }

  .guides-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--spacing-6); }
  .guide-card {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    padding: var(--spacing-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .guide-card:hover { border-color: var(--color-accent); box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
  .guide-card-meta { display: flex; align-items: center; gap: var(--spacing-3); }
