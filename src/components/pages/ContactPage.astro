---
import Base from "../../layouts/Base.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/locales";

const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);

Astro.cache.set({ maxAge: 3600 });

const title = locale === "en" ? "Contact — Tony Ciencia" : "Contacto — Tony Ciencia";
const description = locale === "en" 
	? "Talk to Tony Ciencia. Book a free call or write to us directly to automate your business with AI."
	: "Habla con Tony Ciencia. Agenda una llamada gratuita o escríbenos directamente para automatizar tu negocio con IA.";
---

<Base title={title} description={description}>
	<!-- ═══ HERO ═══════════════════════════════════════════════ -->
	<section class="contact-hero">
		<div class="contact-hero-inner">
			<div class="page-breadcrumb">
				<a href={locale === "en" ? "/en" : "/"}>Tony Ciencia</a>
				<span>→</span>
				<span>{t("nav.contact")}</span>
			</div>
			<h1 class="contact-title">
				{t("contact.title.line1")}<br />
				<span class="title-gradient">{t("contact.title.line2")}</span>
			</h1>
			<p class="contact-subtitle">{t("contact.subtitle")}</p>
		</div>
	</section>

	<!-- ═══ MAIN CONTENT ═══════════════════════════════════════ -->
	<section class="contact-main">
		<div class="contact-main-inner">

			<!-- Formulario -->
			<div class="contact-form-wrap">
				<h2 class="form-title">{t("contact.form.title")}</h2>
				<p class="form-sub">{t("contact.form.sub")}</p>
				<form class="contact-form" method="POST" action="/_emdash/api/forms/contact" novalidate>
					<div class="form-row">
						<div class="form-field">
							<label for="name" class="form-label">{t("contact.form.name")}</label>
							<input type="text" id="name" name="name" class="form-input" placeholder={t("contact.form.namePlaceholder")} required autocomplete="name" />
						</div>
						<div class="form-field">
							<label for="email" class="form-label">{t("contact.form.email")}</label>
							<input type="email" id="email" name="email" class="form-input" placeholder={t("contact.form.emailPlaceholder")} required autocomplete="email" />
						</div>
					</div>
					<div class="form-field">
						<label for="subject" class="form-label">{t("contact.form.subject")}</label>
						<select id="subject" name="subject" class="form-input form-select">
							<option value="">{t("contact.form.subjectPlaceholder")}</option>
							<option value="automatizacion">{t("contact.form.subjectOpt1")}</option>
							<option value="agentes-ia">{t("contact.form.subjectOpt2")}</option>
							<option value="mentoria">{t("contact.form.subjectOpt3")}</option>
							<option value="diagnostico-ia">{t("contact.form.subjectOpt4")}</option>
							<option value="otro">{t("contact.form.subjectOpt5")}</option>
						</select>
					</div>
					<div class="form-field">
						<label for="message" class="form-label">{t("contact.form.message")}</label>
						<textarea id="message" name="message" class="form-input form-textarea" placeholder={t("contact.form.messagePlaceholder")} rows="5" required></textarea>
					</div>
					<button type="submit" class="btn-submit">
						{t("contact.form.submit")}
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
						</svg>
					</button>
				</form>
			</div>

			<!-- Info lateral -->
			<div class="contact-info">
				<div class="info-card">
					<div class="info-icon">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
							<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
						</svg>
					</div>
					<div>
						<div class="info-label">{t("contact.info.email")}</div>
						<a href="mailto:business@tonyciencia.com" class="info-value">business@tonyciencia.com</a>
					</div>
				</div>

				<div class="info-card">
					<div class="info-icon">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
						</svg>
					</div>
					<div>
						<div class="info-label">{t("contact.info.time")}</div>
						<div class="info-value">{t("contact.info.timeVal")}</div>
					</div>
				</div>

				<div class="info-card">
					<div class="info-icon">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
							<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
						</svg>
					</div>
					<div>
						<div class="info-label">{t("contact.info.call")}</div>
						<div class="info-value">{t("contact.info.callVal")}</div>
					</div>
				</div>

				<div class="faq-block">
					<h3 class="faq-title">{t("contact.faq.title")}</h3>
					<div class="faq-list">
						<div class="faq-item">
							<strong>{t("contact.faq.q1")}</strong>
							<p>{t("contact.faq.a1")}</p>
						</div>
						<div class="faq-item">
							<strong>{t("contact.faq.q2")}</strong>
							<p>{t("contact.faq.a2")}</p>
						</div>
						<div class="faq-item">
							<strong>{t("contact.faq.q3")}</strong>
							<p>{t("contact.faq.a3")}</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</Base>

<style>
	.contact-hero { padding: clamp(4rem, 8vw, 7rem) var(--spacing-6) clamp(3rem, 5vw, 4rem); background: var(--color-bg); border-bottom: 1px solid var(--color-border-subtle); }
	.contact-hero-inner { max-width: var(--wide-width); margin: 0 auto; }
	.page-breadcrumb { display: flex; align-items: center; gap: var(--spacing-2); font-size: var(--font-size-sm); color: var(--color-muted); margin-bottom: var(--spacing-6); }
	.page-breadcrumb a { color: var(--color-muted); text-decoration: none; transition: color var(--transition-fast); }
	.page-breadcrumb a:hover { color: var(--color-accent); }
	.contact-title { font-size: clamp(2.25rem, 5vw, 3.5rem); font-weight: 700; letter-spacing: -0.03em; line-height: 1.12; color: var(--color-text); margin: 0 0 var(--spacing-5); }
	.title-gradient { background: var(--tc-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
	.contact-subtitle { font-size: var(--font-size-lg); color: var(--color-text-secondary); line-height: 1.65; max-width: 500px; margin: 0; }
	
	.contact-main { padding: clamp(3rem, 6vw, 5rem) var(--spacing-6); }
	.contact-main-inner { max-width: var(--wide-width); margin: 0 auto; display: grid; grid-template-columns: 1fr 380px; gap: var(--spacing-16); align-items: start; }
	
	.contact-form-wrap { display: flex; flex-direction: column; gap: var(--spacing-6); }
	.form-title { font-size: var(--font-size-2xl); font-weight: 700; letter-spacing: -0.02em; color: var(--color-text); margin: 0; }
	.form-sub { font-size: var(--font-size-base); color: var(--color-text-secondary); line-height: 1.65; margin: 0; }
	.contact-form { display: flex; flex-direction: column; gap: var(--spacing-5); }
	.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-4); }
	.form-field { display: flex; flex-direction: column; gap: var(--spacing-2); }
	.form-label { font-size: var(--font-size-sm); font-weight: 500; color: var(--color-text); }
	.form-input { font-family: var(--font-sans); font-size: var(--font-size-base); color: var(--color-text); background: var(--color-bg); border: 1.5px solid var(--color-border); border-radius: var(--radius-lg); padding: 11px 16px; transition: border-color var(--transition-fast), box-shadow var(--transition-fast); width: 100%; -webkit-appearance: none; appearance: none; }
	.form-input:focus { outline: none; border-color: var(--color-accent); box-shadow: 0 0 0 3px var(--color-accent-ring); }
	.form-input::placeholder { color: var(--color-muted); }
	.form-select { cursor: pointer; }
	.form-textarea { resize: vertical; min-height: 140px; line-height: 1.65; }
	
	.btn-submit { display: inline-flex; align-items: center; justify-content: center; gap: var(--spacing-3); padding: 14px 32px; background: var(--tc-gradient); color: white; font-family: var(--font-sans); font-size: var(--font-size-base); font-weight: 600; border: none; border-radius: var(--radius-lg); cursor: pointer; transition: transform var(--transition-fast), box-shadow var(--transition-fast); align-self: flex-start; }
	.btn-submit:hover { transform: translateY(-1px); box-shadow: 4px 4px 0 var(--color-accent); }
	
	.contact-info { display: flex; flex-direction: column; gap: var(--spacing-4); position: sticky; top: 88px; }
	.info-card { display: flex; align-items: flex-start; gap: var(--spacing-4); padding: var(--spacing-5); background: var(--color-bg-subtle); border: 1px solid var(--color-border-subtle); border-radius: var(--radius-lg); }
	.info-icon { display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 10px; background: var(--tc-gradient-subtle); color: var(--color-accent); flex-shrink: 0; }
	.info-label { font-size: var(--font-size-xs); font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-muted); margin-bottom: var(--spacing-1); }
	.info-value { font-size: var(--font-size-base); color: var(--color-text); font-weight: 500; text-decoration: none; transition: color var(--transition-fast); }
	a.info-value:hover { color: var(--color-accent); }
	
	.faq-block { background: var(--color-bg-subtle); border: 1px solid var(--color-border-subtle); border-radius: var(--radius-lg); padding: var(--spacing-6); display: flex; flex-direction: column; gap: var(--spacing-5); }
	.faq-title { font-size: var(--font-size-sm); font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-muted); margin: 0; }
	.faq-list { display: flex; flex-direction: column; gap: var(--spacing-4); }
	.faq-item { font-size: var(--font-size-sm); border-bottom: 1px solid var(--color-border-subtle); padding-bottom: var(--spacing-4); }
	.faq-item:last-child { border-bottom: none; padding-bottom: 0; }
	.faq-item strong { display: block; font-weight: 600; color: var(--color-text); margin-bottom: var(--spacing-2); }
	.faq-item p { color: var(--color-text-secondary); line-height: 1.6; margin: 0; }
	
	@media (max-width: 900px) { .contact-main-inner { grid-template-columns: 1fr; } .contact-info { position: static; } }
	@media (max-width: 640px) { .form-row { grid-template-columns: 1fr; } .btn-submit { align-self: stretch; } }
</style>
