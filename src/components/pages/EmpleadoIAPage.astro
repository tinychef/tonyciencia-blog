---
import Base from "../../layouts/Base.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/locales";

const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);

const CONTACT_URL = locale === "en" ? "/en/contact" : "/contacto";
const WA_NUMBER = "56976424523";
const BUSINESS_EMAIL = "bussines@tonyciencia.com";

const faqItems = [
  {
    question: "¿Necesito tener conocimientos técnicos para usar esto?",
    answer: "No. Nosotros configuramos todo. Tu equipo solo necesita revisar el panel y recibir las notificaciones.",
  },
  {
    question: "¿Funciona con mi WhatsApp actual?",
    answer: "Sí, integramos con WhatsApp Business API. Te guiamos en el proceso de verificación si aún no lo tienes.",
  },
  {
    question: "¿Qué pasa si el cliente hace una pregunta que la IA no sabe responder?",
    answer: "El sistema detecta cuándo no tiene la respuesta y escala automáticamente a un agente humano, sin que el cliente note la diferencia.",
  },
  {
    question: "¿En cuánto tiempo está listo?",
    answer: "22 días hábiles desde que nos entregas la información de tu negocio.",
  },
  {
    question: "¿Puedo cancelar el servicio mensual?",
    answer: "Sí, sin penalizaciones. Damos aviso con 30 días de anticipación.",
  },
];

const whoCards = [
  { title: "Lavanderías",             pain: "Clientes preguntando por su ropa, reportando prendas dañadas o perdidas, sin que nadie lleve el control." },
  { title: "Veterinarias",            pain: "Dueños de mascotas en pánico a las 11pm sin poder contactar al veterinario." },
  { title: "Agencias de Autos",       pain: "Prospectos preguntando precios y disponibilidad que se enfrían si no les respondes en minutos." },
  { title: "Inmobiliarias",           pain: "Leads de propiedades que se pierden porque nadie respondió el domingo." },
  { title: "Restaurantes y Dark Kitchens", pain: "Pedidos, quejas y preguntas de menú que saturan a tu equipo." },
  { title: "Salones y Spas",          pain: "Citas sin confirmar, cancelaciones de último minuto y clientes esperando respuesta." },
  { title: "Gimnasios",               pain: "Preguntas de membresías, horarios y clases que llegan en todo momento." },
  { title: "Clínicas y Consultorios", pain: "Pacientes que necesitan agendar, cancelar o preguntar resultados fuera de horario." },
];

const whoIcons = [
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.38 3.46L16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.57a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.57a2 2 0 0 0-1.34-2.23z"/></svg>`,
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h.5l2.5-3h7l2.5 3H21a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2z"/><circle cx="7.5" cy="14.5" r="1.5"/><circle cx="16.5" cy="14.5" r="1.5"/></svg>`,
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><line x1="7" y1="2" x2="7" y2="22"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/></svg>`,
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>`,
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>`,
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
];

const features = [
  "Flujo de conversación diseñado a la medida de tu negocio",
  "Respuestas automáticas 24/7 en todos tus canales",
  "Sistema de escalamiento al equipo o sucursal correcta",
  "Registro automático de incidencias y reportes",
  "Panel de control centralizado con métricas por canal",
  "Base de conocimiento entrenada con tus FAQs reales",
  "Integración con WhatsApp Business, Messenger e Instagram DM",
  "Capacitación a tu equipo incluida",
  "30 días de soporte post-implementación",
];

const comparison = [
  { criteria: "Horario", traditional: "8 hrs/día, 5 días", ai: "24/7, sin excepciones" },
  { criteria: "Canales simultáneos", traditional: "1 conversación a la vez", ai: "Ilimitados" },
  { criteria: "Tiempo de respuesta", traditional: "Minutos u horas", ai: "Segundos" },
  { criteria: "Registro de datos", traditional: "Manual (si lo hace)", ai: "Automático, siempre" },
  { criteria: "Costo mensual", traditional: "$500–$1,500 USD", ai: "$377 USD" },
  { criteria: "Vacaciones / faltas", traditional: "Sí", ai: "Nunca" },
];

const implementFeatures = [
  "Análisis y mapeo de tus flujos de atención",
  "Configuración en WhatsApp Business + Messenger + IG",
  "Entrenamiento con tus FAQs y políticas reales",
  "Integración con tu equipo y sistema de escalamiento",
  "Pruebas y ajuste fino antes del lanzamiento",
];

const monthlyFeatures = [
  "Mantenimiento y actualizaciones continuas",
  "Optimización mensual basada en conversaciones reales",
  "Soporte técnico prioritario",
  "Nuevas integraciones según tu negocio crece",
  "Reporte mensual de métricas e incidencias",
];
---

<Base
  title={t("empleadoIA.meta.title")}
  description={t("empleadoIA.meta.description")}
  schemaType="FAQPage"
  faqItems={faqItems}
  breadcrumbs={[{ name: "Empleado de IA", url: "/empleado-ia" }]}
>

  <!-- ═══ 1. HERO ═══ -->
  <section class="eia-hero">
    <div class="eia-hero-orb eia-hero-orb--1" aria-hidden="true"></div>
    <div class="eia-hero-orb eia-hero-orb--2" aria-hidden="true"></div>
    <div class="eia-hero-inner">
      <span class="hub-badge" data-animate data-delay="0">IA para Negocios</span>
      <h1 class="eia-hero-title" data-animate data-delay="1">
        Tu negocio siempre respondiendo.
        <span class="eia-gradient-text">Sin contratar más personal.</span>
      </h1>
      <p class="eia-hero-sub" data-animate data-delay="2">
        Automatiza la atención al cliente de tu negocio con un Asistente de IA que responde,
        registra incidencias y escala al equipo correcto — las 24 horas, todos los días.
      </p>
      <div class="eia-hero-ctas" data-animate data-delay="3">
        <a href={CONTACT_URL} class="eia-btn-primary">Quiero mi Asistente de IA →</a>
        <a href="#como-funciona" class="eia-btn-secondary">Ver cómo funciona ↓</a>
      </div>
      <!-- Botones rápidos de contacto -->
      <div class="eia-quick-contact" data-animate data-delay="4">
        <a
          href={`https://wa.me/${WA_NUMBER}?text=Hola%2C%20me%20interesa%20el%20Empleado%20de%20IA`}
          class="eia-quick-btn eia-quick-btn--wa"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Contactar por WhatsApp"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
        <a
          href={`mailto:${BUSINESS_EMAIL}`}
          class="eia-quick-btn eia-quick-btn--email"
          aria-label="Enviar email"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          {BUSINESS_EMAIL}
        </a>
      </div>
      <div class="eia-channels" data-animate data-delay="5" aria-label="Canales soportados">
        <span class="eia-channel">
          <svg class="eia-channel-icon" aria-label="WhatsApp" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </span>
        <span class="eia-channel-sep" aria-hidden="true">·</span>
        <span class="eia-channel">
          <svg class="eia-channel-icon" aria-label="Messenger" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 4.974 0 11.111c0 3.498 1.744 6.614 4.469 8.65V24l4.088-2.242c1.092.301 2.246.464 3.443.464 6.627 0 12-4.975 12-11.111C24 4.974 18.627 0 12 0zm1.191 14.963l-3.055-3.26-5.963 3.26L10.732 8.1l3.131 3.26L19.752 8.1l-6.561 6.863z"/></svg>
          Messenger
        </span>
        <span class="eia-channel-sep" aria-hidden="true">·</span>
        <span class="eia-channel">
          <svg class="eia-channel-icon" aria-label="Instagram" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          Instagram
        </span>
        <span class="eia-channel-sep" aria-hidden="true">·</span>
        <span class="eia-channel">
          <svg class="eia-channel-icon" aria-label="Chat Web" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
          Chat Web
        </span>
        <span class="eia-channel-sep" aria-hidden="true">·</span>
        <span class="eia-channel">
          <svg class="eia-channel-icon" aria-label="SMS" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.6a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 17.92z"></path></svg>
          SMS
        </span>
      </div>
    </div>
  </section>

  <!-- ═══ 2. ¿PARA QUIÉN? ═══ -->
  <section class="eia-section eia-for-who">
    <div class="eia-section-inner">
      <h2 class="eia-section-title" data-animate>Tu negocio recibe mensajes todos los días</h2>
      <div class="eia-who-grid">
        {whoCards.map((card, i) => (
          <div class="eia-who-card" data-animate data-delay={String(i % 4)}>
            <span class="eia-who-icon" aria-hidden="true" set:html={whoIcons[i]} />
            <h3 class="eia-who-title">{card.title}</h3>
            <p class="eia-who-pain">"{card.pain}"</p>
          </div>
        ))}
      </div>
      <p class="eia-who-close" data-animate>
        Si tu equipo pierde tiempo respondiendo lo mismo una y otra vez,
        tienes un problema que la IA ya puede resolver.
      </p>
    </div>
  </section>

  <!-- ═══ 3. CÓMO FUNCIONA ═══ -->
  <section class="eia-section eia-how" id="como-funciona">
    <div class="eia-section-inner eia-section-inner--narrow">
      <h2 class="eia-section-title eia-section-title--center" data-animate>Así trabaja tu nuevo Empleado de IA</h2>
      <div class="eia-steps">
        <div class="eia-step" data-animate data-delay="0">
          <div class="eia-step-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <div class="eia-step-num">Paso 1</div>
          <h3 class="eia-step-title">Cliente escribe</h3>
          <p class="eia-step-desc">Tu cliente manda un mensaje por WhatsApp, Instagram o Messenger preguntando, reportando un problema o pidiendo información.</p>
        </div>
        <div class="eia-step-connector" aria-hidden="true"></div>
        <div class="eia-step" data-animate data-delay="1">
          <div class="eia-step-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M9 8h6M9 12h4"/></svg>
          </div>
          <div class="eia-step-num">Paso 2</div>
          <h3 class="eia-step-title">La IA responde y registra</h3>
          <p class="eia-step-desc">El asistente responde al instante, resuelve dudas frecuentes, levanta reportes y recopila los datos necesarios.</p>
        </div>
        <div class="eia-step-connector" aria-hidden="true"></div>
        <div class="eia-step" data-animate data-delay="2">
          <div class="eia-step-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          </div>
          <div class="eia-step-num">Paso 3</div>
          <h3 class="eia-step-title">Escala lo que importa</h3>
          <p class="eia-step-desc">Si la situación requiere atención humana, el sistema notifica al responsable correcto con toda la información lista.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 4. QUÉ INCLUYE ═══ -->
  <section class="eia-section eia-features">
    <div class="eia-section-inner eia-section-inner--narrow">
      <h2 class="eia-section-title eia-section-title--center" data-animate>Todo configurado. Todo funcionando. Desde el día 1.</h2>
      <div class="eia-features-grid">
        {features.map((f, i) => (
          <div class="eia-feature-item" data-animate data-delay={String(i % 3)}>
            <span class="eia-feature-check" aria-hidden="true">✓</span>
            <span>{f}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ 5. TABLA COMPARATIVA ═══ -->
  <section class="eia-section eia-comparison">
    <div class="eia-section-inner eia-section-inner--narrow">
      <h2 class="eia-section-title eia-section-title--center" data-animate>Compara antes de decidir</h2>
      <div class="eia-table-wrapper" data-animate data-delay="1">
        <table class="eia-table">
          <thead>
            <tr>
              <th scope="col">Criterio</th>
              <th scope="col">Empleado Tradicional</th>
              <th scope="col" class="eia-table-ia-head">Empleado IA</th>
            </tr>
          </thead>
          <tbody>
            {comparison.map((row, i) => (
              <tr data-animate data-delay={String(i % 4)}>
                <td class="eia-table-criteria">{row.criteria}</td>
                <td class="eia-table-traditional">{row.traditional}</td>
                <td class="eia-table-ai">{row.ai}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="eia-table-note" data-animate data-delay="1">
        * Costo estimado de empleado de atención al cliente en LATAM. El Empleado IA no reemplaza a tu equipo — lo libera para lo que realmente importa.
      </p>
    </div>
  </section>

  <!-- ═══ 6. PRECIOS ═══ -->
  <section class="eia-section eia-pricing">
    <div class="eia-section-inner eia-section-inner--narrow">
