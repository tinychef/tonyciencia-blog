---
interface Props {
	type: "website" | "article";
	title: string;
	description?: string | null;
	url: string;
	image?: string | null;
	locale: string;
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	breadcrumbs?: Array<{ name: string; url: string }> | null;
	schemaType?: string | null;
	faqItems?: Array<{ question: string; answer: string }> | null;
	readingTime?: number | null;
}

const { type, title, description, url, image, locale, publishedTime, modifiedTime, author, breadcrumbs, schemaType, faqItems, readingTime } = Astro.props;

const siteUrl = Astro.url.origin;
const SITE_AUTHOR_NAME = "Antonio Duque";

const SOCIAL_PROFILES = [
	"https://youtube.com/@tonyciencia",
	"https://instagram.com/tonyciencia",
	"https://x.com/tonyciencia",
];

const orgSchema = {
	"@context": "https://schema.org",
	"@type": ["Organization", "LocalBusiness"],
	"@id": `${siteUrl}#organization`,
	name: "Tony Ciencia LLC",
	alternateName: "Tony Ciencia",
	url: siteUrl,
	logo: {
		"@type": "ImageObject",
		url: `${siteUrl}/assets/logo-tonyciencia-full.webp`,
		width: 400,
		height: 120,
	},
	image: `${siteUrl}/assets/og-default.webp`,
	description: "Implementa IA, Avanza con educación práctica en inteligencia artificial, automatización y crecimiento digital.",
	slogan: "Implementa IA, Avanza",
	address: {
		"@type": "PostalAddress",
		addressLocality: "Albuquerque",
		addressRegion: "NM",
		addressCountry: "US",
	},
	areaServed: "Worldwide",
	knowsLanguage: ["es", "en"],
	sameAs: SOCIAL_PROFILES,
	contactPoint: {
		"@type": "ContactPoint",
		contactType: "customer service",
		availableLanguage: ["Spanish", "English"],
		url: `${siteUrl}/contacto`,
	},
};

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"@id": `${siteUrl}#website`,
	name: "Tony Ciencia",
	url: siteUrl,
	inLanguage: locale === "en" ? "en" : "es",
	publisher: {
		"@type": "Organization",
		name: "Tony Ciencia LLC",
		url: siteUrl,
	},
	potentialAction: {
		"@type": "SearchAction",
		target: `${siteUrl}${locale === "en" ? "/en/search" : "/search"}?q={search_term_string}`,
		"query-input": "required name=search_term_string",
	},
};

const breadcrumbSchema =
	breadcrumbs && breadcrumbs.length > 0
		? {
				"@context": "https://schema.org",
				"@type": "BreadcrumbList",
				itemListElement: [
					{ "@type": "ListItem", position: 1, name: locale === "en" ? "Home" : "Inicio", item: siteUrl },
					...breadcrumbs.map((crumb, idx) => ({
						"@type": "ListItem",
						position: idx + 2,
						name: crumb.name,
						item: crumb.url.startsWith("http") ? crumb.url : `${siteUrl}${crumb.url}`,
					})),
				],
			}
		: null;

const effectiveSchemaType = schemaType || (type === "article" ? "Article" : null);

const authorPerson = {
	"@type": "Person",
	name: author || SITE_AUTHOR_NAME,
	url: `${siteUrl}${locale === "en" ? "/en/about" : "/about"}`,
	...(author ? {} : {
		jobTitle: "AI Educator & Automation Specialist",
		worksFor: { "@id": `${siteUrl}#organization` },
		sameAs: SOCIAL_PROFILES,
		knowsAbout: [
			"Artificial Intelligence",
			"Marketing Automation",
			"n8n",
			"ChatGPT",
			"Meta Ads",
			"Google Ads",
		],
	}),
};

function buildArticleSchema() {
	if (type !== "article") return null;

	const baseType = effectiveSchemaType === "HowTo" ? "HowTo"
		: effectiveSchemaType === "LearningResource" ? "LearningResource"
		: "BlogPosting";

	const schema: Record<string, unknown> = {
		"@context": "https://schema.org",
		"@type": baseType,
		headline: title,
		description: description || "",
		url,
		inLanguage: locale === "en" ? "en" : "es",
		...(image ? { image } : { image: `${siteUrl}/assets/og-default.webp` }),
		...(publishedTime && { datePublished: publishedTime }),
		...(modifiedTime && { dateModified: modifiedTime }),
		author: authorPerson,
		publisher: {
			"@type": "Organization",
			name: "Tony Ciencia LLC",
			logo: {
				"@type": "ImageObject",
				url: `${siteUrl}/assets/logo-tonyciencia-full.webp`,
			},
		},
		speakable: {
			"@type": "SpeakableSpecification",
			cssSelector: [".quick-answer", ".article-excerpt"],
		},
	};

	if (readingTime) {
		schema.timeRequired = `PT${readingTime}M`;
	}

	if (baseType === "LearningResource") {
		schema.educationalLevel = "Intermediate";
		schema.learningResourceType = "Article";
		schema.isAccessibleForFree = true;
	}

	return schema;
}

const articleSchema = buildArticleSchema();

const faqSchema =
	faqItems && faqItems.length > 0
		? {
				"@context": "https://schema.org",
				"@type": "FAQPage",
				mainEntity: faqItems.map((item) => ({
					"@type": "Question",
					name: item.question,
					acceptedAnswer: {
						"@type": "Answer",
						text: item.answer,
					},
				})),
			}
		: null;
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
<script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
{breadcrumbSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
{articleSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}
{faqSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
