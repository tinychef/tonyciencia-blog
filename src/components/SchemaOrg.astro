---
interface Props {
	type: "website" | "article";
	title: string;
	description?: string | null;
	url: string;
	image?: string | null;
	locale: string;
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	breadcrumbs?: Array<{ name: string; url: string }> | null;
	schemaType?: string | null;
	faqItems?: Array<{ question: string; answer: string }> | null;
}

const { type, title, description, url, image, locale, publishedTime, modifiedTime, author, breadcrumbs, schemaType, faqItems } = Astro.props;

const siteUrl = Astro.url.origin;
const SITE_AUTHOR_NAME = "Antonio Duque";

const SOCIAL_PROFILES = [
	"https://youtube.com/@tonyciencia",
	"https://instagram.com/tonyciencia",
	"https://x.com/tonyciencia",
];

const orgSchema = {
	"@context": "https://schema.org",
	"@type": ["Organization", "LocalBusiness"],
	name: "Tony Ciencia LLC",
	alternateName: "Tony Ciencia",
	url: siteUrl,
	logo: {
		"@type": "ImageObject",
		url: `${siteUrl}/assets/logo-tonyciencia-full.webp`,
		width: 400,
		height: 120,
	},
	image: `${siteUrl}/assets/og-default.webp`,
	description: "Educación en IA, automatización de negocios y transformación digital para emprendedores y empresas.",
	address: {
		"@type": "PostalAddress",
		addressLocality: "Albuquerque",
		addressRegion: "NM",
		addressCountry: "US",
	},
	areaServed: "Worldwide",
	knowsLanguage: ["es", "en"],
	sameAs: SOCIAL_PROFILES,
	contactPoint: {
		"@type": "ContactPoint",
		contactType: "customer service",
		availableLanguage: ["Spanish", "English"],
		url: `${siteUrl}/contacto`,
	},
};

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: "Tony Ciencia",
	url: siteUrl,
	inLanguage: locale === "en" ? "en" : "es",
	publisher: {
		"@type": "Organization",
		name: "Tony Ciencia LLC",
		url: siteUrl,
	},
	potentialAction: {
		"@type": "SearchAction",
		target: `${siteUrl}/search?q={search_term_string}`,
		"query-input": "required name=search_term_string",
	},
};

const breadcrumbSchema =
	breadcrumbs && breadcrumbs.length > 0
		? {
				"@context": "https://schema.org",
				"@type": "BreadcrumbList",
				itemListElement: [
					{ "@type": "ListItem", position: 1, name: "Inicio", item: siteUrl },
					...breadcrumbs.map((crumb, idx) => ({
						"@type": "ListItem",
						position: idx + 2,
						name: crumb.name,
						item: crumb.url.startsWith("http") ? crumb.url : `${siteUrl}${crumb.url}`,
					})),
				],
			}
		: null;

const effectiveSchemaType = schemaType || (type === "article" ? "Article" : null);

const articleSchema =
	type === "article"
		? {
				"@context": "https://schema.org",
				"@type": effectiveSchemaType === "HowTo" ? "HowTo" : "BlogPosting",
				headline: title,
				description: description || "",
				url,
				inLanguage: locale === "en" ? "en" : "es",
				...(image ? { image } : { image: `${siteUrl}/assets/og-default.webp` }),
				...(publishedTime && { datePublished: publishedTime }),
				...(modifiedTime && { dateModified: modifiedTime }),
				author: {
					"@type": "Person",
					name: author || SITE_AUTHOR_NAME,
					url: `${siteUrl}${locale === "en" ? "/en/about" : "/about"}`,
				},
				publisher: {
					"@type": "Organization",
					name: "Tony Ciencia LLC",
					logo: {
						"@type": "ImageObject",
						url: `${siteUrl}/assets/logo-tonyciencia-full.webp`,
					},
				},
			}
		: null;

const faqSchema =
	faqItems && faqItems.length > 0
		? {
				"@context": "https://schema.org",
				"@type": "FAQPage",
				mainEntity: faqItems.map((item) => ({
					"@type": "Question",
					name: item.question,
					acceptedAnswer: {
						"@type": "Answer",
						text: item.answer,
					},
				})),
			}
		: null;
---

<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
{breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
{articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}
{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
