---
import { PortableText } from "emdash/ui";
import type { Locale } from "../i18n/locales";

interface Props {
	title: string;
	content: any;
	lastReviewed?: Date | null;
	locale: Locale;
}

const { title, content, lastReviewed, locale } = Astro.props;
const dateLocale = locale === "en" ? "en-US" : "es-ES";
const reviewedLabel = locale === "en" ? "Last reviewed:" : "Última revisión:";
---

<article class="legal-page">
	<div class="legal-inner">
		<h1>{title}</h1>
		<PortableText value={content} />
		{lastReviewed && (
			<p class="legal-reviewed">
				{reviewedLabel} {lastReviewed.toLocaleDateString(dateLocale, { year: "numeric", month: "long", day: "numeric" })}
			</p>
		)}
	</div>
</article>

<style>
	.legal-page { padding: var(--spacing-16) var(--spacing-6); }
	.legal-inner { max-width: var(--content-width); margin: 0 auto; }
	.legal-inner h1 {
		font-size: var(--font-size-3xl);
		font-weight: 700;
		letter-spacing: -0.03em;
		margin-bottom: var(--spacing-8);
	}
	.legal-inner :global(h2) {
		font-size: var(--font-size-xl);
		margin-top: var(--spacing-10);
		margin-bottom: var(--spacing-4);
	}
	.legal-inner :global(p) {
		color: var(--color-text-secondary);
		line-height: var(--leading-relaxed);
		margin-bottom: var(--spacing-4);
	}
	.legal-reviewed {
		margin-top: var(--spacing-12);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		border-top: 1px solid var(--color-border);
		padding-top: var(--spacing-4);
	}
</style>
