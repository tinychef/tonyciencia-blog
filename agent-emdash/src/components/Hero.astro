---
// Hero section — Tony Ciencia homepage
// Brand: AI & Automation educator | Antonio Duque
---

<section class="hero" aria-label="Tony Ciencia — IA y Automatización">
	<!-- Animated background -->
	<div class="hero-bg" aria-hidden="true">
		<div class="blob blob-purple"></div>
		<div class="blob blob-cyan"></div>
		<div class="grid-lines"></div>
	</div>

	<div class="hero-inner">
		<!-- Left: Content -->
		<div class="hero-content">
			<div class="hero-badge">
				<span class="badge-dot"></span>
				YouTuber · IA · Automatización
			</div>

			<h1 class="hero-title">
				Domina la IA.<br />
				<span class="gradient-text">Automatiza tu negocio.</span>
			</h1>

			<p class="hero-desc">
				Soy Antonio Duque. Ayudo a emprendedores y agencias a implementar
				inteligencia artificial y automatización con herramientas reales —
				n8n, Make, OpenAI y mucho más.
			</p>

			<div class="hero-ctas">
				<a
					href="https://www.youtube.com/@tonyciencia"
					target="_blank"
					rel="noopener noreferrer"
					class="cta-primary"
				>
					<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
						<path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
					</svg>
					Ver Canal
				</a>
				<a href="#servicios" class="cta-secondary">
					Explorar Servicios
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M5 12h14M12 5l7 7-7 7"/>
					</svg>
				</a>
			</div>

			<div class="hero-stats" role="list">
				<div class="stat" role="listitem">
					<span class="stat-num">5+</span>
					<span class="stat-label">años en IA</span>
				</div>
				<div class="stat-divider" aria-hidden="true"></div>
				<div class="stat" role="listitem">
					<span class="stat-num">17</span>
					<span class="stat-label">herramientas</span>
				</div>
				<div class="stat-divider" aria-hidden="true"></div>
				<div class="stat" role="listitem">
					<span class="stat-num">3</span>
					<span class="stat-label">servicios</span>
				</div>
			</div>
		</div>

		<!-- Right: Visual card -->
		<div class="hero-visual" aria-hidden="true">
			<div class="visual-card">
				<div class="card-glow"></div>
				<div class="card-inner">
					<div class="card-header">
						<div class="card-dots">
							<span></span><span></span><span></span>
						</div>
						<span class="card-label">n8n workflow</span>
					</div>
					<div class="card-nodes">
						<div class="node node-trigger">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
								<circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
							</svg>
							<span>Trigger</span>
						</div>
						<div class="node-line"></div>
						<div class="node node-ai">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
								<path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.46 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.46 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"/>
							</svg>
							<span>AI Agent</span>
						</div>
						<div class="node-line"></div>
						<div class="node node-output">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
								<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
							</svg>
							<span>WhatsApp</span>
						</div>
					</div>
					<div class="card-status">
						<span class="status-dot"></span>
						<span>Workflow activo · 1,240 ejecuciones</span>
					</div>
				</div>
			</div>

			<!-- Floating tags -->
			<div class="float-tag tag-1">n8n</div>
			<div class="float-tag tag-2">OpenAI</div>
			<div class="float-tag tag-3">Make</div>
			<div class="float-tag tag-4">🤖 IA</div>
		</div>
	</div>
</section>

<style>
	/* ── Hero wrapper ── */
	.hero {
		position: relative;
		overflow: hidden;
		background: #0d0f14;
		color: #e2e8f0;
		padding: 5rem 1.5rem 4rem;
		min-height: 90vh;
		display: flex;
		align-items: center;
	}

	/* ── Animated background ── */
	.hero-bg {
		position: absolute;
		inset: 0;
		pointer-events: none;
	}

	.blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		opacity: 0.35;
		animation: pulse 8s ease-in-out infinite;
	}

	.blob-purple {
		width: 600px;
		height: 600px;
		background: radial-gradient(circle, #7c3aed, #4c1d95);
		top: -200px;
		right: -100px;
		animation-delay: 0s;
	}

	.blob-cyan {
		width: 400px;
		height: 400px;
		background: radial-gradient(circle, #06b6d4, #0e7490);
		bottom: -100px;
		left: 10%;
		animation-delay: 4s;
	}

	@keyframes pulse {
		0%, 100% { transform: scale(1) translate(0, 0); opacity: 0.35; }
		50% { transform: scale(1.1) translate(20px, -20px); opacity: 0.5; }
	}

	.grid-lines {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
		background-size: 60px 60px;
	}

	/* ── Layout ── */
	.hero-inner {
		position: relative;
		z-index: 1;
		max-width: 1200px;
		margin: 0 auto;
		width: 100%;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	/* ── Badge ── */
	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.375rem 1rem;
		border: 1px solid rgba(124, 58, 237, 0.4);
		border-radius: 100px;
		font-size: 0.8125rem;
		font-weight: 500;
		color: #c4b5fd;
		background: rgba(124, 58, 237, 0.1);
		margin-bottom: 1.5rem;
		width: fit-content;
	}

	.badge-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: #a78bfa;
		animation: blink 2s ease-in-out infinite;
		flex-shrink: 0;
	}

	@keyframes blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.3; }
	}

	/* ── Title ── */
	.hero-title {
		font-family: var(--font-display, var(--font-sans));
		font-size: clamp(2.5rem, 5vw, 4rem);
		font-weight: 800;
		line-height: 1.1;
		letter-spacing: -0.03em;
		color: #f1f5f9;
		margin-bottom: 1.5rem;
	}

	.gradient-text {
		background: linear-gradient(135deg, #a78bfa 0%, #06b6d4 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	/* ── Description ── */
	.hero-desc {
		font-size: 1.125rem;
		line-height: 1.7;
		color: #94a3b8;
		margin-bottom: 2rem;
		max-width: 520px;
	}

	/* ── CTAs ── */
	.hero-ctas {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-bottom: 2.5rem;
	}

	.cta-primary {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem 1.5rem;
		background: #7c3aed;
		color: white;
		border-radius: 8px;
		font-size: 0.9375rem;
		font-weight: 600;
		text-decoration: none;
		transition: background 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
		box-shadow: 0 0 20px rgba(124, 58, 237, 0.4);
	}

	.cta-primary:hover {
		background: #6d28d9;
		transform: translateY(-1px);
		box-shadow: 0 0 30px rgba(124, 58, 237, 0.6);
		color: white;
	}

	.cta-secondary {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem 1.5rem;
		border: 1px solid rgba(255, 255, 255, 0.15);
		color: #e2e8f0;
		border-radius: 8px;
		font-size: 0.9375rem;
		font-weight: 500;
		text-decoration: none;
		background: rgba(255, 255, 255, 0.05);
		backdrop-filter: blur(8px);
		transition: border-color 0.15s ease, background 0.15s ease;
	}

	.cta-secondary:hover {
		border-color: rgba(167, 139, 250, 0.5);
		background: rgba(124, 58, 237, 0.1);
		color: #e2e8f0;
	}

	/* ── Stats ── */
	.hero-stats {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.stat {
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
	}

	.stat-num {
		font-family: var(--font-display, var(--font-sans));
		font-size: 1.75rem;
		font-weight: 800;
		color: #f1f5f9;
		line-height: 1;
	}

	.stat-label {
		font-size: 0.8125rem;
		color: #64748b;
		font-weight: 500;
	}

	.stat-divider {
		width: 1px;
		height: 2.5rem;
		background: rgba(255, 255, 255, 0.1);
	}

	/* ── Visual card ── */
	.hero-visual {
		position: relative;
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.visual-card {
		position: relative;
		width: 100%;
		max-width: 400px;
		border-radius: 16px;
		background: rgba(22, 25, 34, 0.8);
		border: 1px solid rgba(124, 58, 237, 0.3);
		backdrop-filter: blur(20px);
		overflow: hidden;
		animation: float 6s ease-in-out infinite;
	}

	@keyframes float {
		0%, 100% { transform: translateY(0px); }
		50% { transform: translateY(-12px); }
	}

	.card-glow {
		position: absolute;
		top: -50%;
		left: -50%;
		width: 200%;
		height: 200%;
		background: conic-gradient(
			from 0deg,
			transparent 0deg,
			rgba(124, 58, 237, 0.15) 60deg,
			rgba(6, 182, 212, 0.1) 120deg,
			transparent 180deg
		);
		animation: spin 8s linear infinite;
	}

	@keyframes spin {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	.card-inner {
		position: relative;
		z-index: 1;
		padding: 1.5rem;
	}

	.card-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1.5rem;
	}

	.card-dots {
		display: flex;
		gap: 6px;
	}

	.card-dots span {
		width: 10px;
		height: 10px;
		border-radius: 50%;
	}

	.card-dots span:nth-child(1) { background: #ef4444; }
	.card-dots span:nth-child(2) { background: #f59e0b; }
	.card-dots span:nth-child(3) { background: #10b981; }

	.card-label {
		font-size: 0.75rem;
		color: #64748b;
		font-family: var(--font-mono);
		letter-spacing: 0.05em;
	}

	.card-nodes {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1.5rem;
		overflow-x: auto;
	}

	.node {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem;
		border-radius: 10px;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.08);
		min-width: 72px;
		flex-shrink: 0;
		transition: border-color 0.2s ease;
	}

	.node:hover { border-color: rgba(167, 139, 250, 0.4); }

	.node span {
		font-size: 0.7rem;
		color: #64748b;
		white-space: nowrap;
		font-family: var(--font-mono);
	}

	.node-trigger { color: #a78bfa; }
	.node-ai { color: #06b6d4; }
	.node-output { color: #10b981; }

	.node-line {
		flex: 1;
		height: 1px;
		background: linear-gradient(90deg, rgba(167,139,250,0.4), rgba(6,182,212,0.4));
		min-width: 20px;
	}

	.card-status {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.625rem 0.875rem;
		background: rgba(16, 185, 129, 0.08);
		border: 1px solid rgba(16, 185, 129, 0.2);
		border-radius: 8px;
	}

	.status-dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: #10b981;
		flex-shrink: 0;
		animation: blink 2s ease-in-out infinite;
	}

	.card-status span:last-child {
		font-size: 0.75rem;
		color: #6ee7b7;
		font-family: var(--font-mono);
	}

	/* ── Floating tags ── */
	.float-tag {
		position: absolute;
		padding: 0.375rem 0.75rem;
		border-radius: 100px;
		font-size: 0.8125rem;
		font-weight: 600;
		backdrop-filter: blur(12px);
		border: 1px solid rgba(255,255,255,0.1);
		background: rgba(22, 25, 34, 0.9);
		color: #e2e8f0;
		white-space: nowrap;
		pointer-events: none;
	}

	.tag-1 {
		top: 10%;
		right: -10px;
		color: #fb923c;
		border-color: rgba(251, 146, 60, 0.3);
		animation: floatTag 5s ease-in-out infinite;
	}

	.tag-2 {
		top: 45%;
		right: -20px;
		color: #34d399;
		border-color: rgba(52, 211, 153, 0.3);
		animation: floatTag 6s ease-in-out infinite 1s;
	}

	.tag-3 {
		bottom: 20%;
		right: -5px;
		color: #60a5fa;
		border-color: rgba(96, 165, 250, 0.3);
		animation: floatTag 7s ease-in-out infinite 2s;
	}

	.tag-4 {
		bottom: 5%;
		left: 10%;
		color: #f472b6;
		border-color: rgba(244, 114, 182, 0.3);
		animation: floatTag 5.5s ease-in-out infinite 0.5s;
	}

	@keyframes floatTag {
		0%, 100% { transform: translateY(0px) rotate(-1deg); }
		50% { transform: translateY(-8px) rotate(1deg); }
	}

	/* ── Responsive ── */
	@media (max-width: 900px) {
		.hero { padding: 4rem 1.5rem 3rem; min-height: auto; }

		.hero-inner {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.hero-visual {
			order: -1;
		}

		.visual-card { max-width: 360px; }

		.float-tag { display: none; }
	}

	@media (max-width: 600px) {
		.hero-title { font-size: 2.25rem; }
		.hero-desc { font-size: 1rem; }
		.cta-primary, .cta-secondary { width: 100%; justify-content: center; }
		.hero-stats { gap: 1rem; }
		.stat-num { font-size: 1.5rem; }
	}
</style>
