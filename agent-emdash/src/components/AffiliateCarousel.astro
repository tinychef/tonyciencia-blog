---
// Infinite dual-direction affiliate carousel
// Row 1 → izquierda | Row 2 → derecha
// Logos via Google Favicon API (64px, 1:1)
// Solo herramientas ACTIVAS de PartnerStack

interface Tool {
	name: string;
	url: string;
	site: string;
	tag?: string;
}

const ACTIVE_TOOLS: Tool[] = [
	{ name: "Pipedrive",       url: "https://aff.trypipedrive.com/vyzzvh7thge6",        site: "pipedrive.com",       tag: "CRM" },
	{ name: "monday.com",      url: "https://try.monday.com/i32p0zf6vr81",              site: "monday.com",          tag: "Gestión" },
	{ name: "Apollo.io",       url: "https://get.apollo.io/mzxfxk1o1ea5",              site: "apollo.io",           tag: "Ventas" },
	{ name: "Close CRM",       url: "https://refer.close.com/bf9dumgltl5q",             site: "close.com",           tag: "CRM" },
	{ name: "Brevo",           url: "https://get.brevo.com/p76y9av2p0t1",              site: "brevo.com",           tag: "Email" },
	{ name: "Emergent",        url: "https://get.emergent.sh/qh22mu56q2fj",            site: "emergent.sh",         tag: "IA" },
	{ name: "Murf AI",         url: "https://get.murf.ai/e5a3jr17jump",               site: "murf.ai",             tag: "Voz IA" },
	{ name: "ActiveCampaign",  url: "https://try.activecampaign.com/x53ed2y6qns9",    site: "activecampaign.com",  tag: "Marketing" },
	{ name: "Kit",             url: "https://partners.kit.com/v78kkgp588z9-uw04r",    site: "kit.com",             tag: "Creadores" },
	{ name: "GetResponse",     url: "https://try.getresponsetoday.com/zxqczrj1idl8",  site: "getresponse.com",     tag: "Email" },
	{ name: "AdCreative.ai",   url: "https://free-trial.adcreative.ai/3fn5zxosagaz",  site: "adcreative.ai",       tag: "Ads IA" },
	{ name: "ClickUp",         url: "https://try.web.clickup.com/vrgnpqnkkxr6",       site: "clickup.com",         tag: "Productividad" },
	{ name: "ElevenLabs",      url: "https://try.elevenlabs.io/8w0jtxk54bd0",         site: "elevenlabs.io",       tag: "Voz IA" },
	{ name: "Wati.io",         url: "https://affiliates.wati.io/23d5qw8lx136",        site: "wati.io",             tag: "WhatsApp" },
	{ name: "Gamma",           url: "https://try.gamma.app/wupcgyzfekir",             site: "gamma.app",           tag: "Presentaciones" },
	{ name: "n8n",             url: "https://n8n.partnerlinks.io/8qtvuqc23ra6",       site: "n8n.io",              tag: "Automatización" },
];

function getFaviconUrl(site: string): string {
	return `https://t2.gstatic.com/faviconV2?client=SOCIAL&type=FAVICON&fallback_opts=TYPE,SIZE,URL&url=https://${site}&size=64`;
}

// Split into two rows (interleaved for visual balance)
const row1: Tool[] = ACTIVE_TOOLS.filter((_, i) => i % 2 === 0);
const row2: Tool[] = ACTIVE_TOOLS.filter((_, i) => i % 2 !== 0);
---

<section class="carousel-section" id="herramientas" aria-label="Herramientas recomendadas">
	<div class="carousel-header">
		<p class="carousel-eyebrow">Ecosistema de herramientas</p>
		<h2 class="carousel-title">
			Las mejores herramientas de IA
		</h2>
		<p class="carousel-subtitle">
			Probadas, usadas y recomendadas — pruébalas con mi enlace de afiliado
		</p>
	</div>

	<!-- Row 1: izquierda → -->
	<div class="carousel-row" aria-label="Herramientas fila 1">
		<div class="track track-left">
			{[...row1, ...row1].map((tool) => (
				<a
					href={tool.url}
					target="_blank"
					rel="noopener noreferrer"
					class="tool-card"
					aria-label={`${tool.name} — ${tool.tag}`}
				>
					<div class="tool-logo">
						<img
							src={getFaviconUrl(tool.site)}
							alt={`${tool.name} logo`}
							width="32"
							height="32"
							loading="lazy"
							decoding="async"
							onerror="this.style.display='none'"
						/>
					</div>
					<div class="tool-info">
						<span class="tool-name">{tool.name}</span>
						<span class="tool-tag">{tool.tag}</span>
					</div>
					<span class="tool-cta">Pruébalo →</span>
				</a>
			))}
		</div>
	</div>

	<!-- Row 2: derecha ← (reverse) -->
	<div class="carousel-row" aria-label="Herramientas fila 2">
		<div class="track track-right">
			{[...row2, ...row2].map((tool) => (
				<a
					href={tool.url}
					target="_blank"
					rel="noopener noreferrer"
					class="tool-card"
					aria-label={`${tool.name} — ${tool.tag}`}
				>
					<div class="tool-logo">
						<img
							src={getFaviconUrl(tool.site)}
							alt={`${tool.name} logo`}
							width="32"
							height="32"
							loading="lazy"
							decoding="async"
							onerror="this.style.display='none'"
						/>
					</div>
					<div class="tool-info">
						<span class="tool-name">{tool.name}</span>
						<span class="tool-tag">{tool.tag}</span>
					</div>
					<span class="tool-cta">Pruébalo →</span>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	/* ── Section wrapper ── */
	.carousel-section {
		background: #0d0f14;
		padding: 5rem 0;
		overflow: hidden;
		border-top: 1px solid rgba(255, 255, 255, 0.05);
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
	}

	/* ── Header ── */
	.carousel-header {
		text-align: center;
		max-width: 600px;
		margin: 0 auto 3rem;
		padding: 0 1.5rem;
	}

	.carousel-eyebrow {
		font-size: 0.8125rem;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #7c3aed;
		margin-bottom: 0.75rem;
	}

	.carousel-title {
		font-family: var(--font-display, var(--font-sans));
		font-size: clamp(1.75rem, 3vw, 2.5rem);
		font-weight: 800;
		color: #f1f5f9;
		letter-spacing: -0.03em;
		line-height: 1.15;
		margin-bottom: 0.75rem;
	}

	.carousel-subtitle {
		font-size: 1rem;
		color: #64748b;
		line-height: 1.6;
	}

	/* ── Row container (clips overflow) ── */
	.carousel-row {
		position: relative;
		margin-bottom: 1rem;
		/* Fade edges */
		mask-image: linear-gradient(
			90deg,
			transparent 0%,
			black 8%,
			black 92%,
			transparent 100%
		);
		-webkit-mask-image: linear-gradient(
			90deg,
			transparent 0%,
			black 8%,
			black 92%,
			transparent 100%
		);
	}

	.carousel-row:last-child { margin-bottom: 0; }

	/* ── Scrolling track ── */
	.track {
		display: flex;
		width: max-content;
		gap: 0.875rem;
		padding: 0.5rem 0;
	}

	.track-left {
		animation: scrollLeft 35s linear infinite;
	}

	.track-right {
		animation: scrollLeft 28s linear infinite reverse;
	}

	/* Pause on hover/focus-within for accessibility */
	.carousel-row:hover .track,
	.carousel-row:focus-within .track {
		animation-play-state: paused;
	}

	@keyframes scrollLeft {
		0%   { transform: translateX(0); }
		100% { transform: translateX(-50%); }
	}

	/* ── Tool card ── */
	.tool-card {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.75rem 1.25rem;
		background: rgba(30, 35, 48, 0.8);
		border: 1px solid rgba(255, 255, 255, 0.07);
		border-radius: 12px;
		text-decoration: none;
		color: #e2e8f0;
		white-space: nowrap;
		flex-shrink: 0;
		backdrop-filter: blur(8px);
		transition:
			border-color 0.2s ease,
			background 0.2s ease,
			transform 0.2s ease;
		min-width: 200px;
	}

	.tool-card:hover {
		border-color: rgba(124, 58, 237, 0.5);
		background: rgba(124, 58, 237, 0.12);
		transform: translateY(-2px);
		color: #e2e8f0;
	}

	/* ── Logo wrapper (1:1 ratio) ── */
	.tool-logo {
		width: 36px;
		height: 36px;
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.06);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		overflow: hidden;
	}

	.tool-logo img {
		width: 24px;
		height: 24px;
		object-fit: contain;
		border-radius: 4px;
	}

	/* ── Tool info ── */
	.tool-info {
		display: flex;
		flex-direction: column;
		gap: 0.125rem;
		flex: 1;
		min-width: 0;
	}

	.tool-name {
		font-size: 0.9375rem;
		font-weight: 600;
		color: #f1f5f9;
		line-height: 1.2;
	}

	.tool-tag {
		font-size: 0.6875rem;
		color: #475569;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	/* ── CTA text ── */
	.tool-cta {
		font-size: 0.8125rem;
		font-weight: 600;
		color: #7c3aed;
		white-space: nowrap;
		transition: color 0.15s ease;
	}

	.tool-card:hover .tool-cta {
		color: #a78bfa;
	}

	/* ── Reduced motion ── */
	@media (prefers-reduced-motion: reduce) {
		.track-left,
		.track-right {
			animation: none;
		}
		.carousel-row {
			overflow-x: auto;
		}
		.track {
			padding-bottom: 0.5rem;
		}
	}
</style>
