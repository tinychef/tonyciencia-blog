{
  "name": "tonyciencia",
  "version": "0.0.3",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "dev": "astro dev",
    "build:seed": "node scripts/build-seed.mjs",
    "check:seo-i18n": "node scripts/check-seo-i18n.mjs",
    "extract:seed": "node scripts/extract-seed-source.mjs",
    "build": "pnpm build:seed && astro build",
    "preview": "astro preview",
    "deploy": "pnpm build && wrangler deploy",
    "typecheck": "astro check",
    "bootstrap": "pnpm build:seed && emdash init && emdash seed",
    "seed": "pnpm build:seed && emdash seed"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.7",
    "@astrojs/react": "^5.0.0",
    "@astrojs/sitemap": "^3.7.2",
    "@emdash-cms/cloudflare": "^0.14.0",
    "@emdash-cms/plugin-forms": "^0.2.2",
    "@emdash-cms/plugin-webhook-notifier": "^0.2.0",
    "astro": "^6.0.1",
    "emdash": "^0.14.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@cloudflare/workers-types": "^4.20260305.1",
    "wrangler": "^4.80.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  },
  "emdash": {
    "label": "Tony Ciencia",
    "seed": "seed/seed.json"
  }
}
