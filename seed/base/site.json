        {
          "slug": "source",
          "label": "Source",
          "type": "string"
        },
        {
          "slug": "schema_type",
          "label": "Schema Type",
          "type": "string"
        },
        {
          "slug": "faq_items",
          "label": "FAQ Section",
          "type": "portableText"
        },
        {
          "slug": "key_entities",
          "label": "Key Entities (comma-separated)",
          "type": "string"
