        "_type": "block",
        "style": "normal",
        "markDefs": [
          {
            "_key": "l0",
            "_type": "link",
            "href": "https://www.streak.com/"
          }
        ],
        "children": [
          {
            "_type": "span",
            "text": "Then I tried ",
            "marks": []
