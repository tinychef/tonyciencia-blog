      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "2. ",
            "marks": []
          },
          {
            "_type": "span",
            "text": "The AI builds it.",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Base44's engine generates a full application with pages, navigation, databases, and logic. We're talking functional software, not a static mockup.",
