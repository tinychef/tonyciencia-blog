        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "One purchase, one activation, continuous coverage",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
