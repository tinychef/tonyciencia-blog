        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Enhanced Automations and Integrations",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "The automation library keeps expanding. monday.com now connects with over 200 apps — Slack, Google Workspace, Zoom, HubSpot, Salesforce, Jira, and many more. The integrations are native and smooth, not clunky workarounds.",
            "marks": []
