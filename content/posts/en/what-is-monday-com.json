      {
        "_type": "block",
        "style": "h3",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Workload View Improvements",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Managing team capacity just got easier. The updated workload view shows who's overbooked and who has bandwidth, so you can redistribute tasks before burnout hits.",
