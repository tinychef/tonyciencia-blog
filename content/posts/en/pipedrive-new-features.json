      {
        "_type": "block",
        "style": "h3",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Remote and Hybrid Sales Teams",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "With cloud access, real-time updates, and mobile apps, Pipedrive works whether your team is in the office, at home, or on the road. The real-time sales feed keeps everyone aligned without constant check-in meetings.",
            "marks": []
          }
        ]
