        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "If you're a founder wearing the sales hat, Pipedrive's Lite plan gives you a clean, affordable workspace to track leads and close deals. The AI reporting alone saves you from drowning in spreadsheets.",
            "marks": []
          }
        ]
      },
