          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "AISQ isn't the first meeting assistant on the market. But several features make it stand out in a crowded field.",
