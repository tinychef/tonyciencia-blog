      },
      {
        "_type": "block",
        "style": "h3",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Multi-Platform Support",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "AISQ works across Zoom, Google Meet, Microsoft Teams, and phone calls. You're not locked into one platform, which matters when your clients use Zoom but your internal team lives in Teams. One tool covers everything.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "h3",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Speaker Identification",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "The transcription doesn't just capture words—it attributes them to the right person. In meetings with multiple participants, this is the difference between usable notes and a wall of undifferentiated text.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "h3",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Automatic Action Item Extraction",
