      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Vague prompt:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " \"A video about morning routines.\"",
            "marks": []
          }
