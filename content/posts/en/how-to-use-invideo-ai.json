      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "This is where the magic starts. Click \"Create New Video\" and you'll see a prompt box. Type what you want — be as specific or as vague as you like.",
            "marks": []
          }
        ]
