      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "This usually takes 1-3 minutes depending on video length. Grab a coffee. When you come back, you'll have a full preview ready to watch.",
            "marks": []
          }
