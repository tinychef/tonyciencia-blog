          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Here's a tip I picked up after a few weeks: include the platform you're targeting (YouTube, Instagram, TikTok) and the tone you want (professional, casual, energetic). The AI adjusts pacing, aspect ratio, and visual style accordingly.",
            "marks": []
          }
