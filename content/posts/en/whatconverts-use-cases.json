          {
            "_type": "span",
            "text": "Use Case 1: Phone Call Attribution for Service Businesses",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Here's a scenario I see constantly.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "A plumbing company spends $4,000/month on Google Ads. They get calls. Some convert into jobs. But they have zero visibility into which keywords, ads, or landing pages are driving those high-value calls.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "WhatConverts assigns unique tracking numbers to each campaign. When someone calls, the platform logs:",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "The exact ad or keyword they clicked",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "The landing page they visited",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Call duration and recording",
            "marks": []
          }
