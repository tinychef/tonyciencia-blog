        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Prezi's 2025 updates make a strong case for ditching traditional slide decks. The AI presentation builder eliminates the blank-canvas problem. The zoom canvas keeps audiences engaged. The video recording features open up entirely new ways to communicate.",
            "marks": []
          }
        ]
      },
