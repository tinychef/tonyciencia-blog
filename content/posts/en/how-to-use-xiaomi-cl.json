          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "No. The Mi Home app works on both iOS and Android. You can control air purifiers, lamps, and other smart devices from any smartphone. A Xiaomi phone does unlock deeper integration through HyperOS, but it's not required.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Is Xiaomi CL available in the United States?",
            "marks": [
              "strong"
            ]
          }
