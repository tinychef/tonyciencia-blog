      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [
          {
            "_key": "l2",
            "_type": "link",
            "href": "https://tonyciencia.com/en/posts/bubble-use-cases"
          }
        ],
        "children": [
          {
            "_type": "span",
            "text": "Need a marketplace where buyers have many orders, each order has many line items, and each line item references a product? That's a few clicks in Bubble's database editor. ",
            "marks": []
          },
          {
            "_type": "span",
            "text": "Discover more use cases Bubble handles beautifully",
            "marks": [
              "l2"
