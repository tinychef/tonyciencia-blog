          }
        ],
        "children": [
          {
            "_type": "span",
            "text": "First off, ",
            "marks": []
          },
          {
            "_type": "span",
            "text": "download CapCut for free",
            "marks": [
              "l0"
            ]
          },
          {
            "_type": "span",
            "text": " to follow along. It's quick and opens up a world of possibilities.",
            "marks": []
