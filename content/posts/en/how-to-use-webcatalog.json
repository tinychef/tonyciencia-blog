            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "h2",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Your Step-by-Step Tutorial: From Web Tab to Desktop App",
