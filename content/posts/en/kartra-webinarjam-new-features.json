      },
      {
        "_type": "block",
        "style": "h3",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Calendar and Booking Enhancements",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Kartra's native calendar tool now supports:",
            "marks": []
