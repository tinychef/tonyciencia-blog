          }
        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "For course creators who sell transformation and accountability, that certificate feature alone is a small but meaningful differentiator.",
