          }
        ]
      },
      {
        "_type": "block",
        "style": "h2",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "New & Featured Functions You Should Know About",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Close ships updates regularly, and a few recent additions stand out:",
            "marks": []
