        "children": [
          {
            "_type": "span",
            "text": "Key Features That Make Nutshell Shine",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Beyond the tips above, here are the features that consistently impress Nutshell users:",
            "marks": []
          }
