      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Visual Pipeline Management",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " — Drag-and-drop deal tracking with customizable stages, weighted values, and probability scoring. It's the clearest pipeline view I've seen in any CRM at this price point.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Built-in Email Marketing",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " — Nutshell includes email marketing tools natively. You don't need a separate platform for newsletters, drip campaigns, or one-off blasts. This is rare for a CRM in its class and earned it recognition as a G2 leader in Email Marketing.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "People and Company Profiles",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " — Every contact gets a rich profile showing emails, calls, meetings, notes, and deal history in one place. No more digging through spreadsheets to remember who said what.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Reporting and Forecasting",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " — Real-time dashboards with customizable reports. Track pipeline velocity, conversion rates by stage, rep performance, and revenue forecasts. Export everything to PDF or share live links with stakeholders.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Task Management",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " — Built-in task queues let reps see exactly what needs attention today. Tasks can be tied to deals, contacts, or companies, and they integrate with your calendar.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Mobile App",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " — Full-featured iOS and Android app for updating deals, logging calls, and checking your pipeline from anywhere.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "API and Webhooks",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " — For teams with developers, Nutshell offers a robust API and webhook system for custom integrations and workflows.",
            "marks": []
          }
        ]
