          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "2. ",
            "marks": []
          },
          {
            "_type": "span",
            "text": "Connect Your Email & Calendar:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Close pulls in your existing emails and meetings, so you have immediate context. This step alone saves hours of manual data entry.",
