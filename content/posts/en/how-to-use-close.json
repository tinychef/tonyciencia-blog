      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "3. Add steps: a Day 1 email, a Day 3 call task, a Day 5 SMS, a Day 7 follow-up email.",
