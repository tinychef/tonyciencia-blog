      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "1. ",
            "marks": []
          },
          {
            "_type": "span",
            "text": "Create Your Account:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Head to close.com and sign up. The onboarding process is refreshingly straightforward.",
