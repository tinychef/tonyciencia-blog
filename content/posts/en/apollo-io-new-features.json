        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Scalable Pricing",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": ": The free plan is great for starters, and paid tiers offer more credits and features. I upgraded to the Professional plan after hitting limits, and the 20% annual discount made it a no-brainer for growing teams.",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
      },
      {
