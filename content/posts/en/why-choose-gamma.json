        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "I will be direct: Gamma has replaced about 70% of my presentation workflow. The other 30% is heavy customization for clients with strict brand guidelines — and even there, Gamma gives me a first draft that saves an hour.",
            "marks": []
