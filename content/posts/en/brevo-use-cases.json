  "data": {
    "title": "Brevo Email Marketing: 5 Use Cases Fueling Growth",
    "excerpt": "Discover how Brevo's CRM & multi-channel platform transforms email marketing for growing businesses. Real use cases to inspire your strategy.",
    "featured_image": {
      "$media": {
        "url": "https://tonyciencia.com/blog/brevo-use-cases.jpg",
        "alt": "Brevo Email Marketing: 5 Use Cases Fueling Growth",
