      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "The platform has earned its spot as a go-to recommendation for growing businesses that need to get their processes out of people's heads and into a system. It's well-designed, regularly updated, and backed by a team that clearly listens to customer feedback.",
            "marks": []
          }
