        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "If your CRM is full of incomplete records — missing emails, no phone numbers, outdated job titles — Seamless.AI's enrichment feature fills the gaps. You upload your list, and the platform verifies and updates contact details automatically.",
            "marks": []
          }
        ]
