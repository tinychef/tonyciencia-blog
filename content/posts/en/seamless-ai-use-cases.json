      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "This is a game-changer for marketing teams running account-based campaigns. Accurate data means better targeting, fewer bounces, and higher response rates.",
            "marks": []
          }
        ]
      },
      {
