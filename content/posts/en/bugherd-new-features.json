      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Web development agencies.",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Collecting feedback from multiple clients on staging sites becomes painless. Each client gets their own project, and nothing falls through the cracks.",
            "marks": []
