        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Freelance designers and developers.",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " If you build sites for clients who \"aren't technical,\" BugHerd removes the friction entirely. They point, you fix.",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "In-house product teams.",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " QA testers and product managers can annotate bugs directly on the live site and route them to engineering with full context.",
            "marks": []
