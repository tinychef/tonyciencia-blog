        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "UX researchers.",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " During user testing sessions, researchers can pin observations to specific UI elements in real time.",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
      },
