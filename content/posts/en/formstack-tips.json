        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Use approval steps sparingly.",
            "marks": [
