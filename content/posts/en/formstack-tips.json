      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Map your process on paper first.",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Don't start building until you know every step, decision point, and destination.",
            "marks": []
