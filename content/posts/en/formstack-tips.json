      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "The visual workflow builder in Formstack Suite connects your forms, documents, and signatures into automated sequences. This is where the real time savings happen.",
            "marks": []
          }
