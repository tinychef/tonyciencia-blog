      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Developers and technical professionals",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " who want to understand AI capabilities deeply enough to build with them, not just consume them.",
