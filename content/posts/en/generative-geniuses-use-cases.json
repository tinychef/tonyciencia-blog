      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Marketing teams",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " that want to integrate AI into their campaigns without guessing at prompts. The structured courses give you tested workflows, not just theory.",
