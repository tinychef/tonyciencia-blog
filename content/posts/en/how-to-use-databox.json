        "style": "h3",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Step 1: Sign Up and Explore the Free Plan",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [
