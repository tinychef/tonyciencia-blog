          {
            "_type": "span",
            "text": "Step 5: Automate Reports and Alerts",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Set up automated reports to send weekly PDFs to your team or clients. I schedule mine every Monday morning—it keeps everyone aligned without extra work. You can also create alerts for KPI thresholds, so you never miss a beat.",
            "marks": []
          }
        ]
