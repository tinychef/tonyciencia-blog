      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "1. ",
            "marks": []
          },
          {
            "_type": "span",
            "text": "Client fills out an intake form.",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " You've embedded the Formstack form on your website or sent a direct link. Smart logic adjusts fields based on the service they select. Required fields ensure nothing gets missed.",
