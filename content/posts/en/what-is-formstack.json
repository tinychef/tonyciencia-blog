      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Scenario:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " You run a mid-size consulting firm. Every new client needs to fill out an intake form, sign a service agreement, and receive an onboarding packet.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Here's how Formstack handles the entire flow:",
