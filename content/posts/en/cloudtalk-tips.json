            "text": "what is CloudTalk",
            "marks": [
              "l1"
            ]
          },
          {
            "_type": "span",
            "text": " on our site.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
