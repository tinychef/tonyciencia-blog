  "data": {
    "title": "Envato Elements: 28M+ Creative Assets, One Subscription",
    "excerpt": "Envato Elements gives you unlimited downloads of 28M+ templates, stock video, music, fonts, and AI tools. See why creators love it.",
    "featured_image": {
      "$media": {
        "url": "https://tonyciencia.com/blog/what-is-envato-elements.jpg",
        "alt": "Envato Elements: 28M+ Creative Assets, One Subscription",
