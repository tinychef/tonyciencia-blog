        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "AI Voice Over",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " — Generate natural-sounding voiceovers for videos, ads, and presentations.",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "AI Music & Sound Effects Generation",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
