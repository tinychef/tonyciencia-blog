        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "AI Graphics & Mockup Generation",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " — Generate design mockups, graphics, and visual assets on demand.",
