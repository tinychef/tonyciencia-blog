      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "4. Passives (7–8) receive an in-app message offering a 1:1 product walkthrough.",
            "marks": []
          }
