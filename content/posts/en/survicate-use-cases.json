        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "3. Promoters (9–10) are tagged in HubSpot and enrolled in an automated testimonial request flow.",
