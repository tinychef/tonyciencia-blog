        "children": [
          {
            "_type": "span",
            "text": "Connect Streak to tools like Slack, Google Sheets, Typeform, and 900+ apps via native integrations and webhooks. Set up triggers that update your CRM automatically when external events happen.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Data Validation (Enterprise)",
            "marks": [
