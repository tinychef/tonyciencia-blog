      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Can I use Streak with multiple Gmail accounts?",
            "marks": [
              "strong"
            ]
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Yes. Streak works across multiple Google accounts in the same browser. Each account gets its own pipelines and data, and you can switch between them easily.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Is Streak secure enough for sensitive business data?",
            "marks": [
              "strong"
            ]
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Streak is SOC 2 Type II certified and encrypts all data at rest and in transit. It runs entirely within Google's infrastructure, so your data never leaves the Google ecosystem. Enterprise plans add data validation and audit logs for extra peace of mind.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "What happens to my data if I stop using Streak?",
            "marks": [
              "strong"
            ]
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Your Gmail messages stay exactly where they are—Streak doesn't copy or move your emails. Pipeline data can be exported to CSV at any time. You own your data, period.",
            "marks": []
          }
        ]
      }
