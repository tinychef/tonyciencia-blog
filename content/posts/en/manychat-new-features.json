      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "3. ",
            "marks": []
          },
          {
            "_type": "span",
            "text": "Keep flows short.",
            "marks": [
              "strong"
            ]
