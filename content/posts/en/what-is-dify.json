          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Conversation Memory Management",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " — Fine-tune how your chatbot remembers previous interactions. Set window sizes, summarize long conversations, or use entity memory to track specific details across sessions.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Structured Output Parsing",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " — Force the LLM to return JSON, tables, or specific data formats. This is essential when you're feeding AI output into downstream systems.",
