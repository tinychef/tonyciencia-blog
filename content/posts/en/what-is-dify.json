          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "You have an AI-powered product idea but not a full engineering team. Dify lets you prototype in hours and ship in days. The free tier is generous enough to build and validate before you commit.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
