      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Multi-Language Support in the Knowledge Base",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " — Upload documents in different languages and the system handles cross-lingual retrieval. Ask a question in Spanish, get an answer from an English document.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Custom Tool Creation via OpenAPI",
            "marks": [
              "strong"
            ]
