  "data": {
    "title": "Staff Scheduling Software: 7 Shiftie Use Cases That Save Hours",
    "excerpt": "Discover how Shiftie staff scheduling software transforms shift planning, attendance tracking, and team management. Try it free for 28 days today.",
    "featured_image": {
      "$media": {
        "url": "https://tonyciencia.com/blog/shiftie-use-cases.jpg",
        "alt": "Staff Scheduling Software: 7 Shiftie Use Cases That Save Hours",
