          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Instantly keeps its pricing transparent. There are three main tiers:",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Growth Plan",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " — Designed for individuals and small teams getting started with cold email. Includes unlimited email accounts, automated warmup, and core campaign features.",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Hypergrowth Plan",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " — Built for scaling teams that need higher sending limits, advanced AI features, and priority support.",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
