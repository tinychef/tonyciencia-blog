        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Goals:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Use the \"Goals\" feature to set and track larger objectives (OKRs, for instance). You can nest smaller targets under a goal and connect relevant tasks. Watching your progress bar fill up is surprisingly motivating.",
            "marks": []
          }
        ]
