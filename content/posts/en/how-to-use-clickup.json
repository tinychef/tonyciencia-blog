            "_type": "span",
            "text": "Spaces > Folders > Lists > Tasks",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": ". This is your filing cabinet for everything.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Space:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " A broad category (e.g., \"Marketing,\" \"Engineering,\" \"Personal Projects\").",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Folder:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " A subdivision within a Space (e.g., inside \"Marketing,\" you might have \"Q4 Campaigns\" or \"Social Media\").",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "List:",
            "marks": [
