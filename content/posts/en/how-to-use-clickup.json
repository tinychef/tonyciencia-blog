      {
        "_type": "block",
        "style": "normal",
        "markDefs": [
          {
            "_key": "l1",
            "_type": "link",
            "href": "https://try.web.clickup.com/vrgnpqnkkxr6"
          }
        ],
        "children": [
          {
            "_type": "span",
            "text": "First things first, head over to ",
            "marks": []
