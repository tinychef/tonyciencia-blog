      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "AI Credits System:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Every plan now includes monthly AI credits that power Chloe and other AI-assisted features. Solo gets 500/month, Essentials gets 1,000/user, Growth gets 1,500/user. Credits refresh monthly and additional credits are available if you need more.",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
