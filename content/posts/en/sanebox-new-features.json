        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "SaneBlackHole",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": ": A fun way to banish unwanted senders—drag an email to this folder, and future emails from that address disappear forever. Goodbye, spam!",
            "marks": []
          }
