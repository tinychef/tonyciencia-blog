      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Is OpenArt AI free to use?",
            "marks": [
              "strong"
            ]
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Yes. OpenArt offers a free tier with enough credits to explore the platform and generate a solid number of images. Paid plans unlock more credits, faster generation, commercial rights, and advanced features like consistent characters and custom model training.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Can I use OpenArt AI images commercially?",
            "marks": [
              "strong"
            ]
          }
        ]
