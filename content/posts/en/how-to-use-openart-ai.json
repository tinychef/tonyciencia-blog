        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Step 1: Sign Up and Access the Workspace",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [
          {
