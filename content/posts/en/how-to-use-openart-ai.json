        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Hit \"Create\" and wait a few seconds. OpenArt generates images fast, especially on paid tiers where you get up to 16 parallel generations at once.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "When your images appear, you can:",
