      {
        "_type": "block",
        "style": "h2",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Pricing: What Each Tier Gets You",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "OpenArt offers three main subscription levels, and the current annual pricing (50% off) makes them genuinely affordable:",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "| Plan | Price (Annual) | Credits/Month | Images | Videos | Characters |",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "|------|---------------|---------------|--------|--------|------------|",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "| Essential | $7/mo | 4,000 | ~4,000 | ~50 | ~13 |",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "| Advanced | $14.50/mo | 12,000 | ~12,000 | ~150 | ~40 |",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "| Infinite | $28/mo | 24,000 | ~24,000 | ~300 | ~80 |",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "The Advanced plan hits the sweet spot for most creators. You get commercial use rights, 16 parallel generations, and enough credits for serious daily use. If you are just exploring, the Essential plan is more than enough to fall in love with the tool.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [
          {
            "_key": "l6",
            "_type": "link",
            "href": "https://openartai.pxf.io/c/6249333/3106413/38572"
          }
        ],
        "children": [
          {
            "_type": "span",
            "text": "Pick the plan that fits your creative workflow",
            "marks": [
              "l6"
            ]
          },
          {
            "_type": "span",
            "text": " and start generating today.",
            "marks": []
          }
        ]
