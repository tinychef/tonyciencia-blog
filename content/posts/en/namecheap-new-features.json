        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Every hosting account now includes a free Positive SSL certificate. No more paying $10-15 extra per year just to get that padlock icon in browsers. For small sites and blogs, this alone saves money immediately.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Enhanced EasyWP WordPress Hosting",
