      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "I went with a local number in my area code. Within 60 seconds, it was live. I sent a test text to my own phone. It arrived instantly, showing the business name I configured.",
