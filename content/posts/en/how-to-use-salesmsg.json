          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "One thing I genuinely appreciate: Salesmsg handles all the carrier registration and compliance stuff (10DLC, A2P) behind the scenes. You don't need to understand telecom jargon. They just make sure your messages deliver.",
            "marks": []
          }
