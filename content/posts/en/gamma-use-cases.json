        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Gamma compresses that workflow dramatically.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Its social media feature lets you generate platform-specific content from a single prompt. Need a LinkedIn carousel summarizing your latest blog post? Done. Want an Instagram-friendly infographic with your key stats? Easy. Need a Twitter/X thread outline? Gamma handles it.",
            "marks": []
