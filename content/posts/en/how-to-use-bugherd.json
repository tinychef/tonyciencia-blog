  "data": {
    "title": "BugHerd Tutorial: Collect Website Feedback in Minutes",
    "excerpt": "Learn how to use BugHerd to gather visual website feedback. Clients point, click, comment—done. Step-by-step setup guide inside.",
    "featured_image": {
      "$media": {
        "url": "https://tonyciencia.com/blog/how-to-use-bugherd.jpg",
