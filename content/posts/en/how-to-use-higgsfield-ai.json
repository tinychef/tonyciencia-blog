      {
        "_type": "block",
        "style": "h2",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Step 3: Choose Your Camera Movement",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "This is Higgsfield's signature feature, and it deserves its own step.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "After entering your prompt, you'll see camera movement options. The platform offers a curated set of cinematic movements, each modeled after real filmmaking techniques:",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Dolly in/out",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " — Smooth approach or retreat toward the subject",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Tracking shot",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " — Camera follows the subject laterally",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Crane shot",
            "marks": [
              "strong"
            ]
          },
          {
