      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Let me be direct: construction management software has a reputation for being bloated and painful to learn. That's the thing reviewers keep pointing out about Contractor Foreman — it's different. Capterra's own summary says it plainly: *\"What sets Contractor Foreman apart from its competitors is its ease of use.\"",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Here are the capabilities that matter most to working contractors:",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Project Management",
            "marks": [
              "strong"
            ]
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Create projects, assign tasks, set milestones, and track progress in real time. You can see at a glance which jobs are on schedule and which ones need attention. The daily log feature lets foremen record site activity, weather conditions, and issues — which creates a paper trail that protects you legally.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Financials & Invoicing",
            "marks": [
              "strong"
            ]
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Build estimates, convert them into budgets, and track actual costs against projections as the job moves forward. When it's time to bill, you can generate invoices directly from the platform and even accept online payments. No more chasing checks.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Time Cards with GPS Tracking",
            "marks": [
              "strong"
            ]
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Your crew clocks in from their phones, and the system logs their location. That means accurate time records without the hassle of paper timesheets or buddy-punching. Payroll gets a lot less painful.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Work Orders & Change Orders",
            "marks": [
              "strong"
            ]
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Create, assign, and track work orders on the fly. Change orders are documented with proper approval workflows, so scope creep doesn't turn into a financial surprise at the end of the project.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Document Management",
            "marks": [
              "strong"
            ]
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Plans, contracts, permits, photos, inspection reports — upload everything to the project folder and access it from anywhere. Unlimited storage across all plans means you're never forced to delete old files to make room.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Client Portal",
            "marks": [
              "strong"
            ]
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Share project updates, photos, and documents with clients through a branded portal. It looks professional and reduces the number of \"how's the project going?\" calls your office field every week.",
            "marks": []
          }
        ]
