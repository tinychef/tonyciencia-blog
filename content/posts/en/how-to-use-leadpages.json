        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Use it as the landing page for your Facebook or Google Ads.",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "The analytics dashboard then shows you real-time traffic, conversions, and A/B test performance. Seeing your conversion rate climb after a test is genuinely exciting.",
            "marks": []
