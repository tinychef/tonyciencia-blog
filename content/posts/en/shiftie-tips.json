      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Publish rotas early.",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Two weeks ahead is the sweet spot. It gives employees time to flag conflicts and swap shifts if needed.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Review timesheets weekly, not monthly.",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Catching discrepancies early prevents payroll headaches. Shiftie makes this fast — just scan the timesheet tab every Friday.",
            "marks": []
          }
