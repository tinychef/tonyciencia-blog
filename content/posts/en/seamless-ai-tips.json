      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Filter by job title specificity.",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Don't search for \"Manager.\" Search for \"Director of Demand Generation\" or \"Head of Sales Operations.\" Narrow titles mean more relevant leads and fewer wasted reveals.",
