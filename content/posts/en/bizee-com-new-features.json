      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [
          {
            "_key": "l4",
            "_type": "link",
            "href": "https://bizee.com/business-formation/business-license-research-package"
          }
        ],
        "children": [
          {
            "_type": "span",
            "text": "This one's a sleeper hit. Every state — and often every city — has different licensing requirements depending on your industry. Bizee's new ",
            "marks": []
          },
          {
            "_type": "span",
            "text": "Business License Research Package",
            "marks": [
              "l4"
            ]
          },
          {
            "_type": "span",
            "text": " identifies exactly which permits and licenses you need based on your business type and location. No more guessing, no more Googling municipal codes at 2 AM.",
            "marks": []
          }
