        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Virtual numbers in 50+ countries. Automatic call recording. IVR that routes like a seasoned receptionist. Analytics that turn every conversation into actionable data. An AI Voice Agent that never sleeps.",
