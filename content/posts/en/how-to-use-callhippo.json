        "children": [
          {
            "_type": "span",
            "text": "Leverage integrations aggressively.",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " ",
            "marks": []
          },
          {
            "_type": "span",
            "text": "Connect CallHippo with your existing stack",
            "marks": [
              "l6"
            ]
          },
          {
            "_type": "span",
            "text": "—whether that's Apollo.io for prospect data, monday.com for project tracking, or Slack for real-time call notifications. Every integration reduces manual work and keeps information flowing.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
