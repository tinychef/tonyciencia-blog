        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Date",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " — deadlines and milestones",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Person",
            "marks": [
              "strong"
            ]
          },
          {
