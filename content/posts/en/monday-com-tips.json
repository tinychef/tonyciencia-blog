      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Rename columns",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " to match your team's vocabulary. If you call deadlines \"ship dates,\" change it. Familiar language reduces friction.",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Add your own status labels.",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " The default \"Working on it\" might not cut it for your workflow. I've seen teams use labels like \"Awaiting client feedback\" or \"In QA\" — super specific, super useful.",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
