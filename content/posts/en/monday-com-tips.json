            "marks": [
              "strong"
            ]
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Trigger: *Every Monday at 9 AM* → Action: *Send a summary email of all items in progress.*",
