          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Leadership gets visibility. Team members stay aligned. Everyone starts the week informed.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "The beauty is that these take under five minutes to set up. Once running, they work silently in the background — freeing your brain for the work that actually needs creative thinking.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [
