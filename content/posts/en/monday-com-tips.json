        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "The deadline watchdog.",
            "marks": [
              "strong"
            ]
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Trigger: *When a date arrives* → Action: *Change status to \"Overdue\" and notify the assigned person.*",
