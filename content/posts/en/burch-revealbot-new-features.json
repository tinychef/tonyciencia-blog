      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [
          {
            "_key": "l5",
            "_type": "link",
            "href": "https://join.bir.ch/8lplegjqn6ru"
          }
        ],
        "children": [
          {
            "_type": "span",
            "text": "Bürch's pricing is refreshingly straightforward: it's based on your monthly ad spend, starting with the Essential plan at $49 per month for up to $10K in spend. You save 20% with annual billing, and there are no hidden overages—just transparent costs that scale with your growth. Considering the time saved and performance gains, it's an investment that pays for itself quickly. ",
            "marks": []
          },
          {
            "_type": "span",
            "text": "Give Bürch a try with their free plan",
            "marks": [
              "l5"
            ]
          },
          {
            "_type": "span",
            "text": " to see the difference.",
            "marks": []
          }
        ]
