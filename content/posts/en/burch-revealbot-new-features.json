          {
            "_key": "l3",
            "_type": "link",
            "href": "https://tonyciencia.com/en/posts/burch-revealbot-use-cases"
          }
        ],
        "children": [
          {
            "_type": "span",
            "text": "Bürch is perfect for small to medium-sized marketing teams juggling multiple ad accounts. If you're an e-commerce brand, a digital agency, or a solo marketer managing up to $10K in monthly ad spend, this tool is tailored for you. It simplifies complexity, so even if you're not a tech expert, you can run high-performing campaigns. Discover more use cases in our ",
            "marks": []
          },
          {
            "_type": "span",
            "text": "detailed guide",
            "marks": [
              "l3"
            ]
          },
          {
            "_type": "span",
