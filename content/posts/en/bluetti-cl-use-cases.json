        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "A ",
            "marks": []
          },
          {
            "_type": "span",
            "text": "homeowner",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " in an area with frequent outages (hurricane zones, wildfire regions, rural areas with aging infrastructure)",
