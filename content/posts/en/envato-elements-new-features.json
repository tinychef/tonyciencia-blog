          }
        ]
      },
      {
        "_type": "block",
        "style": "h3",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Is the Envato Elements commercial license really lifetime?",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Yes. Every asset you download from Envato Elements — including AI-generated content — comes with a lifetime commercial license. Even if you cancel your subscription, the license for assets you've already downloaded remains valid for commercial use with no attribution required.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "h3",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "How many AI generations do I get per month?",
            "marks": []
