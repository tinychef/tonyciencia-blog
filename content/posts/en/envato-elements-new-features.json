      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "One subscription, zero context-switching.",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Before, you might need a stock video site, a separate music library, a font subscription, an AI image tool, and a video editor. Now, Envato Elements covers nearly all of it in one dashboard.",
