        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "It depends on your tier. The Core plan ($16.50/month) includes 10 AI generations per month. The Plus plan ($39/month) includes 100 AI generations. The Ultimate plan ($109/month) offers the highest generation capacity. AI generations cover image, video, voiceover, music, sound effects, and graphics creation.",
            "marks": []
          }
        ]
      },
      {
