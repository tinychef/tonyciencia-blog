        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "The platform connects serious sellers with thousands of active buyers across more than 100 countries. Whether someone is looking to offload a local bakery, acquire a SaaS company, or invest in a franchise abroad, this is the kind of place where those conversations happen.",
            "marks": []
          }
