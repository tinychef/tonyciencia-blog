          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "SaaS companies",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " running product demos and qualification calls love the built-in calling and pipeline features. The speed-to-lead automation with Chloe is particularly powerful for high-volume inbound.",
