      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "The learning curve is gentle. I've seen teams go from signup to full adoption in less than a week. Compare that to enterprise CRMs that require months of implementation—Close respects your time.",
            "marks": []
          }
        ]
