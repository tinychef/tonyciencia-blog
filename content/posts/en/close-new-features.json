          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Day 4-5:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Train your team. Close's interface is intuitive enough that most reps are making calls and sending sequences within their first session.",
