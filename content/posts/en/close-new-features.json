        "_type": "block",
        "style": "h2",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "The Bottom Line",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Close in 2025 isn't just keeping up with the AI revolution—it's leading it for inside sales teams. Chloe changes the game by handling the first mile of sales engagement, so your human reps can focus on what they do best: building relationships and closing deals.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "If you're tired of CRMs that force you into workarounds for calling and texting, or you're watching speed-to-lead costs you deals, Close deserves your attention.",
            "marks": []
          }
        ]
      },
