          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Day 3:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Activate Chloe on a test batch of leads. Watch her qualify and book meetings. Adjust her qualification criteria based on early results.",
