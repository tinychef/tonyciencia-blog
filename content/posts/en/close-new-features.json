  "data": {
    "title": "Close CRM 2025: New AI Sales Agent Chloe & Features",
    "excerpt": "Discover Close CRM's latest features including Chloe, the AI sales agent that calls your leads. See why 11,500+ teams choose Close → Try free today.",
    "featured_image": {
      "$media": {
        "url": "https://tonyciencia.com/blog/close-new-features.jpg",
        "alt": "Close CRM 2025: New AI Sales Agent Chloe & Features",
