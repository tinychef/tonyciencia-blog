      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "B2B SaaS Companies:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Especially those with technical products where support conversations are deep and happen in developer-centric tools like Slack.",
            "marks": []
