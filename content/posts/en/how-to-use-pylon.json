        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Enterprise Support Teams:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " That need to manage SLAs, multiple stakeholders, and high-touch communication across formal (email) and informal (Slack) channels.",
