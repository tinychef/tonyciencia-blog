        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "The licensing simplicity alone saves me mental energy I used to spend tracking which asset came from which platform and what rights I had.",
            "marks": []
