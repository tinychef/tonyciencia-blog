      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Here's a number that might surprise you: there are over 4,000 known data brokers operating globally. In the US alone, companies like Acxiom, CoreLogic, and LexisNexis maintain profiles on virtually every adult.",
            "marks": []
          }
        ]
