    "content": [
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "*Disclosure: This post contains affiliate links. If you book through them, I may earn a small commission at no extra cost to you — it helps keep TonyCiencia running.*",
