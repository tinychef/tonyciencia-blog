        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Negocios con Horarios Extendidos o Urgencias:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Clínicas veterinarias, servicios de reparación (plomería, cerrajería), propiedades de alquiler vacacional. Una llamada a las 3 AM no es un dolor de cabeza, es una oportunidad capturada.",
