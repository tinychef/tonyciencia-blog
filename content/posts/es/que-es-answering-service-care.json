        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "PYMEs con Equipos Pequeños:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Negocios donde el dueño o un par de empleados lo hacen todo. Liberar tiempo de atención telefónica significa poder enfocarse en ventas o producción.",
            "marks": []
