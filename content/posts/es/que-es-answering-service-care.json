        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Profesionales Autónomos y Freelancers:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Abogados, consultores, arquitectos, médicos privados. Cuando estás en una reunión o con un cliente, no pierdes la siguiente consulta.",
            "marks": []
