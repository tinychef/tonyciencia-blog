        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Edición basada en texto:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Elimina \"ehms\", \"ahs\", pausas largas o secciones enteras seleccionándolas en la transcripción. El video se adapta al instante.",
            "marks": []
          }
        ],
        "listItem": "bullet",
