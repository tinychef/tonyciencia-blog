  "data": {
    "title": "Shiftie: Programación de turnos para equipos sin estrés",
    "excerpt": "Descubre qué es Shiftie y cómo simplifica la programación de turnos, gestión de equipos y control de asistencia. Prueba gratis.",
    "featured_image": {
      "$media": {
        "url": "https://tonyciencia.com/blog/que-es-shiftie.jpg",
