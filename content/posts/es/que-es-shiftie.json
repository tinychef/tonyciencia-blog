        "children": [
          {
            "_type": "span",
            "text": "Ahorra horas semanales",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " en administración manual.",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
