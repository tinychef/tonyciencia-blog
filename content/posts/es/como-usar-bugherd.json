            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": ": Puede ser un compañero de equipo o, mejor aún, un cliente de confianza para una prueba piloto.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
