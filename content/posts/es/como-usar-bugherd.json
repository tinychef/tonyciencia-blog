            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": ": Abre tu web, activa el sidebar de BugHerd y señala cualquier cosa. Experimenta lo fácil que es.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [
