      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Esto es un superpoder para marketers. En lugar de invertir horas en crear una sola versión perfecta, produces múltiples variantes rápidamente y optimizas basándote en datos reales.",
            "marks": []
          }
