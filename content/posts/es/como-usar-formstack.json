      },
      {
        "_type": "block",
        "style": "h2",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Conclusión: De la Fricción a la Fluidez",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
