      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Departamentos de Recursos Humanos:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
