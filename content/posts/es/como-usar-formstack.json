        "children": [
          {
            "_type": "span",
            "text": "Marketing y Agencias:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Captura de leads con formularios inteligentes que alimentan directamente tu CRM, y generación automática de propuestas personalizadas basadas en las respuestas.",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [
          {
            "_key": "l4",
            "_type": "link",
