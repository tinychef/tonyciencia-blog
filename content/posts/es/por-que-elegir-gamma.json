            "_type": "span",
            "text": "1. ",
            "marks": []
          },
          {
            "_type": "span",
            "text": "Importación inteligente",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": ": Sube un PDF o archivo PPTX y Gamma lo transforma en una presentación web editable. Ideal para modernizar materiales antiguos sin empezar de cero.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "2. ",
            "marks": []
          },
          {
            "_type": "span",
            "text": "Exportación versátil",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": ": Descarga en PDF, PPTX (para PowerPoint/Google Slides), PNG, o comparte como enlace web interactivo. Perfecto para diferentes contextos.",
