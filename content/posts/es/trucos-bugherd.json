        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "En una sesión de 30 minutos, recibo entre 15 y 40 comentarios puntuales. Antes, eso tomaba 3 reuniones y un documento de 8 páginas.",
