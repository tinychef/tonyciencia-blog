        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Les pido que marquen *todo* lo que les llama la atención: colores, espaciado, copy, flujo.",
