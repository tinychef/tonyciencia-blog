        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Cualquier persona que valore el control y la imagen:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " Si te molesta que tu plataforma de cursos tenga su logo por todas partes, aquí tienes la solución definitiva.",
