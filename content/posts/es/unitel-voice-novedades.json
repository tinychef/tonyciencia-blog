        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "1. ",
            "marks": []
          },
          {
            "_type": "span",
            "text": "Crea tu cuenta",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " en la plataforma de Unitel Voice. Ellos usan PartnerStack para gestionar afiliados y partners, lo cual da confianza adicional porque es un ecosistema reconocido.",
