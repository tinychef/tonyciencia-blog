        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "2. ",
            "marks": []
          },
          {
            "_type": "span",
            "text": "Script de saludo",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": ": Cómo quieres que te presenten. Ejemplo: \"Buenos días, gracias por llamar a [Tu Empresa]. ¿En qué puedo ayudarle?\"",
