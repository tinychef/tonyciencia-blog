          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Procesamiento de facturas con excepciones manejadas:",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " El bot extrae datos, valida contra el ERP, y si hay discrepancia, genera una tarea de revisión con toda la contexto adjunto — no un email genérico.",
            "marks": []
          }
        ],
        "listItem": "bullet",
        "level": 1
      },
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
