            "text": "comportamiento",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": ". Aquí es donde ",
            "marks": []
          },
          {
            "_type": "span",
            "text": "Amplitude",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": " se vuelve tu mejor aliado. No es otra herramienta de analytics más; es un microscopio para tu producto.",
            "marks": []
          }
