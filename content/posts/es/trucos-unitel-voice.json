    "content": [
      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "(Divulgación: este contenido incluye enlaces de afiliado. Si realizas una compra a través de ellos, puedo recibir una comisión sin costo adicional para ti.)",
            "marks": []
