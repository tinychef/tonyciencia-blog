        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Cualquier persona curiosa",
            "marks": [
              "strong"
            ]
          },
          {
            "_type": "span",
            "text": ": Que quiera experimentar con la automatización y la IA sin barreras técnicas. Su comunidad open-source es muy activa y solidaria.",
