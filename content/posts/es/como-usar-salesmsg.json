      {
        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "2.  Selecciona ",
            "marks": []
          },
          {
            "_type": "span",
            "text": "\"Enviar a múltiples contactos\"",
            "marks": [
              "strong"
