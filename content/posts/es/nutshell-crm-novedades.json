        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "*Este artículo contiene enlaces de afiliado. Si realizas una compra a través de ellos, puedo recibir una comisión sin costo adicional para ti. Solo recomiendo herramientas que uso y confío.*",
            "marks": []
          }
