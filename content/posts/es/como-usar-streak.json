        "_type": "block",
        "style": "normal",
        "markDefs": [],
        "children": [
          {
            "_type": "span",
            "text": "Streak está diseñado específicamente para Gmail y Google Workspace. No tiene integración nativa con Outlook. Si tu correo es de Google, es la herramienta perfecta.",
